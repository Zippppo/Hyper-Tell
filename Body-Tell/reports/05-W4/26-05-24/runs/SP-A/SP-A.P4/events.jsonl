ne:\n    49\t    torch.manual_seed(0)\n    50\t    model = VoxTellBodyModel(\n    51\t        VoxTellBodyConfig(\n    52\t            input_channels=1,\n    53\t            encoder_channels=(4, 8, 16),\n    54\t            text_embedding_dim=8,\n    55\t            query_dim=16,\n    56\t            transformer_num_heads=4,\n    57\t            transformer_layers=1,\n    58\t            num_maskformer_stages=3,\n    59\t            num_heads=2,\n    60\t            deep_supervision=True,\n    61\t        )\n    62\t    )\n    63\t\n    64\t    occupancy = torch.randn(1, 1, 16, 16, 16)\n    65\t    text_embeddings = torch.randn(1, 2, 8)\n    66\t\n    67\t    logits = model(occupancy, text_embeddings)\n    68\t\n    69\t    assert isinstance(logits, list)\n    70\t    assert [tuple(item.shape) for item in logits] == [\n    71\t        (1, 2, 16, 16, 16),\n    72\t        (1, 2, 8, 8, 8),\n    73\t    ]\n    74\t\n    75\t\n    76\tdef test_voxtell_body_model_returns_five_aligned_decoder_outputs() -> None:\n    77\t    torch.manual_seed(0)\n    78\t    model = VoxTellBodyModel(\n    79\t        VoxTellBodyConfig(\n    80\t            input_channels=1,\n    81\t            encoder_channels=(4, 8, 16, 16, 16, 16),\n    82\t            text_embedding_dim=8,\n    83\t            query_dim=16,\n    84\t            text_projection_hidden_dim=16,\n    85\t            transformer_num_heads=4,\n    86\t            transformer_layers=1,\n    87\t            transformer_feedforward_dim=32,\n    88\t            num_maskformer_stages=5,\n    89\t            num_heads=2,\n    90\t            deep_supervision=True,\n    91\t        )\n    92\t    )\n    93\t\n    94\t    assert len(model.decoder.stages) == 5\n    95\t    assert len(model.decoder.transpconvs) == 5\n    96\t    assert len(model.decoder.seg_layers) == 5\n    97\t    assert len(model.project_to_decoder_channels) == 5\n    98\t    assert all(isinstance(layer, nn.Conv3d) for layer in model.decoder.seg_layers)\n    99\t    assert [\n   100\t        projection[-1].out_features\n   101\t        for projection in model.project_to_decoder_channels\n   102\t    ] == [4, 16, 32, 32, 32]\n   103\t\n   104\t    occupancy = torch.randn(1, 1, 32, 32, 32)\n   105\t    text_embeddings = torch.randn(1, 2, 8)\n   106\t\n   107\t    logits = model(occupancy, text_embeddings)\n   108\t\n   109\t    assert isinstance(logits, list)\n   110\t    assert [tuple(item.shape) for item in logits] == [\n   111\t        (1, 2, 32, 32, 32),\n   112\t        (1, 2, 16, 16, 16),\n   113\t        (1, 2, 8, 8, 8),\n   114\t        (1, 2, 4, 4, 4),\n   115\t        (1, 2, 2, 2, 2),\n   116\t    ]\n   117\t    state_dict = model.state_dict()\n   118\t    assert \"decoder.transpconvs.0.weight\" in state_dict\n   119\t    assert \"decoder.stages.0.convs.0.conv.weight\" in state_dict\n   120\t    assert all(f\"decoder.seg_layers.{idx}.weight\" in state_dict for idx in range(5))\n   121\t    assert any(key.startswith(\"decoder.encoder.\") for key in state_dict)\n   122\t\n   123\t\n   124\tdef test_voxtell_body_model_preserves_non_cubic_dhw_axes() -> None:\n   125\t    torch.manual_seed(0)\n   126\t    model = VoxTellBodyModel(\n   127\t        VoxTellBodyConfig(\n   128\t            input_channels=1,\n   129\t            encoder_channels=(2, 4, 4, 4, 4, 4),\n   130\t            text_embedding_dim=8,\n   131\t            query_dim=8,\n   132\t            text_projection_hidden_dim=8,\n   133\t            transformer_num_heads=2,\n   134\t            transformer_layers=1,\n   135\t            transformer_feedforward_dim=16,\n   136\t            num_maskformer_stages=5,\n   137\t            num_heads=2,\n   138\t            deep_supervision=True,\n   139\t        )\n   140\t    )\n   141\t    model.eval()\n   142\t\n   143\t    projected_bottleneck_shapes: list[tuple[int, ...]] = []\n   144\t\n   145\t    def capture_bottleneck_input(\n   146\t        _module: nn.Module,\n   147\t        inputs: tuple[torch.Tensor, ...],\n   148\t        _output: torch.Tensor,\n   149\t    ) -> None:\n   150\t        projected_bottleneck_shapes.append(tuple(inputs[0].shape))\n   151\t\n   152\t    hook = model.project_bottleneck_embed.register_forward_hook(capture_bottleneck_input)\n   153\t    try:\n   154\t        occupancy = torch.randn(1, 1, 32, 64, 96)\n   155\t        text_embeddings = torch.randn(1, 2, 8)\n   156\t\n   157\t        with torch.no_grad():\n   158\t            logits = model(occupancy, text_embeddings)\n   159\t    finally:\n   160\t        hook.remove()\n   161\t\n   162\t    assert projected_bottleneck_shapes == [(1, 2, 3, 1, 4)]\n   163\t    assert isinstance(logits, list)\n   164\t    assert [tuple(item.shape) for item in logits] == [\n   165\t        (1, 2, 32, 64, 96),\n   166\t        (1, 2, 16, 32, 48),\n   167\t        (1, 2, 8, 16, 24),\n   168\t        (1, 2, 4, 8, 12),\n   169\t        (1, 2, 2, 4, 6),\n   170\t    ]\n   171\t\n   172\t\n   173\tdef test_voxtell_decoder_rejects_stride_mismatched_inputs() -> None:\n   174\t    torch.manual_seed(0)\n   175\t    model = VoxTellBodyModel(\n   176\t        VoxTellBodyConfig(\n   177\t            input_channels=1,\n   178\t            encoder_channels=(4, 8, 16),\n   179\t            text_embedding_dim=8,\n   180\t            query_dim=16,\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_66","type":"command_execution","command":"/bin/bash -lc \"nl -ba Body-Tell/body_tell/models/voxtell_body_model.py | sed -n '40,185p'\"","aggregated_output":"    40\t\n    41\tclass VoxTellBodyModel(nn.Module):\n    42\t    \"\"\"Prompt-conditioned binary mask model using VoxTell-style dynamic heads.\"\"\"\n    43\t\n    44\t    def __init__(self, config: VoxTellBodyConfig | None = None) -> None:\n    45\t        super().__init__()\n    46\t        self.config = config or VoxTellBodyConfig()\n    47\t        if self.config.query_dim % self.config.transformer_num_heads != 0:\n    48\t            raise ValueError(\"query_dim must be divisible by transformer_num_heads\")\n    49\t        if len(self.config.encoder_channels) < 2:\n    50\t            raise ValueError(\"encoder_channels must contain at least two stages\")\n    51\t        if self.config.num_maskformer_stages < 1:\n    52\t            raise ValueError(\"num_maskformer_stages must be at least 1 for the dynamic mask head\")\n    53\t        if self.config.num_heads < 1:\n    54\t            raise ValueError(\"num_heads must be at least 1\")\n    55\t\n    56\t        encoder_channels = tuple(int(channel) for channel in self.config.encoder_channels)\n    57\t        self.encoder = self._build_encoder(encoder_channels)\n    58\t        selected_stage = self.config.decoder_layer\n    59\t        if selected_stage < 0:\n    60\t            selected_stage = len(encoder_channels) + selected_stage\n    61\t        if selected_stage < 0 or selected_stage >= len(encoder_channels):\n    62\t            raise ValueError(\"decoder_layer selects no encoder stage\")\n    63\t        self.selected_stage = selected_stage\n    64\t\n    65\t        selected_channels = encoder_channels[self.selected_stage]\n    66\t        self.project_bottleneck_embed = nn.Sequential(\n    67\t            nn.Linear(selected_channels, self.config.query_dim),\n    68\t            nn.GELU(),\n    69\t            nn.Linear(self.config.query_dim, self.config.query_dim),\n    70\t        )\n    71\t        self.project_text_embed = nn.Sequential(\n    72\t            nn.Linear(self.config.text_embedding_dim, self.config.text_projection_hidden_dim),\n    73\t            nn.GELU(),\n    74\t            nn.Linear(self.config.text_projection_hidden_dim, self.config.query_dim),\n    75\t        )\n    76\t\n    77\t        layer = TransformerDecoderLayer(\n    78\t            d_model=self.config.query_dim,\n    79\t            nhead=self.config.transformer_num_heads,\n    80\t            dim_feedforward=self.config.transformer_feedforward_dim,\n    81\t            dropout=self.config.transformer_dropout,\n    82\t            activation=\"relu\",\n    83\t            normalize_before=True,\n    84\t        )\n    85\t        self.transformer_decoder = TransformerDecoder(\n    86\t            decoder_layer=layer,\n    87\t            num_layers=self.config.transformer_layers,\n    88\t            norm=nn.LayerNorm(self.config.query_dim),\n    89\t        )\n    90\t\n    91\t        self.fused_stage_count = min(\n    92\t            self.config.num_maskformer_stages,\n    93\t            len(encoder_channels) - 1,\n    94\t        )\n    95\t        self.project_to_decoder_channels = nn.ModuleList()\n    96\t        for stage_index, channels in enumerate(encoder_channels[: self.fused_stage_count]):\n    97\t            output_dim = channels if stage_index == 0 else channels * self.config.num_heads\n    98\t            self.project_to_decoder_channels.append(\n    99\t                nn.Sequential(\n   100\t                    nn.Linear(self.config.query_dim, self.config.text_projection_hidden_dim),\n   101\t                    nn.GELU(),\n   102\t                    nn.Linear(self.config.text_projection_hidden_dim, output_dim),\n   103\t                )\n   104\t            )\n   105\t\n   106\t        self.decoder = VoxTellDecoder(\n   107\t            encoder=self.encoder,\n   108\t            num_classes=1,\n   109\t            n_conv_per_stage=[1] * (len(encoder_channels) - 1),\n   110\t            deep_supervision=self.config.deep_supervision,\n   111\t            num_maskformer_stages=self.fused_stage_count,\n   112\t            num_heads=self.config.num_heads,\n   113\t        )\n   114\t\n   115\t    def _build_encoder(self, encoder_channels: Tuple[int, ...]) -> nn.Module:\n   116\t        backbone = self.config.backbone.lower().replace(\"-\", \"_\")\n   117\t        if backbone in {\"conv\", \"body_conv\", \"legacy_conv\"}:\n   118\t            return _BodyEncoder(\n   119\t                input_channels=self.config.input_channels,\n   120\t                channels=encoder_channels,\n   121\t            )\n   122\t        if backbone in {\"residual_encoder\", \"voxtell_residual_encoder\"}:\n   123\t            return _build_voxtell_residual_encoder(\n   124\t                input_channels=self.config.input_channels,\n   125\t                channels=encoder_channels,\n   126\t                n_blocks_per_stage=_resolve_n_blocks_per_stage(\n   127\t                    encoder_channels,\n   128\t                    self.config.n_blocks_per_stage,\n   129\t                ),\n   130\t                conv_bias=self.config.encoder_conv_bias,\n   131\t                norm=self.config.encoder_norm,\n   132\t                activation=self.config.encoder_activation,\n   133\t            )\n   134\t        raise ValueError(\n   135\t            \"backbone must be one of 'conv' or 'residual_encoder', \"\n   136\t            f\"got {self.config.backbone!r}\"\n   137\t        )\n   138\t\n   139\t    def forward(self, occupancy: Tensor, text_embeddings: Tensor) -> Tensor | List[Tensor]:\n   140\t        if text_embeddings.ndim == 4 and text_embeddings.shape[2] == 1:\n   141\t            text_embeddings = text_embeddings.squeeze(2)\n   142\t        if text_embeddings.ndim != 3:\n   143\t            raise ValueError(\n   144\t                \"text_embeddings must have shape (B, N, E) or (B, N, 1, E), \"\n   145\t                f\"got {tuple(text_embeddings.shape)}\"\n   146\t            )\n   147\t\n   148\t        skips = self.encoder(occupancy)\n   149\t        selected_feature = skips[self.selected_stage]\n   150\t        batch_size, channels, depth, height, width = selected_feature.shape\n   151\t\n   152\t        bottleneck_embed = selected_feature.permute(0, 3, 4, 2, 1)\n   153\t        bottleneck_embed = self.project_bottleneck_embed(bottleneck_embed)\n   154\t        memory = bottleneck_embed.permute(1, 2, 3, 0, 4).reshape(\n   155\t            -1,\n   156\t            batch_size,\n   157\t            self.config.query_dim,\n   158\t        )\n   159\t        pos = sinusoidal_position_encoding_3d(\n   160\t            (height, width, depth),\n   161\t            self.config.query_dim,\n   162\t            device=memory.device,\n   163\t            dtype=memory.dtype,\n   164\t        )\n   165\t\n   166\t        text_queries = text_embeddings.permute(1, 0, 2)\n   167\t        text_queries = self.project_text_embed(text_queries)\n   168\t        mask_embedding, _ = self.transformer_decoder(\n   169\t            tgt=text_queries,\n   170\t            memory=memory,\n   171\t            pos=pos,\n   172\t        )\n   173\t        mask_embedding = mask_embedding.permute(1, 0, 2)\n   174\t\n   175\t        stage_embeddings = [\n   176\t            projection(mask_embedding)\n   177\t            for projection in self.project_to_decoder_channels\n   178\t        ]\n   179\t        num_prompts = text_embeddings.shape[1]\n   180\t        per_prompt_outputs: List[List[Tensor]] = []\n   181\t        for prompt_index in range(num_prompts):\n   182\t            prompt_stage_embeddings = [\n   183\t                embedding[:, prompt_index : prompt_index + 1, :]\n   184\t                for embedding in stage_embeddings\n   185\t            ]\n","exit_code":0,"status":"completed"}}
