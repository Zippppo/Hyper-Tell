eck_embed = selected_feature.permute(0, 3, 4, 2, 1)\n   154\t        bottleneck_embed = self.project_bottleneck_embed(bottleneck_embed)\n   155\t        memory = bottleneck_embed.permute(1, 2, 3, 0, 4).reshape(\n   156\t            -1,\n   157\t            batch_size,\n   158\t            self.config.query_dim,\n   159\t        )\n   160\t        pos = sinusoidal_position_encoding_3d(\n   161\t            (height, width, depth),\n   162\t            self.config.query_dim,\n   163\t            device=memory.device,\n   164\t            dtype=memory.dtype,\n   165\t            batch_size=batch_size,\n   166\t        )\n   167\t        if (\n   168\t            pos.shape != memory.shape\n   169\t            or pos.dtype != memory.dtype\n   170\t            or pos.device != memory.device\n   171\t        ):\n   172\t            raise RuntimeError(\n   173\t                \"runtime position encoding contract violated: \"\n   174\t                f\"memory shape={tuple(memory.shape)} dtype={memory.dtype} device={memory.device}; \"\n   175\t                f\"pos shape={tuple(pos.shape)} dtype={pos.dtype} device={pos.device}\"\n   176\t            )\n   177\t\n   178\t        text_queries = text_embeddings.permute(1, 0, 2)\n   179\t        text_queries = self.project_text_embed(text_queries)\n   180\t        mask_embedding, _ = self.transformer_decoder(\n   181\t            tgt=text_queries,\n   182\t            memory=memory,\n   183\t            pos=pos,\n   184\t        )\n   185\t        mask_embedding = mask_embedding.permute(1, 0, 2)\n   186\t\n   187\t        stage_embeddings = [\n   188\t            projection(mask_embedding)\n   189\t            for projection in self.project_to_decoder_channels\n   190\t        ]\n   191\t        num_prompts = text_embeddings.shape[1]\n   192\t        per_prompt_outputs: List[List[Tensor]] = []\n   193\t        for prompt_index in range(num_prompts):\n   194\t            prompt_stage_embeddings = [\n   195\t                embedding[:, prompt_index : prompt_index + 1, :]\n   196\t                for embedding in stage_embeddings\n   197\t            ]\n   198\t            per_prompt_outputs.append(self.decoder(skips, prompt_stage_embeddings))\n   199\t\n   200\t        outputs = [\n   201\t            torch.cat(scale_outputs, dim=1)\n   202\t            for scale_outputs in zip(*per_prompt_outputs)\n   203\t        ]\n   204\t        if self.config.deep_supervision:\n   205\t            return outputs\n   206\t        return outputs[0]\n   207\t\n   208\t\n   209\tclass _BodyEncoder(nn.Module):\n   210\t    def __init__(self, input_channels: int, channels: Sequence[int]) -> None:\n   211\t        super().__init__()\n   212\t        self.output_channels = tuple(int(channel) for channel in channels)\n   213\t        self.conv_op = nn.Conv3d\n   214\t        self.conv_bias = False\n   215\t        self.norm_op = _BodyDecoderNorm\n   216\t        self.norm_op_kwargs = {}\n   217\t        self.dropout_op = None\n   218\t        self.dropout_op_kwargs = None\n   219\t        self.nonlin = nn.GELU\n   220\t        self.nonlin_kwargs = {}\n   221\t        self.kernel_sizes = tuple((3, 3, 3) for _ in channels)\n   222\t        self.strides = tuple(\n   223\t            (1, 1, 1) if index == 0 else (2, 2, 2)\n   224\t            for index in range(len(channels))\n   225\t        )\n   226\t        stages = []\n   227\t        current_channels = input_channels\n   228\t        for stage_index, output_channels in enumerate(channels):\n   229\t            stride = 1 if stage_index == 0 else 2\n   230\t            stages.append(_ConvBlock(current_channels, output_channels, stride=stride))\n   231\t            current_channels = output_channels\n   232\t        self.stages = nn.ModuleList(stages)\n   233\t\n   234\t    def forward(self, x: Tensor) -> List[Tensor]:\n   235\t        skips = []\n   236\t        for stage in self.stages:\n   237\t            x = stage(x)\n   238\t            skips.append(x)\n   239\t        return skips\n   240\t\n","exit_code":0,"status":"completed"}}
