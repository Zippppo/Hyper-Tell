{"type":"item.completed","item":{"id":"item_26","type":"command_execution","command":"/bin/bash -lc \"nl -ba Body-Tell/tests/test_prompt_loss_backward.py | sed -n '1,220p'\"","aggregated_output":"     1\tfrom __future__ import annotations\n     2\t\n     3\timport torch\n     4\t\n     5\tfrom body_tell.losses.prompt_losses import PromptSegmentationLoss\n     6\tfrom body_tell.metrics.prompt_metrics import compute_prompt_metrics\n     7\t\n     8\t\n     9\tdef test_prompt_segmentation_loss_backpropagates() -> None:\n    10\t    torch.manual_seed(0)\n    11\t    logits = torch.randn(2, 3, 6, 5, 4, requires_grad=True)\n    12\t    targets = (torch.rand(2, 3, 6, 5, 4) > 0.7).float()\n    13\t    targets[:, 2] = 0.0\n    14\t\n    15\t    criterion = PromptSegmentationLoss(bce_weight=0.5, dice_weight=0.5)\n    16\t    result = criterion(logits, targets)\n    17\t\n    18\t    assert set(result) == {\"loss\", \"bce_loss\", \"dice_loss\"}\n    19\t    assert result[\"loss\"].ndim == 0\n    20\t    result[\"loss\"].backward()\n    21\t    assert logits.grad is not None\n    22\t    assert torch.isfinite(logits.grad).all()\n    23\t\n    24\t\n    25\tdef test_prompt_metrics_report_positive_dice_and_negative_fp_rate() -> None:\n    26\t    logits = torch.full((1, 3, 4, 4, 4), -8.0)\n    27\t    targets = torch.zeros_like(logits)\n    28\t    targets[:, 0, 1:3, 1:3, 1:3] = 1.0\n    29\t    logits[:, 0, 1:3, 1:3, 1:3] = 8.0\n    30\t    logits[:, 2, 0, 0, 0] = 8.0\n    31\t    target_empty = torch.tensor([[False, True, True]])\n    32\t\n    33\t    metrics = compute_prompt_metrics(logits, targets, target_empty=target_empty)\n    34\t\n    35\t    assert metrics[\"foreground_mean_dice\"] > 0.99\n    36\t    assert metrics[\"negative_fp_rate\"] == 1.0 / (2 * 4 * 4 * 4)\n    37\t\n    38\t\n    39\tdef test_prompt_loss_ignores_invalid_padding_prompts() -> None:\n    40\t    torch.manual_seed(1)\n    41\t    logits = torch.randn(1, 3, 4, 4, 4, requires_grad=True)\n    42\t    targets = (torch.rand(1, 3, 4, 4, 4) > 0.65).float()\n    43\t    prompt_valid = torch.tensor([[True, True, False]])\n    44\t    with torch.no_grad():\n    45\t        logits[:, 2] = 20.0\n    46\t    targets[:, 2] = 0.0\n    47\t\n    48\t    criterion = PromptSegmentationLoss(bce_weight=0.5, dice_weight=0.5)\n    49\t    masked = criterion(logits, targets, prompt_valid=prompt_valid)\n    50\t    sliced = criterion(logits[:, :2], targets[:, :2])\n    51\t\n    52\t    assert torch.allclose(masked[\"loss\"], sliced[\"loss\"])\n    53\t    masked[\"loss\"].backward()\n    54\t    assert logits.grad is not None\n    55\t    assert logits.grad[:, 2].abs().sum().item() == 0.0\n    56\t\n    57\t\n    58\tdef test_prompt_metrics_ignore_invalid_padding_prompts() -> None:\n    59\t    logits = torch.full((1, 3, 4, 4, 4), -8.0)\n    60\t    targets = torch.zeros_like(logits)\n    61\t    target_empty = torch.tensor([[False, True, True]])\n    62\t    prompt_valid = torch.tensor([[True, True, False]])\n    63\t\n    64\t    targets[:, 0, 1:3, 1:3, 1:3] = 1.0\n    65\t    logits[:, 0, 1:3, 1:3, 1:3] = 8.0\n    66\t    logits[:, 2] = 8.0\n    67\t\n    68\t    metrics = compute_prompt_metrics(\n    69\t        logits,\n    70\t        targets,\n    71\t        target_empty=target_empty,\n    72\t        prompt_valid=prompt_valid,\n    73\t    )\n    74\t\n    75\t    assert metrics[\"foreground_mean_dice\"] > 0.99\n    76\t    assert metrics[\"negative_fp_rate\"] == 0.0\n","exit_code":0,"status":"completed"}}
