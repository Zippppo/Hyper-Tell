ading the transformer_decoder. prefix\")\n   576\t\n   577\t    checkpoint_path = _resolve_voxtell_checkpoint_path(voxtell_path)\n   578\t    if not checkpoint_path.exists():\n   579\t        raise FileNotFoundError(f\"VoxTell checkpoint does not exist: {checkpoint_path}\")\n   580\t\n   581\t    checkpoint = _load_checkpoint_cpu(checkpoint_path)\n   582\t    if not isinstance(checkpoint, Mapping) or \"network_weights\" not in checkpoint:\n   583\t        raise KeyError(\n   584\t            \"VoxTell checkpoint must contain a 'network_weights' state dict; \"\n   585\t            \"full-checkpoint fallback loading is intentionally not supported\"\n   586\t        )\n   587\t    network_weights = checkpoint[\"network_weights\"]\n   588\t    if not isinstance(network_weights, Mapping):\n   589\t        raise TypeError(\"VoxTell checkpoint field 'network_weights' must be a mapping\")\n   590\t\n   591\t    source_state = {\n   592\t        key[len(prefix) :]: tensor\n   593\t        for key, tensor in network_weights.items()\n   594\t        if isinstance(key, str) and key.startswith(prefix)\n   595\t    }\n   596\t    target_state = model.transformer_decoder.state_dict()\n   597\t\n   598\t    missing_keys = sorted(set(target_state) - set(source_state))\n   599\t    unexpected_keys = sorted(set(source_state) - set(target_state))\n   600\t    shape_mismatches = [\n   601\t        {\n   602\t            \"key\": key,\n   603\t            \"checkpoint_shape\": tuple(int(value) for value in source_state[key].shape),\n   604\t            \"model_shape\": tuple(int(value) for value in target_state[key].shape),\n   605\t        }\n   606\t        for key in sorted(set(source_state) & set(target_state))\n   607\t        if tuple(source_state[key].shape) != tuple(target_state[key].shape)\n   608\t    ]\n   609\t\n   610\t    metadata: dict[str, Any] = {\n   611\t        \"checkpoint_path\": str(checkpoint_path),\n   612\t        \"prefix\": prefix,\n   613\t        \"loaded_tensor_count\": len(source_state),\n   614\t        \"loaded_parameter_count\": sum(int(tensor.numel()) for tensor in source_state.values()),\n   615\t        \"missing_keys\": missing_keys,\n   616\t        \"unexpected_keys\": unexpected_keys,\n   617\t        \"shape_mismatches\": shape_mismatches,\n   618\t        \"excluded_prefixes\": [\n   619\t            \"encoder.\",\n   620\t            \"decoder.\",\n   621\t            \"project_bottleneck_embed.\",\n   622\t            \"project_text_embed.\",\n   623\t            \"project_to_decoder_channels.\",\n   624\t            \"pos_embed\",\n   625\t        ],\n   626\t    }\n   627\t\n   628\t    if missing_keys or unexpected_keys or shape_mismatches:\n   629\t        raise RuntimeError(\n   630\t            \"VoxTell transformer decoder prefix is not load-compatible: \"\n   631\t            f\"missing={len(missing_keys)}, unexpected={len(unexpected_keys)}, \"\n   632\t            f\"shape_mismatches={len(shape_mismatches)}\"\n   633\t        )\n   634\t\n   635\t    model.transformer_decoder.load_state_dict(source_state, strict=True)\n   636\t    return metadata\n   637\t\n   638\t\n   639\tdef _resolve_voxtell_checkpoint_path(voxtell_path: str | Path) -> Path:\n   640\t    path = Path(voxtell_path)\n   641\t    if path.is_dir():\n   642\t        return path / \"fold_0\" / \"checkpoint_final.pth\"\n   643\t    return path\n   644\t\n   645\t\n   646\tdef _load_checkpoint_cpu(checkpoint_path: Path) -> Mapping[str, Any]:\n   647\t    try:\n   648\t        return torch.load(\n   649\t            str(checkpoint_path),\n   650\t            map_location=\"cpu\",\n   651\t            weights_only=False,\n   652\t            mmap=True,\n   653\t        )\n   654\t    except TypeError:\n   655\t        return torch.load(\n   656\t            str(checkpoint_path),\n   657\t            map_location=\"cpu\",\n   658\t            weights_only=False,\n   659\t        )\n   660\t\n","exit_code":0,"status":"completed"}}
