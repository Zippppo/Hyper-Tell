{"type":"item.completed","item":{"id":"item_42","type":"command_execution","command":"/bin/bash -lc \"nl -ba Body-Tell/body_tell/models/voxtell_body_model.py | sed -n '1,130p'\"","aggregated_output":"     1\t\"\"\"VoxTell-style prompt-conditioned model adapted for Body-Tell occupancy grids.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\timport math\n     6\tfrom dataclasses import dataclass\n     7\tfrom pathlib import Path\n     8\tfrom typing import Any, List, Mapping, Sequence, Tuple\n     9\t\n    10\timport torch\n    11\tfrom torch import Tensor, nn\n    12\t\n    13\tfrom .transformer import TransformerDecoder, TransformerDecoderLayer\n    14\t\n    15\t\n    16\tVOXTELL_V1_1_ENCODER_CHANNELS: Tuple[int, ...] = (32, 64, 128, 256, 320, 320)\n    17\tVOXTELL_V1_1_N_BLOCKS_PER_STAGE: Tuple[int, ...] = (1, 3, 4, 6, 6, 6)\n    18\t\n    19\t\n    20\t@dataclass(frozen=True)\n    21\tclass VoxTellBodyConfig:\n    22\t    input_channels: int = 1\n    23\t    encoder_channels: Tuple[int, ...] = (32, 64, 128, 256, 320)\n    24\t    backbone: str = \"conv\"\n    25\t    n_blocks_per_stage: Tuple[int, ...] | None = None\n    26\t    encoder_conv_bias: bool = True\n    27\t    encoder_norm: str = \"instance_norm_3d\"\n    28\t    encoder_activation: str = \"leaky_relu\"\n    29\t    text_embedding_dim: int = 2560\n    30\t    query_dim: int = 2048\n    31\t    text_projection_hidden_dim: int = 2048\n    32\t    transformer_num_heads: int = 8\n    33\t    transformer_layers: int = 6\n    34\t    transformer_feedforward_dim: int = 2048\n    35\t    transformer_dropout: float = 0.1\n    36\t    decoder_layer: int = -1\n    37\t    num_maskformer_stages: int = 5\n    38\t    num_heads: int = 32\n    39\t    deep_supervision: bool = False\n    40\t\n    41\t\n    42\tclass VoxTellBodyModel(nn.Module):\n    43\t    \"\"\"Prompt-conditioned binary mask model using VoxTell-style dynamic heads.\"\"\"\n    44\t\n    45\t    def __init__(self, config: VoxTellBodyConfig | None = None) -> None:\n    46\t        super().__init__()\n    47\t        self.config = config or VoxTellBodyConfig()\n    48\t        if self.config.query_dim % self.config.transformer_num_heads != 0:\n    49\t            raise ValueError(\"query_dim must be divisible by transformer_num_heads\")\n    50\t        if len(self.config.encoder_channels) < 2:\n    51\t            raise ValueError(\"encoder_channels must contain at least two stages\")\n    52\t        if self.config.num_maskformer_stages < 1:\n    53\t            raise ValueError(\"num_maskformer_stages must be at least 1 for the dynamic mask head\")\n    54\t        if self.config.num_heads < 1:\n    55\t            raise ValueError(\"num_heads must be at least 1\")\n    56\t\n    57\t        encoder_channels = tuple(int(channel) for channel in self.config.encoder_channels)\n    58\t        self.encoder = self._build_encoder(encoder_channels)\n    59\t        selected_stage = self.config.decoder_layer\n    60\t        if selected_stage < 0:\n    61\t            selected_stage = len(encoder_channels) + selected_stage\n    62\t        if selected_stage < 0 or selected_stage >= len(encoder_channels):\n    63\t            raise ValueError(\"decoder_layer selects no encoder stage\")\n    64\t        self.selected_stage = selected_stage\n    65\t\n    66\t        selected_channels = encoder_channels[self.selected_stage]\n    67\t        self.project_bottleneck_embed = nn.Sequential(\n    68\t            nn.Linear(selected_channels, self.config.query_dim),\n    69\t            nn.GELU(),\n    70\t            nn.Linear(self.config.query_dim, self.config.query_dim),\n    71\t        )\n    72\t        self.project_text_embed = nn.Sequential(\n    73\t            nn.Linear(self.config.text_embedding_dim, self.config.text_projection_hidden_dim),\n    74\t            nn.GELU(),\n    75\t            nn.Linear(self.config.text_projection_hidden_dim, self.config.query_dim),\n    76\t        )\n    77\t\n    78\t        layer = TransformerDecoderLayer(\n    79\t            d_model=self.config.query_dim,\n    80\t            nhead=self.config.transformer_num_heads,\n    81\t            dim_feedforward=self.config.transformer_feedforward_dim,\n    82\t            dropout=self.config.transformer_dropout,\n    83\t            activation=\"relu\",\n    84\t            normalize_before=True,\n    85\t        )\n    86\t        self.transformer_decoder = TransformerDecoder(\n    87\t            decoder_layer=layer,\n    88\t            num_layers=self.config.transformer_layers,\n    89\t            norm=nn.LayerNorm(self.config.query_dim),\n    90\t        )\n    91\t\n    92\t        self.fused_stage_count = min(\n    93\t            self.config.num_maskformer_stages,\n    94\t            len(encoder_channels) - 1,\n    95\t        )\n    96\t        self.project_to_decoder_channels = nn.ModuleList()\n    97\t        for stage_index, channels in enumerate(encoder_channels[: self.fused_stage_count]):\n    98\t            output_dim = channels if stage_index == 0 else channels * self.config.num_heads\n    99\t            self.project_to_decoder_channels.append(\n   100\t                nn.Sequential(\n   101\t                    nn.Linear(self.config.query_dim, self.config.text_projection_hidden_dim),\n   102\t                    nn.GELU(),\n   103\t                    nn.Linear(self.config.text_projection_hidden_dim, output_dim),\n   104\t                )\n   105\t            )\n   106\t\n   107\t        self.decoder = VoxTellDecoder(\n   108\t            encoder=self.encoder,\n   109\t            num_classes=1,\n   110\t            n_conv_per_stage=[1] * (len(encoder_channels) - 1),\n   111\t            deep_supervision=self.config.deep_supervision,\n   112\t            num_maskformer_stages=self.fused_stage_count,\n   113\t            num_heads=self.config.num_heads,\n   114\t        )\n   115\t\n   116\t    def _build_encoder(self, encoder_channels: Tuple[int, ...]) -> nn.Module:\n   117\t        backbone = self.config.backbone.lower().replace(\"-\", \"_\")\n   118\t        if backbone in {\"conv\", \"body_conv\", \"legacy_conv\"}:\n   119\t            return _BodyEncoder(\n   120\t                input_channels=self.config.input_channels,\n   121\t                channels=encoder_channels,\n   122\t            )\n   123\t        if backbone in {\"residual_encoder\", \"voxtell_residual_encoder\"}:\n   124\t            return _build_voxtell_residual_encoder(\n   125\t                input_channels=self.config.input_channels,\n   126\t                channels=encoder_channels,\n   127\t                n_blocks_per_stage=_resolve_n_blocks_per_stage(\n   128\t                    encoder_channels,\n   129\t                    self.config.n_blocks_per_stage,\n   130\t                ),\n","exit_code":0,"status":"completed"}}
