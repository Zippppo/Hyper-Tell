\\t            \\\"available\\\": False,\\n   180\\t            \\\"checkpoint_path\\\": str(checkpoint_path),\\n   181\\t            \\\"error\\\": \\\"checkpoint file does not exist\\\",\\n   182\\t        }\\n   183\\t\\n   184\\t    try:\\n   185\\t        checkpoint = torch.load(\\n   186\\t            str(checkpoint_path),\\n   187\\t            map_location=\\\"cpu\\\",\\n   188\\t            weights_only=False,\\n   189\\t            mmap=True,\\n   190\\t        )\\n   191\\t    except TypeError:\\n   192\\t        checkpoint = torch.load(\\n   193\\t            str(checkpoint_path),\\n   194\\t            map_location=\\\"cpu\\\",\\n   195\\t            weights_only=False,\\n   196\\t        )\\n   197\\t\\n   198\\t    state_dict = checkpoint.get(\\\"network_weights\\\", checkpoint)\\n   199\\t    shapes = {name: _shape(tensor) for name, tensor in state_dict.items()}\\n   200\\t    rows = []\\n   201\\t    for name, shape in sorted(shapes.items()):\\n   202\\t        match = PROJECT_TO_DECODER_RE.match(name)\\n   203\\t        if not match:\\n   204\\t            continue\\n   205\\t        stage = int(match.group(1))\\n   206\\t        rows.append(\\n   207\\t            {\\n   208\\t                \\\"stage\\\": stage,\\n   209\\t                \\\"output_dim\\\": int(shape[0]),\\n   210\\t                \\\"weight_shape\\\": shape,\\n   211\\t                \\\"bias_shape\\\": shapes.get(f\\\"project_to_decoder_channels.{stage}.2.bias\\\"),\\n   212\\t                \\\"key\\\": f\\\"project_to_decoder_channels.{stage}.2\\\",\\n   213\\t            }\\n   214\\t        )\\n   215\\t\\n   216\\t    return {\\n   217\\t        \\\"available\\\": True,\\n   218\\t        \\\"checkpoint_path\\\": str(checkpoint_path),\\n   219\\t        \\\"key_count\\\": len(shapes),\\n   220\\t        \\\"state_shapes\\\": shapes,\\n   221\\t        \\\"projection_rows\\\": sorted(rows, key=lambda row: row[\\\"stage\\\"]),\\n   222\\t        \\\"pos_embed_shape\\\": shapes.get(\\\"pos_embed\\\"),\\n   223\\t    }\\n   224\\t\\n   225\\t\\n   226\\tdef infer_num_heads_from_projection_rows(\\n   227\\t    rows: list[dict[str, Any]],\\n   228\\t    decoder_configs: dict[int, dict[str, Any]],\\n   229\\t) -> int | None:\\n   230\\t    ratios = []\\n   231\\t    for row in rows:\\n   232\\t        stage = int(row[\\\"stage\\\"])\\n   233\\t        if stage == 0:\\n   234\\t            continue\\n   235\\t        channels = int(decoder_configs[stage][\\\"channels\\\"])\\n   236\\t        output_dim = int(row[\\\"output_dim\\\"])\\n   237\\t        if output_dim % channels != 0:\\n   238\\t            return None\\n   239\\t        ratios.append(output_dim // channels)\\n   240\\t    if not ratios:\\n   241\\t        return None\\n   242\\t    first = ratios[0]\\n   243\\t    return first if all(item == first for item in ratios) else None\\n   244\\t\\n   245\\t\\n   246\\tdef compare_state_shapes(\\n   247\\t    checkpoint_shapes: dict[str, tuple[int, ...]] | None,\\n   248\\t    body_shapes: dict[str, tuple[int, ...]] | None,\\n   249\\t) -> dict[str, Any]:\\n   250\\t    if checkpoint_shapes is None or body_shapes is None:\\n   251\\t        return {\\\"available\\\": False}\\n   252\\t\\n   253\\t    matching = []\\n   254\\t    mismatched = []\\n   255\\t    for name, body_shape in sorted(body_shapes.items()):\\n   256\\t        checkpoint_shape = checkpoint_shapes.get(name)\\n   257\\t        if checkpoint_shape is None:\\n   258\\t            continue\\n   259\\t        if checkpoint_shape == body_shape:\\n   260\\t            matching.append(name)\\n\",\"exit_code\":0,\"status\":\"completed\"}}\nBody-Tell/reports/26-05-24/runs/SP-A.P0/review-events.jsonl:52:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_26\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"nl -ba Body-Tell/scripts/audit_voxtell_alignment.py | sed -n '560,760p'\\\"\",\"aggregated_output\":\"   560\\t\\n   561\\tdef render_html_report(audit: