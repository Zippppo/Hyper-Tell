{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/bin/bash -lc \"nl -ba Body-Tell/tests/test_model_shapes.py | sed -n '260,540p'\"","aggregated_output":"   260\t            num_heads=2,\n   261\t            deep_supervision=False,\n   262\t        )\n   263\t    ).to(device)\n   264\t    captured: dict[str, torch.Tensor] = {}\n   265\t\n   266\t    class CaptureTransformer(nn.Module):\n   267\t        def __init__(self, wrapped: nn.Module) -> None:\n   268\t            super().__init__()\n   269\t            self.wrapped = wrapped\n   270\t\n   271\t        def forward(\n   272\t            self,\n   273\t            tgt: torch.Tensor,\n   274\t            memory: torch.Tensor,\n   275\t            *args,\n   276\t            **kwargs,\n   277\t        ):\n   278\t            captured[\"memory\"] = memory.detach()\n   279\t            captured[\"pos\"] = kwargs[\"pos\"].detach()\n   280\t            return self.wrapped(tgt, memory, *args, **kwargs)\n   281\t\n   282\t    model.transformer_decoder = CaptureTransformer(model.transformer_decoder)\n   283\t\n   284\t    occupancy = torch.randn(1, 1, 16, 32, 48, device=device)\n   285\t    text_embeddings = torch.randn(1, 2, 8, device=device)\n   286\t    with torch.amp.autocast(\"cuda\", dtype=torch.bfloat16):\n   287\t        logits = model(occupancy, text_embeddings)\n   288\t        loss = logits.float().square().mean()\n   289\t    loss.backward()\n   290\t\n   291\t    assert captured[\"memory\"].dtype == torch.bfloat16\n   292\t    assert captured[\"pos\"].shape == captured[\"memory\"].shape\n   293\t    assert captured[\"pos\"].dtype == captured[\"memory\"].dtype\n   294\t    assert captured[\"pos\"].device == captured[\"memory\"].device\n   295\t    assert any(parameter.grad is not None for parameter in model.parameters())\n   296\t\n   297\t\n   298\tdef test_voxtell_decoder_rejects_stride_mismatched_inputs() -> None:\n   299\t    torch.manual_seed(0)\n   300\t    model = VoxTellBodyModel(\n   301\t        VoxTellBodyConfig(\n   302\t            input_channels=1,\n   303\t            encoder_channels=(4, 8, 16),\n   304\t            text_embedding_dim=8,\n   305\t            query_dim=16,\n   306\t            text_projection_hidden_dim=16,\n   307\t            transformer_num_heads=4,\n   308\t            transformer_layers=1,\n   309\t            transformer_feedforward_dim=32,\n   310\t            num_maskformer_stages=3,\n   311\t            num_heads=2,\n   312\t            deep_supervision=False,\n   313\t        )\n   314\t    )\n   315\t\n   316\t    occupancy = torch.randn(1, 1, 15, 16, 16)\n   317\t    text_embeddings = torch.randn(1, 2, 8)\n   318\t\n   319\t    with pytest.raises(ValueError, match=\"stride-compatible input sizes\"):\n   320\t        model(occupancy, text_embeddings)\n   321\t\n   322\t\n   323\tdef test_voxtell_body_model_supports_residual_encoder_policy() -> None:\n   324\t    torch.manual_seed(0)\n   325\t    model = VoxTellBodyModel(\n   326\t        VoxTellBodyConfig(\n   327\t            input_channels=1,\n   328\t            encoder_channels=(4, 8, 16),\n   329\t            backbone=\"residual_encoder\",\n   330\t            n_blocks_per_stage=(1, 2, 3),\n   331\t            text_embedding_dim=8,\n   332\t            query_dim=16,\n   333\t            transformer_num_heads=4,\n   334\t            transformer_layers=1,\n   335\t            num_maskformer_stages=3,\n   336\t            num_heads=2,\n   337\t            deep_supervision=False,\n   338\t        )\n   339\t    )\n   340\t\n   341\t    assert model.encoder.output_channels == (4, 8, 16)\n   342\t    assert model.encoder.strides == ((1, 1, 1), (2, 2, 2), (2, 2, 2))\n   343\t    assert model.encoder.n_blocks_per_stage == (1, 2, 3)\n   344\t    assert [len(stage.blocks) for stage in model.encoder.stages] == [1, 2, 3]\n   345\t\n   346\t    norms = [\n   347\t        module\n   348\t        for module in model.encoder.modules()\n   349\t        if isinstance(module, nn.InstanceNorm3d)\n   350\t    ]\n   351\t    assert norms\n   352\t    assert all(norm.eps == 1e-5 and norm.affine for norm in norms)\n   353\t\n   354\t    activations = [\n   355\t        module\n   356\t        for module in model.encoder.modules()\n   357\t        if isinstance(module, nn.LeakyReLU)\n   358\t    ]\n   359\t    assert activations\n   360\t    assert all(activation.inplace for activation in activations)\n   361\t\n   362\t    main_convs = [\n   363\t        module\n   364\t        for name, module in model.encoder.named_modules()\n   365\t        if isinstance(module, nn.Conv3d)\n   366\t        and (name == \"stem.convs.0.conv\" or name.endswith((\"conv1.conv\", \"conv2.conv\")))\n   367\t    ]\n   368\t    assert main_convs\n   369\t    assert all(conv.bias is not None for conv in main_convs)\n   370\t\n   371\t    occupancy = torch.randn(1, 1, 16, 16, 16)\n   372\t    text_embeddings = torch.randn(1, 2, 8)\n   373\t\n   374\t    logits = model(occupancy, text_embeddings)\n   375\t\n   376\t    assert logits.shape == (1, 2, 16, 16, 16)\n   377\t    assert any(name.startswith(\"encoder.stem.\") for name in model.state_dict())\n   378\t    assert not any(name.startswith(\"encoder.encoder.\") for name in model.state_dict())\n   379\t\n   380\t\n   381\tdef test_voxtell_aligned_config_declares_sp_a_encoder_plan() -> None:\n   382\t    cfg = yaml.safe_load(\n   383\t        Path(\"Body-Tell/configs/phase1_voxtell_aligned.yaml\").read_text()\n   384\t    )\n   385\t    model_cfg = cfg[\"model\"]\n   386\t\n   387\t    assert model_cfg[\"backbone\"] == \"residual_encoder\"\n   388\t    assert tuple(model_cfg[\"encoder_channels\"]) == VOXTELL_V1_1_ENCODER_CHANNELS\n   389\t    assert tuple(model_cfg[\"n_blocks_per_stage\"]) == VOXTELL_V1_1_N_BLOCKS_PER_STAGE\n   390\t    assert model_cfg[\"encoder_norm\"] == \"instance_norm_3d\"\n   391\t    assert model_cfg[\"encoder_activation\"] == \"leaky_relu\"\n   392\t    assert model_cfg[\"encoder_conv_bias\"] is True\n   393\t    assert model_cfg[\"decoder_layer\"] == 4\n   394\t    assert model_cfg[\"num_maskformer_stages\"] == 5\n   395\t    assert model_cfg[\"num_heads\"] == 32\n   396\t\n   397\t    expected_path_b_projection_dims = [\n   398\t        channel if stage == 0 else channel * model_cfg[\"num_heads\"]\n   399\t        for stage, channel in enumerate(model_cfg[\"encoder_channels\"][:-1])\n   400\t    ]\n   401\t    assert expected_path_b_projection_dims == [32, 2048, 4096, 8192, 10240]\n   402\t\n   403\t\n   404\tdef test_voxtell_body_model_retains_decoder_seg_layers_without_deep_supervision() -> None:\n   405\t    torch.manual_seed(0)\n   406\t    model = VoxTellBodyModel(\n   407\t        VoxTellBodyConfig(\n   408\t            input_channels=1,\n   409\t            encoder_channels=(4, 8, 16),\n   410\t            text_embedding_dim=8,\n   411\t            query_dim=16,\n   412\t            transformer_num_heads=4,\n   413\t            transformer_layers=1,\n   414\t            num_maskformer_stages=3,\n   415\t            num_heads=2,\n   416\t            deep_supervision=False,\n   417\t        )\n   418\t    )\n   419\t\n   420\t    assert len(model.project_to_decoder_channels) == 2\n   421\t    assert len(model.decoder.seg_layers) == 2\n   422\t    assert all(isinstance(layer, nn.Conv3d) for layer in model.decoder.seg_layers)\n   423\t    assert [\n   424\t        name\n   425\t        for name, parameter in model.named_parameters()\n   426\t        if name.startswith(\"decoder.seg_layers.\") and parameter.requires_grad\n   427\t    ]\n   428\t\n   429\t    occupancy = torch.randn(1, 1, 16, 16, 16)\n   430\t    text_embeddings = torch.randn(1, 2, 8)\n   431\t    logits = model(occupancy, text_embeddings)\n   432\t    logits.square().mean().backward()\n   433\t\n   434\t    unused = [\n   435\t        name\n   436\t        for name, parameter in model.named_parameters()\n   437\t        if parameter.requires_grad and parameter.grad is None\n   438\t    ]\n   439\t    assert unused == [\n   440\t        \"transformer_decoder.layers.0.self_attn.in_proj_weight\",\n   441\t        \"transformer_decoder.layers.0.self_attn.in_proj_bias\",\n   442\t        \"transformer_decoder.layers.0.self_attn.out_proj.weight\",\n   443\t        \"transformer_decoder.layers.0.self_attn.out_proj.bias\",\n   444\t        \"transformer_decoder.layers.0.norm1.weight\",\n   445\t        \"transformer_decoder.layers.0.norm1.bias\",\n   446\t        \"decoder.seg_layers.0.weight\",\n   447\t        \"decoder.seg_layers.0.bias\",\n   448\t        \"decoder.seg_layers.1.weight\",\n   449\t        \"decoder.seg_layers.1.bias\",\n   450\t    ]\n   451\t\n   452\t\n   453\tdef test_voxtell_transformer_decoder_prefix_loader_filters_exact_keys(\n   454\t    tmp_path: Path,\n   455\t) -> None:\n   456\t    torch.manual_seed(0)\n   457\t    model = VoxTellBodyModel(\n   458\t        VoxTellBodyConfig(\n   459\t            input_channels=1,\n   460\t            encoder_channels=(4, 8, 16),\n   461\t            text_embedding_dim=8,\n   462\t            query_dim=16,\n   463\t            text_projection_hidden_dim=16,\n   464\t            transformer_num_heads=4,\n   465\t            transformer_layers=1,\n   466\t            transformer_feedforward_dim=32,\n   467\t            num_maskformer_stages=3,\n   468\t            num_heads=2,\n   469\t            deep_supervision=False,\n   470\t        )\n   471\t    )\n   472\t    original_text_projection = model.project_text_embed[0].weight.detach().clone()\n   473\t\n   474\t    prefix_tensors = {}\n   475\t    for index, (key, tensor) in enumerate(model.transformer_decoder.state_dict().items()):\n   476\t        prefix_tensors[f\"transformer_decoder.{key}\"] = torch.full_like(\n   477\t            tensor,\n   478\t            fill_value=(index + 1) / 1000.0,\n   479\t        )\n   480\t\n   481\t    voxtell_dir = tmp_path / \"voxtell_v1.1\"\n   482\t    checkpoint_path = voxtell_dir / \"fold_0\" / \"checkpoint_final.pth\"\n   483\t    checkpoint_path.parent.mkdir(parents=True)\n   484\t    torch.save(\n   485\t        {\n   486\t            \"network_weights\": prefix_tensors\n   487\t            | {\n   488\t                \"encoder.stem.convs.0.conv.weight\": torch.ones(1),\n   489\t                \"decoder.seg_layers.0.weight\": torch.ones(1),\n   490\t                \"project_bottleneck_embed.0.weight\": torch.ones(1),\n   491\t                \"project_text_embed.0.weight\": torch.full_like(\n   492\t                    model.project_text_embed[0].weight,\n   493\t                    77.0,\n   494\t                ),\n   495\t                \"project_to_decoder_channels.0.2.weight\": torch.ones(1),\n   496\t                \"pos_embed\": torch.ones(1, 1, model.config.query_dim),\n   497\t            }\n   498\t        },\n   499\t        checkpoint_path,\n   500\t    )\n   501\t\n   502\t    metadata = load_voxtell_transformer_decoder_prefix(model, voxtell_dir)\n   503\t\n   504\t    assert metadata[\"checkpoint_path\"] == str(checkpoint_path)\n   505\t    assert metadata[\"prefix\"] == \"transformer_decoder.\"\n   506\t    assert metadata[\"loaded_tensor_count\"] == len(prefix_tensors)\n   507\t    assert metadata[\"loaded_parameter_count\"] == sum(\n   508\t        tensor.numel() for tensor in prefix_tensors.values()\n   509\t    )\n   510\t    assert metadata[\"missing_keys\"] == []\n   511\t    assert metadata[\"unexpected_keys\"] == []\n   512\t    assert metadata[\"shape_mismatches\"] == []\n   513\t    for key, tensor in model.transformer_decoder.state_dict().items():\n   514\t        torch.testing.assert_close(tensor, prefix_tensors[f\"transformer_decoder.{key}\"])\n   515\t    torch.testing.assert_close(\n   516\t        model.project_text_embed[0].weight,\n   517\t        original_text_projection,\n   518\t    )\n","exit_code":0,"status":"completed"}}
