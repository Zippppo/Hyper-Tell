ne:\\\\n   125\\\\t    torch.manual_seed(0)\\\\n   126\\\\t    model = VoxTellBodyModel(\\\\n   127\\\\t        VoxTellBodyConfig(\\\\n   128\\\\t            input_channels=1,\\\\n   129\\\\t            encoder_channels=(2, 4, 4, 4, 4, 4),\\\\n   130\\\\t            text_embedding_dim=8,\\\\n   131\\\\t            query_dim=8,\\\\n   132\\\\t            text_projection_hidden_dim=8,\\\\n   133\\\\t            transformer_num_heads=2,\\\\n   134\\\\t            transformer_layers=1,\\\\n   135\\\\t            transformer_feedforward_dim=16,\\\\n   136\\\\t            num_maskformer_stages=5,\\\\n   137\\\\t            num_heads=2,\\\\n   138\\\\t            deep_supervision=True,\\\\n   139\\\\t        )\\\\n   140\\\\t    )\\\\n   141\\\\t    model.eval()\\\\n   142\\\\t\\\\n   143\\\\t    projected_bottleneck_shapes: list[tuple[int, ...]] = []\\\\n   144\\\\t\\\\n   145\\\\t    def capture_bottleneck_input(\\\\n   146\\\\t        _module: nn.Module,\\\\n   147\\\\t        inputs: tuple[torch.Tensor, ...],\\\\n   148\\\\t        _output: torch.Tensor,\\\\n   149\\\\t    ) -> None:\\\\n   150\\\\t        projected_bottleneck_shapes.append(tuple(inputs[0].shape))\\\\n   151\\\\t\\\\n   152\\\\t    hook = model.project_bottleneck_embed.register_forward_hook(capture_bottleneck_input)\\\\n   153\\\\t    try:\\\\n   154\\\\t        occupancy = torch.randn(1, 1, 32, 64, 96)\\\\n   155\\\\t        text_embeddings = torch.randn(1, 2, 8)\\\\n   156\\\\t\\\\n   157\\\\t        with torch.no_grad():\\\\n   158\\\\t            logits = model(occupancy, text_embeddings)\\\\n   159\\\\t    finally:\\\\n   160\\\\t        hook.remove()\\\\n   161\\\\t\\\\n   162\\\\t    assert projected_bottleneck_shapes == [(1, 2, 3, 1, 4)]\\\\n   163\\\\t    assert isinstance(logits, list)\\\\n   164\\\\t    assert [tuple(item.shape) for item in logits] == [\\\\n   165\\\\t        (1, 2, 32, 64, 96),\\\\n   166\\\\t        (1, 2, 16, 32, 48),\\\\n   167\\\\t        (1, 2, 8, 16, 24),\\\\n   168\\\\t        (1, 2, 4, 8, 12),\\\\n   169\\\\t        (1, 2, 2, 4, 6),\\\\n   170\\\\t    ]\\\\n   171\\\\t\\\\n   172\\\\t\\\\n   173\\\\tdef test_voxtell_decoder_rejects_stride_mismatched_inputs() -> None:\\\\n   174\\\\t    torch.manual_seed(0)\\\\n   175\\\\t    model = VoxTellBodyModel(\\\\n   176\\\\t        VoxTellBodyConfig(\\\\n   177\\\\t            input_channels=1,\\\\n   178\\\\t            encoder_channels=(4, 8, 16),\\\\n   179\\\\t            text_embedding_dim=8,\\\\n   180\\\\t            query_dim=16,\\\\n\\\",\\\"exit_code\\\":0,\\\"status\\\":\\\"completed\\\"}}\\nBody-Tell/reports/26-05-24/runs/SP-A.P4/events.jsonl:127:{\\\"type\\\":\\\"item.completed\\\",\\\"item\\\":{\\\"id\\\":\\\"item_66\\\",\\\"type\\\":\\\"command_execution\\\",\\\"command\\\":\\\"/bin/bash -lc \\\\\\\"nl -ba Body-Tell/body_tell/models/voxtell_body_model.py | sed -n '40,185p'\\\\\\\"\\\",\\\"aggregated_output\\\":\\\"    40\\\\t\\\\n    41\\\\tclass VoxTellBodyModel(nn.Module):\\\\n    42\\\\t    \\\\\\\"\\\\\\\"\\\\\\\"Prompt-conditioned binary mask model using VoxTell-style dynamic heads.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n    43\\\\t\\\\n    44\\\\t    def __init__(self, config: VoxTellBodyConfig | None = None) -> None:\\\\n    45\\\\t        super().__init__()\\\\n    46\\\\t        self.config = config or VoxTellBodyConfig()\\\\n    47\\\\t        if self.config.query_dim % self.config.transformer_num_heads != 0:\\\\n    48\\\\t            raise ValueError(\\\\\\\"query_dim must be divisible by transformer_num_heads\\\\\\\")\\\\n    49\\\\t        if len(self.config.encoder_channels) < 2:\\\\n    50\\\\t            raise ValueError(\\\\\\\"encoder_channels must contain at least two stages\\\\\\\")\\\\n    51\\\\t        if self.config.num_maskformer_stages < 1:\\\\n    52\\\\t            raise ValueError(\\\\\\\"num_maskformer_stages must be at least 1 for the dynamic mask head\\\\\\\")\\\\n    53\\\\t        if self.config.num_heads < 1:\\\\n    54\\\\t            raise ValueError(\\\\\\\"num_heads must be at least 1\\\\\\\")\\\\n    55\\\\t\\\\n    56\\\\t        encoder_channels = tuple(int(channel) for channel in self.config.encoder_channels)\\\\n    57\\\\t        self.encoder = self._build_encoder(encoder_channels)\\\\n    58\\\\t        selected_stage = self.config.decoder_layer\\\\n    59\\\\t        if selected_stage < 0:\\\\n    60\\\\t            selected_stage = len(encoder_channels) + selected_stage\\\\n    61\\\\t        if selected_stage < 0 or selected_stage >= len(encoder_channels):\\\\n    62\\\\t            raise ValueError(\\\\\\\"decoder_layer selects no encoder stage\\\\\\\")\\\\n    63\\\\t        self.selected_stage = selected_stage\\\\n    64\\\\t\\\\n    65\\\\t        selected_channels = encoder_channels[self.selected_stage]\\\\n    66\\\\t        self.project_bottleneck_embed = nn.Sequential(\\\\n    67\\\\t            nn.Linear(selected_channels, self.config.query_dim),\\\\n    68\\\\t            nn.GELU(),\\\\n    69\\\\t            nn.Linear(self.config.query_dim, self.config.query_dim),\\\\n    70\\\\t        )\\\\n    71\\\\t        self.project_text_embed = nn.Sequential(\\\\n    72\\\\t            nn.Linear(self.config.text_embedding_dim, self.config.text_projection_hidden_dim),\\\\n    73\\\\t            nn.GELU(),\\\\n    74\\\\t            nn.Linear(self.config.text_projection_hidden_dim, self.config.query_dim),\\\\n    75\\\\t        )\\\\n    76\\\\t\\\\n    77\\\\t        layer = TransformerDecoderLayer(\\\\n    78\\\\t            d_model=self.config.query_dim,\\\\n    79\\\\t            nhead=self.config.transformer_num_heads,\\\\n    80\\\\t            dim_feedforward=self.config.transformer_feedforward_dim,\\\\n    81\\\\t            dropout=self.config.transformer_dropout,\\\\n    82\\\\t            activation=\\\\\\\"relu\\\\\\\",\\\\n    83\\\\t            normalize_before=True,\\\\n    84\\\\t        )\\\\n    85\\\\t        self.transformer_decoder = TransformerDecoder(\\\\n    86\\\\t            decoder_layer=layer,\\\\n    87\\\\t            num_layers=self.config.transformer_layers,\\\\n    88\\\\t            norm=nn.LayerNorm(self.config.query_dim),\\\\n    89\\\\t        )\\\\n    90\\\\t\\\\n    91\\\\t        self.fused_stage_count = min(\\\\n    92\\\\t            self.config.num_maskformer_stages,\\\\n    93\\\\t            len(encoder_channels) - 1,\\\\n    94\\\\t        )\\\\n    95\\\\t        self.project_to_decoder_channels = nn.ModuleList()\\\\n    96\\\\t        for stage_index, channels in enumerate(encoder_channels[: self.fused_stage_count]):\\\\n    97\\\\t            output_dim = channels if stage_index == 0 else channels * self.config.num_heads\\\\n    98\\\\t            self.project_to_decoder_channels.append(\\\\n    99\\\\t                nn.Sequential(\\\\n   100\\\\t                    nn.Linear(self.config.query_dim, self.config.text_projection_hidden_dim),\\\\n   101\\\\t                    nn.GELU(),\\\\n   102\\\\t                    nn.Linear(self.config.text_projection_hidden_dim, output_dim),\\\\n   103\\\\t                )\\\\n   104\\\\t            )\\\\n   105\\\\t\\\\n   106\\\\t        self.decoder = VoxTellDecoder(\\\\n   107\\\\t            encoder=self.encoder,\\\\n   108\\\\t            num_classes=1,\\\\n   109\\\\t            n_conv_per_stage=[1] * (len(encoder_channels) - 1),\\\\n   110\\\\t            deep_supervision=self.config.deep_supervision,\\\\n   111\\\\t            num_maskformer_stages=self.fused_stage_count,\\\\n   112\\\\t            num_heads=self.config.num_heads,\\\\n   113\\\\t        )\\\\n   114\\\\t\\\\n   115\\\\t    def _build_encoder(self, encoder_channels: Tuple[int, ...]) -> nn.Module:\\\\n   116\\\\t        backbone = self.config.backbone.lower().replace(\\\\\\\"-\\\\\\\", \\\\\\\"_\\\\\\\")\\\\n   117\\\\t        if backbone in {\\\\\\\"conv\\\\\\\", \\\\\\\"body_conv\\\\\\\", \\\\\\\"legacy_conv\\\\\\\"}:\\\\n   118\\\\t            return _BodyEncoder(\\\\n   119\\\\t        