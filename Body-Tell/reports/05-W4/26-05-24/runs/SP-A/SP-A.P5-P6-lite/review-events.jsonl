\\\\t\\\\n   152\\\\t        bottleneck_embed = selected_feature.permute(0, 3, 4, 2, 1)\\\\n   153\\\\t        bottleneck_embed = self.project_bottleneck_embed(bottleneck_embed)\\\\n   154\\\\t        memory = bottleneck_embed.permute(1, 2, 3, 0, 4).reshape(\\\\n   155\\\\t            -1,\\\\n   156\\\\t            batch_size,\\\\n   157\\\\t            self.config.query_dim,\\\\n   158\\\\t        )\\\\n   159\\\\t        pos = sinusoidal_position_encoding_3d(\\\\n   160\\\\t            (height, width, depth),\\\\n   161\\\\t            self.config.query_dim,\\\\n   162\\\\t            device=memory.device,\\\\n   163\\\\t            dtype=memory.dtype,\\\\n   164\\\\t        )\\\\n   165\\\\t\\\\n   166\\\\t        text_queries = text_embeddings.permute(1, 0, 2)\\\\n   167\\\\t        text_queries = self.project_text_embed(text_queries)\\\\n   168\\\\t        mask_embedding, _ = self.transformer_decoder(\\\\n   169\\\\t            tgt=text_queries,\\\\n   170\\\\t            memory=memory,\\\\n   171\\\\t            pos=pos,\\\\n   172\\\\t        )\\\\n   173\\\\t        mask_embedding = mask_embedding.permute(1, 0, 2)\\\\n   174\\\\t\\\\n   175\\\\t        stage_embeddings = [\\\\n   176\\\\t            projection(mask_embedding)\\\\n   177\\\\t            for projection in self.project_to_decoder_channels\\\\n   178\\\\t        ]\\\\n   179\\\\t        num_prompts = text_embeddings.shape[1]\\\\n   180\\\\t        per_prompt_outputs: List[List[Tensor]] = []\\\\n   181\\\\t        for prompt_index in range(num_prompts):\\\\n   182\\\\t            prompt_stage_embeddings = [\\\\n   183\\\\t                embedding[:, prompt_index : prompt_index + 1, :]\\\\n   184\\\\t                for embedding in stage_embeddings\\\\n   185\\\\t            ]\\\\n\\\",\\\"exit_code\\\":0,\\\"status\\\":\\\"completed\\\"}}\\nBody-Tell/reports/26-05-24/runs/SP-A.P4/events.jsonl:128:{\\\"type\\\":\\\"item.completed\\\",\\\"item\\\":{\\\"id\\\":\\\"item_65\\\",\\\"type\\\":\\\"comm