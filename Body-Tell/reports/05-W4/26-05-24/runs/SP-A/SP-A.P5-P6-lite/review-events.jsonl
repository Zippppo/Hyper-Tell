   48\t                tgt_mask=tgt_mask,\n    49\t                memory_mask=memory_mask,\n    50\t                tgt_key_padding_mask=tgt_key_padding_mask,\n    51\t                memory_key_padding_mask=memory_key_padding_mask,\n    52\t                pos=pos,\n    53\t                query_pos=query_pos,\n    54\t            )\n    55\t            attention_layers.append(weights)\n    56\t            if self.return_intermediate:\n    57\t                intermediate.append(self.norm(output) if self.norm is not None else output)\n    58\t\n    59\t        if self.norm is not None:\n    60\t            output = self.norm(output)\n    61\t            if self.return_intermediate:\n    62\t                intermediate[-1] = output\n    63\t\n    64\t        if self.return_intermediate:\n    65\t            return torch.stack(intermediate)\n    66\t        return output, attention_layers\n    67\t\n    68\t\n    69\tclass TransformerDecoderLayer(nn.Module):\n    70\t    \"\"\"Single decoder layer with self-attention, cross-attention, and FFN.\"\"\"\n    71\t\n    72\t    def __init__(\n    73\t        self,\n    74\t        d_model: int,\n    75\t        nhead: int,\n    76\t        dim_feedforward: int = 2048,\n    77\t        dropout: float = 0.1,\n    78\t        activation: str = \"relu\",\n    79\t        normalize_before: bool = False,\n    80\t    ) -> None:\n    81\t        super().__init__()\n    82\t        self.self_attn = nn.MultiheadAttention(d_model, nhead, dropout=dropout)\n    83\t        self.multihead_attn = nn.MultiheadAttention(d_model, nhead, dropout=dropout)\n    84\t        self.linear1 = nn.Linear(d_model, dim_feedforward)\n    85\t        self.dropout = nn.Dropout(dropout)\n    86\t        self.linear2 = nn.Linear(dim_feedforward, d_model)\n    87\t        self.norm1 = nn.LayerNorm(d_model)\n    88\t        self.norm2 = nn.LayerNorm(d_model)\n    89\t        self.norm3 = nn.LayerNorm(d_model)\n    90\t        self.dropout1 = nn.Dropout(dropout)\n    91\t        self.dropout2 = nn.Dropout(dropout)\n    92\t        self.dropout3 = nn.Dropout(dropout)\n    93\t        self.activation = _get_activation_fn(activation)\n    94\t        self.normalize_before = normalize_before\n    95\t\n    96\t    @staticmethod\n    97\t    def with_pos_embed(tensor: Tensor, pos: Optional[Tensor]) -> Tensor:\n    98\t        return tensor if pos is None else tensor + pos\n    99\t\n   100\t    def forward_post(\n   101\t        self,\n   102\t        tgt: Tensor,\n   103\t        memory: Tensor,\n   104\t        tgt_mask: Optional[Tensor] = None,\n   105\t        memory_mask: Optional[Tensor] = None,\n   106\t        tgt_key_padding_mask: Optional[Tensor] = None,\n   107\t        memory_key_padding_mask: Optional[Tensor] = None,\n   108\t        pos: Optional[Tensor] = None,\n   109\t        query_pos: Optional[Tensor] = None,\n   110\t    ) -> Tuple[Tensor, Tensor]:\n   111\t        q = k = self.with_pos_embed(tgt, query_pos)\n   112\t        tgt2, _ = self.self_attn(\n   113\t            q,\n   114\t            k,\n   115\t            value=tgt,\n   116\t            attn_mask=tgt_mask,\n   117\t            key_padding_mask=tgt_key_padding_mask,\n   118\t        )\n   119\t        tgt = tgt + self.dropout1(tgt2)\n   120\t        tgt = self.norm1(tgt)\n   121\t\n   122\t        tgt2, attn_weights = self.multihead_attn(\n   123\t            query=self.with_pos_embed(tgt, query_pos),\n   124\t            key=self.with_pos_embed(memory, pos),\n   125\t            value=memory,\n   126\t            attn_mask=memory_mask,\n   127\t            key_padding_mask=memory_key_padding_mask,\n   128\t        )\n   129\t        tgt = tgt + self.dropout2(tgt2)\n   130\t        tgt = self.norm2(tgt)\n   131\t\n   132\t        tgt2 = self.linear2(self.dropout(self.activation(self.linear1(tgt))))\n   133\t        tgt = tgt + self.dropout3(tgt2)\n   134\t        tgt = self.norm3(tgt)\n   135\t        return tgt, attn_weights\n   136\t\n   137\t    def forward_pre(\n   138\t        self,\n   139\t        tgt: Tensor,\n   140\t        memory: Tensor,\n   141\t        tgt_mask: Optional[Tensor] = None,\n   142\t        memory_mask: Optional[Tensor] = None,\n   143\t        tgt_key_padding_mask: Optional[Tensor] = None,\n   144\t        memory_key_padding_mask: Optional[Tensor] = None,\n   145\t        pos: Optional[Tensor] = None,\n   146\t        query_pos: Optional[Tensor] = None,\n   147\t    ) -> Tuple[Tensor, Tensor]:\n   148\t        tgt2 = self.norm2(tgt)\n   149\t        tgt2, attn_weights = self.multihead_attn(\n   150\t            query=self.with_pos_embed(tgt2, query_pos),\n   151\t            key=self.with_pos_embed(memory, pos),\n   152\t            value=memory,\n   153\t            attn_mask=memory_mask,\n   154\t            key_padding_mask=memory_key_padding_mask,\n   155\t        )\n   156\t        tgt = tgt + self.dropout2(tgt2)\n   157\t\n   158\t        tgt2 = self.norm3(tgt)\n   159\t        tgt2 = self.linear2(self.dropout(self.activation(self.linear1(tgt2))))\n   160\t        tgt = tgt + self.dropout3(tgt2)\n   161\t        return tgt, attn_weights\n   162\t\n   163\t    def forward(\n   164\t        self,\n   165\t        tgt: Tensor,\n   166\t        memory: Tensor,\n   167\t        tgt_mask: Optional[Tensor] = None,\n   168\t        memory_mask: Optional[Tensor] = None,\n   169\t        tgt_key_padding_mask: Optional[Tensor] = None,\n   170\t        memory_key_padding_mask: Optional[Tensor] = None,\n   171\t        pos: Optional[Tensor] = None,\n   172\t        query_pos: Optional[Tensor] = None,\n   173\t    ) -> Tuple[Tensor, Tensor]:\n   174\t        if self.normalize_before:\n   175\t            return self.forward_pre(\n   176\t                tgt,\n   177\t                memory,\n   178\t                tgt_mask,\n   179\t                memory_mask,\n   180\t                tgt_key_padding_mask,\n   181\t                memory_key_padding_mask,\n   182\t                