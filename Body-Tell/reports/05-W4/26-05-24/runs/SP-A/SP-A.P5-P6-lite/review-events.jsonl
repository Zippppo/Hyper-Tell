ts, dim=1)\n   561\t    if encoded.shape[1] < dim:\n   562\t        padding = torch.zeros(encoded.shape[0], dim - encoded.shape[1], device=device, dtype=dtype)\n   563\t        encoded = torch.cat((encoded, padding), dim=1)\n   564\t    encoded = encoded[:, :dim].to(device=device, dtype=dtype)\n   565\t    return encoded.unsqueeze(1).expand(-1, int(batch_size), -1)\n   566\t\n   567\t\n   568\tdef load_voxtell_transformer_decoder_prefix(\n   569\t    model: VoxTellBodyModel,\n   570\t    voxtell_path: str | Path,\n   571\t    prefix: str = \"transformer_decoder.\",\n   572\t) -> dict[str, Any]:\n   573\t    \"\"\"Load only VoxTell ``transformer_decoder.*`` tensors into ``model``.\"\"\"\n   574\t\n   575\t    if prefix != \"transformer_decoder.\":\n   576\t        raise ValueError(\"P6-lite only supports loading the transformer_decoder. prefix\")\n   577\t\n   578\t    checkpoint_path = _resolve_voxtell_checkpoint_path(voxtell_path)\n   579\t    if not checkpoint_path.exists():\n   580\t        raise FileNotFoundError(f\"VoxTell checkpoint does not exist: {checkpoint_path}\")\n   581\t\n   582\t    checkpoint = _load_checkpoint_cpu(checkpoint_path)\n   583\t    if not isinstance(checkpoint, Mapping) or \"network_weights\" not in checkpoint:\n   584\t        raise KeyError(\n   585\t            \"VoxTell checkpoint must contain a 'network_weights' state dict; \"\n   586\t            \"full-checkpoint fallback loading is intentionally not supported\"\n   587\t        )\n   588\t    network_weights = checkpoint[\"network_weights\"]\n   589\t    if not isinstance(network_weights, Mapping):\n   590\t        raise TypeError(\"VoxTell checkpoint field 'network_weights' must be a mapping\")\n   591\t\n   592\t    source_state = {\n   593\t        key[len(prefix) :]: tensor\n   594\t        for key, tensor in network_weights.items()\n   595\t        if isinstance(key, str) and key.startswith(prefix)\n   596\t    }\n   597\t    target_state = model.transformer_decoder.state_dict()\n   598\t\n   599\t    missing_keys = sorted(set(target_state) - set(source_state))\n   600\t    unexpected_keys = sorted(set(source_state) - set(target_state))\n   601\t    shape_mismatches = [\n   602\t        {\n   603\t            \"key\": key,\n   604\t            \"checkpoint_shape\": tuple(int(value) for value in source_state[key].shape),\n   605\t            \"model_shape\": tuple(int(value) for value in target_state[key].shape),\n   606\t        }\n   607\t        for key in sorted(set(source_state) & set(target_state))\n   608\t        if tuple(source_state[key].shape) != tuple(target_state[key].shape)\n   609\t    ]\n   610\t\n   611\t    metadata: dict[str, Any] = {\n   612\t        \"checkpoint_path\": str(checkpoint_path),\n   613\t        \"prefix\": prefix,\n   614\t        \"loaded_tensor_count\": len(source_state),\n   615\t        \"loaded_parameter_count\": sum(int(tensor.numel()) for tensor in source_state.values()),\n   616\t        \"missing_keys\": missing_keys,\n   617\t        \"unexpected_keys\": unexpected_keys,\n   618\t        \"shape_mismatches\": shape_mismatches,\n   619\t        \"excluded_prefixes\": [\n   620\t            \"encoder.\",\n   621\t            \"decoder.\",\n   622\t            \"project_bottleneck_embed.\",\n   623\t            \"project_text_embed.\",\n   624\t            \"project_to_decoder_channels.\",\n   625\t            \"pos_embed\",\n   626\t        ],\n   627\t    }\n   628\t\n   629\t    if missing_keys or unexpected_keys or shape_mismatches:\n   630\t        raise RuntimeError(\n   631\t            \"VoxTell transformer decoder prefix is not load-compatible: \"\n   632\t            f\"missing={len(missing_keys)}, unexpected={len(unexpected_keys)}, \"\n   633\t            f\"shape_mismatches={len(shape_mismatches)}\"\n   634\t        )\n   635\t\n   636\t    model.transformer_decoder.load_state_dict(source_state, strict=True)\n   637\t    return metadata\n   638\t\n   639\t\n   640\tdef _resolve_voxte