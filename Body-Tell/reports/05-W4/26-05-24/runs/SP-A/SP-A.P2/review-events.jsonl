{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/bin/bash -lc \"nl -ba Body-Tell/body_tell/models/voxtell_body_model.py | sed -n '1,135p;186,250p;368,425p'\"","aggregated_output":"     1\t\"\"\"VoxTell-style prompt-conditioned model adapted for Body-Tell occupancy grids.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\timport math\n     6\tfrom dataclasses import dataclass\n     7\tfrom typing import List, Sequence, Tuple\n     8\t\n     9\timport torch\n    10\timport torch.nn.functional as F\n    11\tfrom torch import Tensor, nn\n    12\t\n    13\tfrom .transformer import TransformerDecoder, TransformerDecoderLayer\n    14\t\n    15\t\n    16\tVOXTELL_V1_1_ENCODER_CHANNELS: Tuple[int, ...] = (32, 64, 128, 256, 320, 320)\n    17\tVOXTELL_V1_1_N_BLOCKS_PER_STAGE: Tuple[int, ...] = (1, 3, 4, 6, 6, 6)\n    18\t\n    19\t\n    20\t@dataclass(frozen=True)\n    21\tclass VoxTellBodyConfig:\n    22\t    input_channels: int = 1\n    23\t    encoder_channels: Tuple[int, ...] = (32, 64, 128, 256, 320)\n    24\t    backbone: str = \"conv\"\n    25\t    n_blocks_per_stage: Tuple[int, ...] | None = None\n    26\t    encoder_conv_bias: bool = True\n    27\t    encoder_norm: str = \"instance_norm_3d\"\n    28\t    encoder_activation: str = \"leaky_relu\"\n    29\t    text_embedding_dim: int = 2560\n    30\t    query_dim: int = 2048\n    31\t    text_projection_hidden_dim: int = 2048\n    32\t    transformer_num_heads: int = 8\n    33\t    transformer_layers: int = 6\n    34\t    transformer_feedforward_dim: int = 2048\n    35\t    transformer_dropout: float = 0.1\n    36\t    decoder_layer: int = -1\n    37\t    num_maskformer_stages: int = 5\n    38\t    num_heads: int = 32\n    39\t    deep_supervision: bool = False\n    40\t\n    41\t\n    42\tclass VoxTellBodyModel(nn.Module):\n    43\t    \"\"\"Prompt-conditioned binary mask model using VoxTell-style dynamic heads.\"\"\"\n    44\t\n    45\t    def __init__(self, config: VoxTellBodyConfig | None = None) -> None:\n    46\t        super().__init__()\n    47\t        self.config = config or VoxTellBodyConfig()\n    48\t        if self.config.query_dim % self.config.transformer_num_heads != 0:\n    49\t            raise ValueError(\"query_dim must be divisible by transformer_num_heads\")\n    50\t        if len(self.config.encoder_channels) < 2:\n    51\t            raise ValueError(\"encoder_channels must contain at least two stages\")\n    52\t        if self.config.num_maskformer_stages < 1:\n    53\t            raise ValueError(\"num_maskformer_stages must be at least 1 for the dynamic mask head\")\n    54\t\n    55\t        encoder_channels = tuple(int(channel) for channel in self.config.encoder_channels)\n    56\t        self.encoder = self._build_encoder(encoder_channels)\n    57\t        selected_stage = self.config.decoder_layer\n    58\t        if selected_stage < 0:\n    59\t            selected_stage = len(encoder_channels) + selected_stage\n    60\t        if selected_stage < 0 or selected_stage >= len(encoder_channels):\n    61\t            raise ValueError(\"decoder_layer selects no encoder stage\")\n    62\t        self.selected_stage = selected_stage\n    63\t\n    64\t        selected_channels = encoder_channels[self.selected_stage]\n    65\t        self.project_visual_embed = nn.Sequential(\n    66\t            nn.Linear(selected_channels, self.config.query_dim),\n    67\t            nn.GELU(),\n    68\t            nn.Linear(self.config.query_dim, self.config.query_dim),\n    69\t        )\n    70\t        self.project_text_embed = nn.Sequential(\n    71\t            nn.Linear(self.config.text_embedding_dim, self.config.text_projection_hidden_dim),\n    72\t            nn.GELU(),\n    73\t            nn.Linear(self.config.text_projection_hidden_dim, self.config.query_dim),\n    74\t        )\n    75\t\n    76\t        layer = TransformerDecoderLayer(\n    77\t            d_model=self.config.query_dim,\n    78\t            nhead=self.config.transformer_num_heads,\n    79\t            dim_feedforward=self.config.transformer_feedforward_dim,\n    80\t            dropout=self.config.transformer_dropout,\n    81\t            activation=\"relu\",\n    82\t            normalize_before=True,\n    83\t        )\n    84\t        self.transformer_decoder = TransformerDecoder(\n    85\t            decoder_layer=layer,\n    86\t            num_layers=self.config.transformer_layers,\n    87\t            norm=nn.LayerNorm(self.config.query_dim),\n    88\t        )\n    89\t\n    90\t        self.fused_stage_count = min(\n    91\t            self.config.num_maskformer_stages,\n    92\t            len(encoder_channels) - 1,\n    93\t        )\n    94\t        self.mask_projections = nn.ModuleList()\n    95\t        for stage_index, channels in enumerate(encoder_channels[: self.fused_stage_count]):\n    96\t            output_dim = channels if stage_index == 0 else channels * self.config.num_heads\n    97\t            self.mask_projections.append(\n    98\t                nn.Sequential(\n    99\t                    nn.Linear(self.config.query_dim, self.config.text_projection_hidden_dim),\n   100\t                    nn.GELU(),\n   101\t                    nn.Linear(self.config.text_projection_hidden_dim, output_dim),\n   102\t                )\n   103\t            )\n   104\t\n   105\t        self.decoder = _VoxTellBodyDecoder(\n   106\t            encoder_channels=encoder_channels,\n   107\t            num_heads=self.config.num_heads,\n   108\t            fused_stage_count=self.fused_stage_count,\n   109\t            deep_supervision=self.config.deep_supervision,\n   110\t        )\n   111\t\n   112\t    def _build_encoder(self, encoder_channels: Tuple[int, ...]) -> nn.Module:\n   113\t        backbone = self.config.backbone.lower().replace(\"-\", \"_\")\n   114\t        if backbone in {\"conv\", \"body_conv\", \"legacy_conv\"}:\n   115\t            return _BodyEncoder(\n   116\t                input_channels=self.config.input_channels,\n   117\t                channels=encoder_channels,\n   118\t            )\n   119\t        if backbone in {\"residual_encoder\", \"voxtell_residual_encoder\"}:\n   120\t            return _build_voxtell_residual_encoder(\n   121\t                input_channels=self.config.input_channels,\n   122\t                channels=encoder_channels,\n   123\t                n_blocks_per_stage=_resolve_n_blocks_per_stage(\n   124\t                    encoder_channels,\n   125\t                    self.config.n_blocks_per_stage,\n   126\t                ),\n   127\t                conv_bias=self.config.encoder_conv_bias,\n   128\t                norm=self.config.encoder_norm,\n   129\t                activation=self.config.encoder_activation,\n   130\t            )\n   131\t        raise ValueError(\n   132\t            \"backbone must be one of 'conv' or 'residual_encoder', \"\n   133\t            f\"got {self.config.backbone!r}\"\n   134\t        )\n   135\t\n   186\tclass _BodyEncoder(nn.Module):\n   187\t    def __init__(self, input_channels: int, channels: Sequence[int]) -> None:\n   188\t        super().__init__()\n   189\t        self.output_channels = tuple(int(channel) for channel in channels)\n   190\t        self.strides = tuple(\n   191\t            (1, 1, 1) if index == 0 else (2, 2, 2)\n   192\t            for index in range(len(channels))\n   193\t        )\n   194\t        stages = []\n   195\t        current_channels = input_channels\n   196\t        for stage_index, output_channels in enumerate(channels):\n   197\t            stride = 1 if stage_index == 0 else 2\n   198\t            stages.append(_ConvBlock(current_channels, output_channels, stride=stride))\n   199\t            current_channels = output_channels\n   200\t        self.stages = nn.ModuleList(stages)\n   201\t\n   202\t    def forward(self, x: Tensor) -> List[Tensor]:\n   203\t        skips = []\n   204\t        for stage in self.stages:\n   205\t            x = stage(x)\n   206\t            skips.append(x)\n   207\t        return skips\n   208\t\n   209\t\n   210\tdef _build_voxtell_residual_encoder(\n   211\t    input_channels: int,\n   212\t    channels: Sequence[int],\n   213\t    n_blocks_per_stage: Sequence[int],\n   214\t    conv_bias: bool,\n   215\t    norm: str,\n   216\t    activation: str,\n   217\t) -> nn.Module:\n   218\t    try:\n   219\t        from dynamic_network_architectures.building_blocks.residual import BasicBlockD\n   220\t        from dynamic_network_architectures.building_blocks.residual_encoders import ResidualEncoder\n   221\t    except ImportError as exc:\n   222\t        raise RuntimeError(\n   223\t            \"backbone='residual_encoder' requires dynamic_network_architectures\"\n   224\t        ) from exc\n   225\t\n   226\t    output_channels = tuple(int(channel) for channel in channels)\n   227\t    blocks_per_stage = tuple(int(blocks) for blocks in n_blocks_per_stage)\n   228\t    kernel_sizes = tuple((3, 3, 3) for _ in output_channels)\n   229\t    strides = tuple(\n   230\t        (1, 1, 1) if index == 0 else (2, 2, 2)\n   231\t        for index in range(len(output_channels))\n   232\t    )\n   233\t\n   234\t    encoder = ResidualEncoder(\n   235\t        input_channels=input_channels,\n   236\t        n_stages=len(output_channels),\n   237\t        features_per_stage=output_channels,\n   238\t        conv_op=nn.Conv3d,\n   239\t        kernel_sizes=kernel_sizes,\n   240\t        strides=strides,\n   241\t        n_blocks_per_stage=blocks_per_stage,\n   242\t        conv_bias=bool(conv_bias),\n   243\t        norm_op=_resolve_residual_norm(norm),\n   244\t        norm_op_kwargs={\"eps\": 1e-5, \"affine\": True},\n   245\t        dropout_op=None,\n   246\t        dropout_op_kwargs=None,\n   247\t        nonlin=_resolve_residual_activation(activation),\n   248\t        nonlin_kwargs={\"inplace\": True},\n   249\t        block=BasicBlockD,\n   250\t        bottleneck_channels=None,\n   368\t    return 1\n   369\t\n   370\t\n   371\tdef _resolve_n_blocks_per_stage(\n   372\t    encoder_channels: Tuple[int, ...],\n   373\t    n_blocks_per_stage: Sequence[int] | None,\n   374\t) -> Tuple[int, ...]:\n   375\t    if n_blocks_per_stage is None:\n   376\t        if encoder_channels == VOXTELL_V1_1_ENCODER_CHANNELS:\n   377\t            return VOXTELL_V1_1_N_BLOCKS_PER_STAGE\n   378\t        return tuple(1 for _ in encoder_channels)\n   379\t\n   380\t    blocks = tuple(int(blocks) for blocks in n_blocks_per_stage)\n   381\t    if len(blocks) != len(encoder_channels):\n   382\t        raise ValueError(\n   383\t            \"n_blocks_per_stage must have one entry per encoder stage: \"\n   384\t            f\"got {len(blocks)} blocks for {len(encoder_channels)} stages\"\n   385\t        )\n   386\t    return blocks\n   387\t\n   388\t\n   389\tdef _resolve_residual_norm(norm: str) -> type[nn.Module]:\n   390\t    normalized = norm.lower().replace(\"-\", \"_\")\n   391\t    if normalized in {\"instance\", \"instance_norm\", \"instance_norm_3d\", \"instancenorm3d\"}:\n   392\t        return nn.InstanceNorm3d\n   393\t    raise ValueError(\n   394\t        \"residual_encoder uses the VoxTell norm policy and only supports \"\n   395\t        f\"InstanceNorm3d, got {norm!r}\"\n   396\t    )\n   397\t\n   398\t\n   399\tdef _resolve_residual_activation(activation: str) -> type[nn.Module]:\n   400\t    normalized = activation.lower().replace(\"-\", \"_\")\n   401\t    if normalized in {\"leaky_relu\", \"leakyrelu\"}:\n   402\t        return nn.LeakyReLU\n   403\t    raise ValueError(\n   404\t        \"residual_encoder uses the VoxTell activation policy and only supports \"\n   405\t        f\"LeakyReLU, got {activation!r}\"\n   406\t    )\n   407\t\n   408\t\n   409\tdef sinusoidal_position_encoding_3d(\n   410\t    spatial_shape: Sequence[int],\n   411\t    dim: int,\n   412\t    device: torch.device,\n   413\t    dtype: torch.dtype,\n   414\t    temperature: float = 10000.0,\n   415\t) -> Tensor:\n   416\t    \"\"\"Return ``(D*H*W, 1, dim)`` deterministic 3D sine/cosine positions.\"\"\"\n   417\t\n   418\t    depth, height, width = (int(x) for x in spatial_shape)\n   419\t    z, y, x = torch.meshgrid(\n   420\t        torch.linspace(0, 1, depth, device=device, dtype=dtype),\n   421\t        torch.linspace(0, 1, height, device=device, dtype=dtype),\n   422\t        torch.linspace(0, 1, width, device=device, dtype=dtype),\n   423\t        indexing=\"ij\",\n   424\t    )\n   425\t    coords = torch.stack((z, y, x), dim=-1).reshape(-1, 3)\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/bin/bash -lc \"nl -ba Body-Tell/tests/test_model_shapes.py | sed -n '1,210p'\"","aggregated_output":"     1\tfrom __future__ import annotations\n     2\t\n     3\tfrom pathlib import Path\n     4\t\n     5\timport torch\n     6\timport yaml\n     7\tfrom torch import nn\n     8\t\n     9\tfrom body_tell.models.voxtell_body_model import (\n    10\t    VOXTELL_V1_1_ENCODER_CHANNELS,\n    11\t    VOXTELL_V1_1_N_BLOCKS_PER_STAGE,\n    12\t    VoxTellBodyConfig,\n    13\t    VoxTellBodyModel,\n    14\t)\n    15\t\n    16\t\n    17\tdef test_voxtell_body_model_outputs_prompt_logits_shape() -> None:\n    18\t    torch.manual_seed(0)\n    19\t    model = VoxTellBodyModel(\n    20\t        VoxTellBodyConfig(\n    21\t            input_channels=1,\n    22\t            encoder_channels=(4, 8, 16),\n    23\t            text_embedding_dim=8,\n    24\t            query_dim=16,\n    25\t            transformer_num_heads=4,\n    26\t            transformer_layers=1,\n    27\t            num_maskformer_stages=3,\n    28\t            num_heads=2,\n    29\t            deep_supervision=False,\n    30\t        )\n    31\t    )\n    32\t\n    33\t    occupancy = torch.randn(2, 1, 16, 16, 16)\n    34\t    text_embeddings = torch.randn(2, 3, 8)\n    35\t\n    36\t    logits = model(occupancy, text_embeddings)\n    37\t\n    38\t    assert logits.shape == (2, 3, 16, 16, 16)\n    39\t    assert logits.dtype == occupancy.dtype\n    40\t\n    41\t\n    42\tdef test_voxtell_body_model_supports_deep_supervision() -> None:\n    43\t    torch.manual_seed(0)\n    44\t    model = VoxTellBodyModel(\n    45\t        VoxTellBodyConfig(\n    46\t            input_channels=1,\n    47\t            encoder_channels=(4, 8, 16),\n    48\t            text_embedding_dim=8,\n    49\t            query_dim=16,\n    50\t            transformer_num_heads=4,\n    51\t            transformer_layers=1,\n    52\t            num_maskformer_stages=3,\n    53\t            num_heads=2,\n    54\t            deep_supervision=True,\n    55\t        )\n    56\t    )\n    57\t\n    58\t    occupancy = torch.randn(1, 1, 16, 16, 16)\n    59\t    text_embeddings = torch.randn(1, 2, 8)\n    60\t\n    61\t    logits = model(occupancy, text_embeddings)\n    62\t\n    63\t    assert isinstance(logits, list)\n    64\t    assert [tuple(item.shape) for item in logits] == [\n    65\t        (1, 2, 16, 16, 16),\n    66\t        (1, 2, 8, 8, 8),\n    67\t    ]\n    68\t\n    69\t\n    70\tdef test_voxtell_body_model_supports_residual_encoder_policy() -> None:\n    71\t    torch.manual_seed(0)\n    72\t    model = VoxTellBodyModel(\n    73\t        VoxTellBodyConfig(\n    74\t            input_channels=1,\n    75\t            encoder_channels=(4, 8, 16),\n    76\t            backbone=\"residual_encoder\",\n    77\t            n_blocks_per_stage=(1, 2, 3),\n    78\t            text_embedding_dim=8,\n    79\t            query_dim=16,\n    80\t            transformer_num_heads=4,\n    81\t            transformer_layers=1,\n    82\t            num_maskformer_stages=3,\n    83\t            num_heads=2,\n    84\t            deep_supervision=False,\n    85\t        )\n    86\t    )\n    87\t\n    88\t    assert model.encoder.output_channels == (4, 8, 16)\n    89\t    assert model.encoder.strides == ((1, 1, 1), (2, 2, 2), (2, 2, 2))\n    90\t    assert model.encoder.n_blocks_per_stage == (1, 2, 3)\n    91\t    assert [len(stage.blocks) for stage in model.encoder.stages] == [1, 2, 3]\n    92\t\n    93\t    norms = [\n    94\t        module\n    95\t        for module in model.encoder.modules()\n    96\t        if isinstance(module, nn.InstanceNorm3d)\n    97\t    ]\n    98\t    assert norms\n    99\t    assert all(norm.eps == 1e-5 and norm.affine for norm in norms)\n   100\t\n   101\t    activations = [\n   102\t        module\n   103\t        for module in model.encoder.modules()\n   104\t        if isinstance(module, nn.LeakyReLU)\n   105\t    ]\n   106\t    assert activations\n   107\t    assert all(activation.inplace for activation in activations)\n   108\t\n   109\t    main_convs = [\n   110\t        module\n   111\t        for name, module in model.encoder.named_modules()\n   112\t        if isinstance(module, nn.Conv3d)\n   113\t        and (name == \"stem.convs.0.conv\" or name.endswith((\"conv1.conv\", \"conv2.conv\")))\n   114\t    ]\n   115\t    assert main_convs\n   116\t    assert all(conv.bias is not None for conv in main_convs)\n   117\t\n   118\t    occupancy = torch.randn(1, 1, 16, 16, 16)\n   119\t    text_embeddings = torch.randn(1, 2, 8)\n   120\t\n   121\t    logits = model(occupancy, text_embeddings)\n   122\t\n   123\t    assert logits.shape == (1, 2, 16, 16, 16)\n   124\t    assert any(name.startswith(\"encoder.stem.\") for name in model.state_dict())\n   125\t    assert not any(name.startswith(\"encoder.encoder.\") for name in model.state_dict())\n   126\t\n   127\t\n   128\tdef test_voxtell_aligned_config_declares_sp_a_encoder_plan() -> None:\n   129\t    cfg = yaml.safe_load(\n   130\t        Path(\"Body-Tell/configs/phase1_voxtell_aligned.yaml\").read_text()\n   131\t    )\n   132\t    model_cfg = cfg[\"model\"]\n   133\t\n   134\t    assert model_cfg[\"backbone\"] == \"residual_encoder\"\n   135\t    assert tuple(model_cfg[\"encoder_channels\"]) == VOXTELL_V1_1_ENCODER_CHANNELS\n   136\t    assert tuple(model_cfg[\"n_blocks_per_stage\"]) == VOXTELL_V1_1_N_BLOCKS_PER_STAGE\n   137\t    assert model_cfg[\"encoder_norm\"] == \"instance_norm_3d\"\n   138\t    assert model_cfg[\"encoder_activation\"] == \"leaky_relu\"\n   139\t    assert model_cfg[\"encoder_conv_bias\"] is True\n   140\t    assert model_cfg[\"decoder_layer\"] == 4\n   141\t    assert model_cfg[\"num_maskformer_stages\"] == 5\n   142\t\n   143\t\n   144\tdef test_voxtell_body_model_omits_parameters_unused_without_deep_supervision() -> None:\n   145\t    torch.manual_seed(0)\n   146\t    model = VoxTellBodyModel(\n   147\t        VoxTellBodyConfig(\n   148\t            input_channels=1,\n   149\t            encoder_channels=(4, 8, 16),\n   150\t            text_embedding_dim=8,\n   151\t            query_dim=16,\n   152\t            transformer_num_heads=4,\n   153\t            transformer_layers=1,\n   154\t            num_maskformer_stages=3,\n   155\t            num_heads=2,\n   156\t            deep_supervision=False,\n   157\t        )\n   158\t    )\n   159\t\n   160\t    assert len(model.mask_projections) == 2\n   161\t    assert not [\n   162\t        name\n   163\t        for name, parameter in model.named_parameters()\n   164\t        if name.startswith(\"decoder.seg_layers.\") and parameter.requires_grad\n   165\t    ]\n   166\t\n   167\t    occupancy = torch.randn(1, 1, 16, 16, 16)\n   168\t    text_embeddings = torch.randn(1, 2, 8)\n   169\t    logits = model(occupancy, text_embeddings)\n   170\t    logits.square().mean().backward()\n   171\t\n   172\t    unused = [\n   173\t        name\n   174\t        for name, parameter in model.named_parameters()\n   175\t        if parameter.requires_grad and parameter.grad is None\n   176\t    ]\n   177\t    assert unused == [\n   178\t        \"transformer_decoder.layers.0.self_attn.in_proj_weight\",\n   179\t        \"transformer_decoder.layers.0.self_attn.in_proj_bias\",\n   180\t        \"transformer_decoder.layers.0.self_attn.out_proj.weight\",\n   181\t        \"transformer_decoder.layers.0.self_attn.out_proj.bias\",\n   182\t        \"transformer_decoder.layers.0.norm1.weight\",\n   183\t        \"transformer_decoder.layers.0.norm1.bias\",\n   184\t    ]\n","exit_code":0,"status":"completed"}}
