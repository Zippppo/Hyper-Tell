 num_maskformer_stages=3,\\\\\\\\\\\\\\\\n            num_heads=2,\\\\\\\\\\\\\\\\n            deep_supervision=False,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    occupancy = torch.randn(2, 1, 16, 16, 16)\\\\\\\\\\\\\\\\n    text_embeddings = torch.randn(2, 3, 8)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    logits = model(occupancy, text_embeddings)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    assert logits.shape == (2, 3, 16, 16, 16)\\\\\\\\\\\\\\\\n    assert logits.dtype == occupancy.dtype\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef test_voxtell_body_model_supports_deep_supervision() -> None:\\\\\\\\\\\\\\\\n    torch.manual_seed(0)\\\\\\\\\\\\\\\\n    model = VoxTellBodyModel(\\\\\\\\\\\\\\\\n        VoxTellBodyConfig(\\\\\\\\\\\\\\\\n            input_channels=1,\\\\\\\\\\\\\\\\n            encoder_channels=(4, 8, 16),\\\\\\\\\\\\\\\\n            text_embedding_dim=8,\\\\\\\\\\\\\\\\n            query_dim=16,\\\\\\\\\\\\\\\\n            transformer_num_heads=4,\\\\\\\\\\\\\\\\n            transformer_layers=1,\\\\\\\\\\\\\\\\n            num_maskformer_stages=3,\\\\\\\\\\\\\\\\n            num_heads=2,\\\\\\\\\\\\\\\\n            deep_supervision=True,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    occupancy = torch.randn(1, 1, 16, 16, 16)\\\\\\\\\\\\\\\\n    text_embeddings = torch.randn(1, 2, 8)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    logits = model(occupancy, text_embeddings)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    assert isinstance(logits, list)\\\\\\\\\\\\\\\\n    assert [tuple(item.shape) for item in logits] == [\\\\\\\\\\\\\\\\n        (1, 2, 16, 16, 16),\\\\\\\\\\\\\\\\n        (1, 2, 8, 8, 8),\\\\\\\\\\\\\\\\n    ]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef test_voxtell_body_model_omits_parameters_unused_without_deep_supervision() -> None:\\\\\\\\\\\\\\\\n    torch.manual_seed(0)\\\\\\\\\\\\\\\\n    model = VoxTellBodyModel(\\\\\\\\\\\\\\\\n        VoxTellBodyConfig(\\\\\\\\\