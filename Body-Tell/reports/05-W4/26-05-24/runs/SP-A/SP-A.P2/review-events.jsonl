\\\\\\\"\\\\n   471\\\\t        f\\\\\\\"key={row['key']}\\\\\\\"\\\\n   472\\\\t    )\\\\n   473\\\\t\\\\n   474\\\\t\\\\n   475\\\\tdef print_text_report(audit: dict[str, Any]) -> None:\\\\n   476\\\\t    body = audit[\\\\\\\"body\\\\\\\"]\\\\n   477\\\\t    voxtell = audit[\\\\\\\"voxtell\\\\\\\"]\\\\n   478\\\\t    print(\\\\\\\"SP-A.P0 VoxTell compatibility baseline\\\\\\\")\\\\n   479\\\\t    print()\\\\n   480\\\\t    print(\\\\\\\"Body-Tell current\\\\\\\")\\\\n   481\\\\t    print(f\\\\\\\"  config: {body['config_path']}\\\\\\\")\\\\n   482\\\\t    print(f\\\\\\\"  num_heads: {body['num_heads']}\\\\\\\")\\\\n   483\\\\t    print(\\\\n   484\\\\t        \\\\\\\"  fused projection stages: \\\\\\\"\\\\n   485\\\\t        f\\\\\\\"{body['fused_stage_count_actual']} \\\\\\\"\\\\n   486\\\\t        f\\\\\\\"(configured {body['num_maskformer_stages_config']})\\\\\\\"\\\\n   487\\\\t    )\\\\n   488\\\\t    for row in body[\\\\\\\"projection_rows\\\\\\\"]:\\\\n   489\\\\t        print(projection_line(row))\\\\n   490\\\\t    print()\\\\n   491\\\\t    print(\\\\\\\"VoxTell v1.1 source default\\\\\\\")\\\\n   492\\\\t    print(f\\\\\\\"  num_heads: {voxtell['source_default']['num_heads']}\\\\\\\")\\\\n   493\\\\t    for row in voxtell[\\\\\\\"source_default\\\\\\\"][\\\\\\\"projection_rows\\\\\\\"]:\\\\n   494\\\\t        print(projection_line(row))\\\\n   495\\\\t    print()\\\\n   496\\\\t    print(\\\\\\\"VoxTell v1.1 predictor/checkpoint profile\\\\\\\")\\\\n   497\\\\t    print(f\\\\\\\"  predictor num_heads: {voxtell['predictor_v1_1']['num_heads']}\\\\\\\")\\\\n   498\\\\t    if voxtell[\\\\\\\"checkpoint\\\\\\\"] and voxtell[\\\\\\\"checkpoint\\\\\\\"].get(\\\\\\\"available\\\\\\\"):\\\\n   499\\\\t        print(f\\\\\\\"  checkpoint: {voxtell['checkpoint']['checkpoint_path']}\\\\\\\")\\\\n   500\\\\t        print(f\\\\\\\"  checkpoint keys: {voxtell['checkpoint']['key_count']}\\\\\\\")\\\\n   501\\\\t        print(f\\\\\\\"  checkpoint pos_embed: {fmt_shape(