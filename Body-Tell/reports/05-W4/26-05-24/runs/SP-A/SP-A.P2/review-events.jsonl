\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,320p' Body-Tell/body_tell/models/transformer.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":null,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"in_progress\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.started\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_15\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,220p' Body-Tell/scripts/parameter_audit.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":null,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"in_progress\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_14\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,320p' Body-Tell/body_tell/models/transformer.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Text prompt decoder adapted from VoxTell's DETR-style transformer.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nfrom __future__ import annotations\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport copy\\\\\\\\\\\\\\\\nfrom typing import Callable, List, Optional, Tuple\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport torch\\\\\\\\\\\\\\\\nimport torch.nn.functional as F\\\\\\\\\\\\\\\\nfrom torch import Tensor, nn\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass TransformerDecoder(nn.Module):\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Stack of transformer decoder layers for text-query/image-memory fusion.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def __init__(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        decoder_layer: nn.Module,\\\\\\\\\\\\\\\\n        num_layers: int,\\\\\\\\\\\\\\\\n        norm: Optional[nn.Module] = None,\\\\\\\\\\\\\\\\n        return_intermediate: bool = False,\\\\\\\\\\\\\\\\n    ) -> None:\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\n        self.layers = _get_clones(decoder_layer, num_layers)\\\\\\\\\\\\\\\\n        self.num_layers = num_layers\\\\\\\\\\\\\\\\n        self.norm = norm\\\\\\\\\\\\\\\\n        self.return_intermediate = return_intermediate\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        tgt: Tensor,\\\\\\\\\\\\\\\\n        memory: Tensor,\\\\\\\\\\\\\\\\n        tgt_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        tgt_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        query_pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n    ) -> Tuple[Tensor, List[Tensor]] | Tensor:\\\\\\\\\\\\\\\\n        output = tgt\\\\\\\\\\\\\\\\n        intermediate = []\\\\\\\\\\\\\\\\n        attention_layers = []\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        for layer in self.layers:\\\\\\\\\\\\\\\\n            output, weights = layer(\\\\\\\\\\\\\\\\n                output,\\\\\\\\\\\\\\\\n                memory,\\\\\\\\\\\\\\\\n                tgt_mask=tgt_mask,\\\\\\\\\\\\\\\\n                memory_mask=memory_mask,\\\\\\\\\\\\\\\\n                tgt_key_padding_mask=tgt_key_padding_mask,\\\\\\\\\\\\\\\\n                memory_key_padding_mask=memory_key_padding_mask,\\\\\\\\\\\\\\\\n                pos=pos,\\\\\\\\\\\\\\\\n                query_pos=query_pos,\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n            attention_layers.append(weights)\\\\\\\\\\\\\\\\n            if self.return_intermediate:\\\\\\\\\\\\\\\\n                intermediate.append(self.norm(output) if self.norm is not None else output)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        if self.norm is not None:\\\\\\\\\\\\\\\\n            output = self.norm(output)\\\\\\\\\\\\\\\\n            if self.return_intermediate:\\\\\\\\\\\\\\\\n                intermediate[-1] = output\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        if self.return_intermediate:\\\\\\\\\\\\\\\\n            return torch.stack(intermediate)\\\\\\\\\\\\\\\\n        return output, attention_layers\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass TransformerDecoderLayer(nn.Module):\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Single decoder layer with self-attention, cross-attention, and FFN.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def __init__(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        d_model: int,\\\\\\\\\\\\\\\\n        nhead: int,\\\\\\\\\\\\\\\\n        dim_feedforward: int = 2048,\\\\\\\\\\\\\\\\n        dropout: float = 0.1,\\\\\\\\\\\\\\\\n        activation: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"relu\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        normalize_before: bool = False,\\\\\\\\\\\\\\\\n    ) -> None:\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\n        self.self_attn = nn.MultiheadAttention(d_model, nhead, dropout=dropout)\\\\\\\\\\\\\\\\n        self.multihead_attn = nn.MultiheadAttention(d_model, nhead, dropout=dropout)\\\\\\\\\\\\\\\\n        self.linear1 = nn.Linear(d_model, dim_feedforward)\\\\\\\\\\\\\\\\n        self.dropout = nn.Dropout(dropout)\\\\\\\\\\\\\\\\n        self.linear2 = nn.Linear(dim_feedforward, d_model)\\\\\\\\\\\\\\\\n        self.norm1 = nn.LayerNorm(d_model)\\\\\\\\\\\\\\\\n        self.norm2 = nn.LayerNorm(d_model)\\\\\\\\\\\\\\\\n        self.norm3 = nn.LayerNorm(d_model)\\\\\\\\\\\\\\\\n        self.dropout1 = nn.Dropout(dropout)\\\\\\\\\\\\\\\\n        self.dropout2 = nn.Dropout(dropout)\\\\\\\\\\\\\\\\n        self.dropout3 = nn.Dropout(dropout)\\\\\\\\\\\\\\\\n        self.activation = _get_activation_fn(activation)\\\\\\\\\\\\\\\\n        self.normalize_before = normalize_before\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @staticmethod\\\\\\\\\\\\\\\\n    def with_pos_embed(tensor: Tensor, pos: Optional[Tensor]) -> Tensor:\\\\\\\\\\\\\\\\n        return tensor if pos is None else tensor + pos\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward_post(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        tgt: Tensor,\\\\\\\\\\\\\\\\n        memory: Tensor,\\\\\\\\\\\\\\\\n        tgt_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        tgt_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        query_pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n    ) -> Tuple[Tensor, Tensor]:\\\\\\\\\\\\\\\\n        q = k = self.with_pos_embed(tgt, query_pos)\\\\\\\\\\\\\\\\n        tgt2, _ = self.self_attn(\\\\\\\\\\\\\\\\n            q,\\\\\\\\\\\\\\\\n            k,\\\\\\\\\\\\\\\\n            value=tgt,\\\\\\\\\\\\\\\\n            attn_mask=tgt_mask,\\\\\\\\\\\\\\\\n            key_padding_mask=tgt_key_padding_mask,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        tgt = tgt + self.dropout1(tgt2)\\\\\\\\\\\\\\\\n        tgt = self.norm1(tgt)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        tgt2, attn_weights = self.multihead_attn(\\\\\\\\\\\\\\\\n            query=self.with_pos_embed(tgt, query_pos),\\\\\\\\\\\\\\\\n            key=self.with_pos_embed(memory, pos),\\\\\\\\\\\\\\\\n            value=memory,\\\\\\\\\\\\\\\\n            attn_mask=memory_mask,\\\\\\\\\\\\\\\\n            key_padding_mask=memory_key_padding_mask,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        tgt = tgt + self.dropout2(tgt2)\\\\\\\\\\\\\\\\n        tgt = self.norm2(tgt)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        tgt2 = self.linear2(self.dropout(self.activation(self.linear1(tgt))))\\\\\\\\\\\\\\\\n        tgt = tgt + self.dropout3(tgt2)\\\\\\\\\\\\\\\\n        tgt = self.norm3(tgt)\\\\\\\\\\\\\\\\n        return tgt, attn_weights\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward_pre(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        tgt: Tensor,\\\\\\\\\\\\\\\\n        memory: Tensor,\\\\\\\\\\\\\\\\n        tgt_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        tgt_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        query_pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n    ) -> Tuple[Tensor, Tensor]:\\\\\\\\\\\\\\\\n        tgt2 = self.norm1(tgt)\\\\\\\\\\\\\\\\n        q = k = self.with_pos_embed(tgt2, query_pos)\\\\\\\\\\\\\\\\n        tgt2, _ = self.self_attn(\\\\\\\\\\\\\\\\n            q,\\\\\\\\\\\\\\\\n            k,\\\\\\\\\\\\\\\\n            value=tgt2,\\\\\\\\\\\\\\\\n            attn_mask=tgt_mask,\\\\\\\\\\\\\\\\n            key_padding_mask=tgt_key_padding_mask,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        tgt = tgt + self.dropout1(tgt2)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        tgt2 = self.norm2(tgt)\\\\\\\\\\\\\\\\n        tgt2, attn_weights = self.multihead_attn(\\\\\\\\\\\\\\\\n            query=self.with_pos_embed(tgt2, query_pos),\\\\\\\\\\\\\\\\n            key=self.with_pos_embed(memory, pos),\\\\\\\\\\\\\\\\n            value=memory,\\\\\\\\\\\\\\\\n            attn_mask=memory_mask,\\\\\\\\\\\\\\\\n            key_padding_mask=memory_key_padding_mask,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        tgt = tgt + self.dropout2(tgt2)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        tgt2 = self.norm3(tgt)\\\\\\\\\\\\\\\\n        tgt2 = self.linear2(self.dropout(self.activation(self.linear1(tgt2))))\\\\\\\\\\\\\\\\n        tgt = tgt + self.dropout3(tgt2)\\\\\\\\\\\\\\\\n        return tgt, attn_weights\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        tgt: Tensor,\\\\\\\\\\\\\\\\n        memory: Tensor,\\\\\\\\\\\\\\\\n        tgt_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        tgt_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        query_pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n    ) -> Tuple[Tensor, Tensor]:\\\\\\\\\\\\\\\\n        if self.normalize_before:\\\\\\\\\\\\\\\\n            return self.forward_pre(\\\\\\\\\\\\\\\\n                tgt,\\\\\\\\\\\\\\\\n                memory,\\\\\\\\\\\\\\\\n                tgt_mask,\\\\\\\\\\\\\\\\n                memory_mask,\\\\\\\\\\\\\\\\n                tgt_key_padding_mask,\\\\\\\\\\\\\\\\n                memory_key_padding_mask,\\\\\\\\\\\\\\\\n                pos,\\\\\\\\\\\\\\\\n                query_pos,\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n        return self.forward_post(\\\\\\\\\\\\\\\\n            tgt,\\\\\\\\\\\\\\\\n            memory,\\\\\\\\\\\\\\\\n            tgt_mask,\\\\\\\\\\\\\\\\n            memory_mask,\\\\\\\\\\\\\\\\n            tgt_key_padding_mask,\\\\\\\\\\\\\\\\n            memory_key_padding_mask,\\\\\\\\\\\\\\\\n            pos,\\\\\\\\\\\\\\\\n            query_pos,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _get_clones(module: nn.Module, count: int) -> nn.ModuleList:\\\\\\\\\\\\\\\\n    return nn.ModuleList([copy.deepcopy(module) for _ in range(count)])\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef _get_activation_fn(activation: str) -> Callable[[Tensor], Tensor]:\\\\\\\\\\\\\\\\n    if activation == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"relu\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n        return F.relu\\\\\\\\\\\\\\\\n    if activation == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"gelu\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n        return F.gelu\\\\\\\\\\\\\\\\n    if activation == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"glu\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\n        return F.glu\\\\\\\\\\\\\\\\n    raise RuntimeError(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"activation should be relu/gelu/glu, not {activation}.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n__all__ = [\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"TransformerDecoder\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"TransformerDecoderLayer\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":0,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"completed\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_15\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,220p' Body-Tell/scripts/parameter_audit.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"#!/usr/bin/env python3\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Audit Body-Tell model parameter counts and emit an HTML report.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nfrom __future__ import annotations\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport argparse\\\\\\\\\\\\\\\\nimport html\\\\\\\\\\\\\\\\nimport importlib.util\\\\\\\\\\\\\\\\nimport json\\\\\\\\\\\\\\\\nimport re\\\\\\\\\\\\\\\\nimport sys\\\\\\\\\\\\\\\\nfrom collections import defaultdict\\\\\\\\\\\\\\\\nfrom dataclasses import asdict\\\\\\\\\\\\\\\\nfrom datetime import datetime\\\\\\\\\\\\\\\\nfrom pathlib import Path\\\\\\\\\\\\\\\\nfrom typing import Any\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport torch\\\\\\\\\\\\\\\\nimport yaml\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nREPO_ROOT = Path(__file__).resolve().parents[2]\\\\\\\\\\\\\\\\nBODY_TELL_ROOT = Path(__file__).resolve().parents[1]\\\\\\\\\\\\\\\\nif str(BODY_TELL_ROOT) not in sys.path:\\\\\\\\\\\\\\\\n    sys.path.insert(0, str(BODY_TELL_ROOT))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef load_body_train_module() -> Any:\\\\\\\\\\\\\\\\n    train_path = BODY_TELL_ROOT / \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"train.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    spec = importlib.util.spec_from_file_location(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"body_tell_train_entry\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", train_path)\\\\\\\\\\\\\\\\n    if spec is None or spec.loader is None:\\\\\\\\\\\\\\\\n        raise RuntimeError(f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Cannot import training entry from {train_path}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n    module = importlib.util.module_from_spec(spec)\\\\\\\\\\\\\\\\n    spec.loader.exec_module(module)\\\\\\\\\\\\\\\\n    return module\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef human_count(value: int) -> str:\\\\\\\\\\\\\\\\n    if value >= 1_000_000_000:\\\\\\\\\\\\\\\\n        return f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{value / 1_000_000_000:.3f}B\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    if value >= 1_000_000:\\\\\\\\\\\\\\\\n        return f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{value / 1_000_000:.3f}M\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    if value >= 1_000:\\\\\\\\\\\\\\\\n        return f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{value / 1_000:.3f}K\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    return str(value)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef bytes_to_gib(value: int) -> float:\\\\\\\\\\\\\\\\n    return value / (1024**3)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef module_param_count(model: torch.nn.Module, prefix: str) -> tuple[int, int]:\\\\\\\\\\\\\\\\n    module = model.get_submodule(prefix) if prefix else model\\\\\\\\\\\\\\\\n    total = sum(param.numel() for param in module.parameters())\\\\\\\\\\\\\\\\n    trainable = sum(param.numel() for param in module.parameters() if param.requires_grad)\\\\\\\\\\\\\\\\n    return total, trainable\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef direct_child_counts(model: torch.nn.Module) -> list[dict[str, Any]]:\\\\\\\\\\\\\\\\n    rows = []\\\\\\\\\\\\\\\\n    for name, child in model.named_children():\\\\\\\\\\\\\\\\n        total = sum(param.numel() for param in child.parameters())\\\\\\\\\\\\\\\\n        trainable = sum(param.numel() for param in child.parameters() if param.requires_grad)\\\\\\\\\\\\\\\\n        rows.append({\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": name, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"total\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": total, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"trainable\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": trainable})\\\\\\\\\\\\\\\\n    return rows\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef subtree_counts(model: torch.nn.Module) -> list[dict[str, Any]]:\\\\\\\\\\\\\\\\n    prefixes = [\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"encoder\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"encoder.stages.0\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"encoder.stages.1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"encoder.stages.2\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"encoder.stages.3\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"encoder.stages.4\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"project_visual_embed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"project_text_embed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"transformer_decoder\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"transformer_decoder.layers.0\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"transformer_decoder.layers.1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"transformer_decoder.layers.2\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"transformer_decoder.layers.3\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"transformer_decoder.layers.4\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"transformer_decoder.layers.5\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"transformer_decoder.norm\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mask_projections\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mask_projections.0\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mask_projections.1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mask_projections.2\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"mask_projections.3\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"decoder\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"decoder.upconvs\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"decoder.blocks\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"decoder.seg_layers\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n    ]\\\\\\\\\\\\\\\\n    rows = []\\\\\\\\\\\\\\\\n    for prefix in prefixes:\\\\\\\\\\\\\\\\n        try:\\\\\\\\\\\\\\\\n            total, trainable = module_param_count(model, prefix)\\\\\\\\\\\\\\\\n        except AttributeError:\\\\\\\\\\\\\\\\n            continue\\\\\\\\\\\\\\\\n        rows.append({\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": prefix, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"total\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": total, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"trainable\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": trainable})\\\\\\\\\\\\\\\\n    return rows\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef parameter_rows(model: torch.nn.Module) -> list[dict[str, Any]]:\\\\\\\\\\\\\\\\n    rows = []\\\\\\\\\\\\\\\\n    for name, param in model.named_parameters():\\\\\\\\\\\\\\\\n        rows.append(\\\\\\\\\\\\\\\\n            {\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": name,\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": tuple(int(x) for x in param.shape),\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"numel\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": int(param.numel()),\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"requires_grad\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": bool(param.requires_grad),\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"dtype\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": str(param.dtype).replace(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"torch.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"),\\\\\\\\\\\\\\\\n            }\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n    return sorted(rows, key=lambda item: item[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"numel\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"], reverse=True)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef top_level_from_name(name: str) -> str:\\\\\\\\\\\\\\\\n    return name.split(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\".\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 1)[0]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef category_counts(param_rows: list[dict[str, Any]]) -> list[dict[str, Any]]:\\\\\\\\\\\\\\\\n    grouped: dict[str, dict[str, int]] = defaultdict(lambda: {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"total\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"trainable\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 0})\\\\\\\\\\\\\\\\n    for row in param_rows:\\\\\\\\\\\\\\\\n        key = top_level_from_name(row[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"])\\\\\\\\\\\\\\\\n        grouped[key][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"total\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] += row[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"numel\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]\\\\\\\\\\\\\\\\n        if row[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"requires_grad\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]:\\\\\\\\\\\\\\\\n            grouped[key][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"trainable\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] += row[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"numel\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]\\\\\\\\\\\\\\\\n    return [\\\\\\\\\\\\\\\\n        {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": name, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"total\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": counts[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"total\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"], \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"trainable\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": counts[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"trainable\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]}\\\\\\\\\\\\\\\\n        for name, counts in sorted(grouped.items(), key=lambda item: item[1][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"total\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"], reverse=True)\\\\\\\\\\\\\\\\n    ]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef find_logged_parameter_count(log_path: Path | None) -> int | None:\\\\\\\\\\\\\\\\n    if not log_path or not log_path.exists():\\\\\\\\\\\\\\\\n        return None\\\\\\\\\\\\\\\\n    pattern = re.compile(r\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Model parameters:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\s*([0-9,]+)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n    for line in log_path.read_text(encoding=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"utf-8\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", errors=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"replace\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").splitlines():\\\\\\\\\\\\\\\\n        match = pattern.search(line)\\\\\\\\\\\\\\\\n        if match:\\\\\\\\\\\\\\\\n            return int(match.group(1).replace(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"))\\\\\\\\\\\\\\\\n    return None\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef parse_training_metrics(log_path: Path | None) -> dict[str, Any] | None:\\\\\\\\\\\\\\\\n    if not log_path or not log_path.exists():\\\\\\\\\\\\\\\\n        return None\\\\\\\\\\\\\\\\n    epoch_pattern = re.compile(\\\\\\\\\\\\\\\\n        r\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Epoch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\s+(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\d+).*?loss=([0-9.]+).*?dice=([0-9.]+).*?fg_dice=([0-9.]+).*?neg_fp=([0-9.]+)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n    val_pattern = re.compile(\\\\\\\\\\\\\\\\n        r\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\[val\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\s+loss=([0-9.]+)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\s+\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\|\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\s+fg_dice=([0-9.]+)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\s+\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\|\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\s+neg_fp=([0-9.]+)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n    train_rows = []\\\\\\\\\\\\\\\\n    val_rows = []\\\\\\\\\\\\\\\\n    for line in log_path.read_text(encoding=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"utf-8\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", errors=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"replace\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").splitlines():\\\\\\\\\\\\\\\\n        epoch_match = epoch_pattern.search(line)\\\\\\\\\\\\\\\\n        if epoch_match:\\\\\\\\\\\\\\\\n            train_rows.append(\\\\\\\\\\\\\\\\n                {\\\\\\\\\\\\\\\\n                    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"epoch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": int(epoch_match.group(1)),\\\\\\\\\\\\\\\\n                    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"loss\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": float(epoch_match.group(2)),\\\\\\\\\\\\\\\\n                    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"dice_loss\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": float(epoch_match.group(3)),\\\\\\\\\\\\\\\\n                    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"fg_dice\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": float(epoch_match.group(4)),\\\\\\\\\\\\\\\\n                    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"neg_fp\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": float(epoch_match.group(5)),\\\\\\\\\\\\\\\\n                }\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n            continue\\\\\\\\\\\\\\\\n        val_match = val_pattern.search(line)\\\\\\\\\\\\\\\\n        if val_match:\\\\\\\\\\\\\\\\n            val_rows.append(\\\\\\\\\\\\\\\\n                {\\\\\\\\\\\\\\\\n                    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"epoch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": len(val_rows) + 1,\\\\\\\\\\\\\\\\n                    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"loss\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": float(val_match.group(1)),\\\\\\\\\\\\\\\\n                    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"fg_dice\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": float(val_match.group(2)),\\\\\\\\\\\\\\\\n                    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"neg_fp\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": float(val_match.group(3)),\\\\\\\\\\\\\\\\n                }\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n    if not train_rows and not val_rows:\\\\\\\\\\\\\\\\n        return None\\\\\\\\\\\\\\\\n    return {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"train\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": train_rows, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"val\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": val_rows}\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef pct(value: int, total: int) -> str:\\\\\\\\\\\\\\\\n    if total == 0:\\\\\\\\\\\\\\\\n        return \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"0.00%\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    return f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"{100 * value / total:.2f}%\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef row_html(row: dict[str, Any], total: int) -> str:\\\\\\\\\\\\\\\\n    return (\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<tr>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td><code>{html.escape(str(row['name']))}</code></td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td class=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"num\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\">{row['total']:,}</td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td class=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"num\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\">{human_count(row['total'])}</td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td class=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"num\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\">{pct(row['total'], total)}</td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td class=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"num\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\">{row['trainable']:,}</td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"</tr>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef param_row_html(row: dict[str, Any], total: int) -> str:\\\\\\\\\\\\\\\\n    return (\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<tr>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td><code>{html.escape(row['name'])}</code></td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td><code>{html.escape(str(row['shape']))}</code></td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td class=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"num\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\">{row['numel']:,}</td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td class=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"num\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\">{pct(row['numel'], total)}</td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td>{html.escape(row['dtype'])}</td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"<td>{'yes' if row['requires_grad'] else 'no'}</td>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"</tr>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\ndef render_report(audit: dict[str, Any]) -> str:\\\\\\\\\\\\\\\\n    total = audit[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"totals\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"][\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"parameters\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":0,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"completed\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_12\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '250,430p' Body-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"        <thead>\\\\\\\\\\\\\\\\n          <tr><th>模块</th><th>目标实现</th><th>权重复用要求</th></tr>\\\\\\\\\\\\\\\\n        </thead>\\\\\\\\\\\\\\\\n        <tbody>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td><code>encoder</code></td>\\\\\\\\\\\\\\\\n            <td>使用 <code>dynamic_network_architectures.building_blocks.residual_encoders.ResidualEncoder</code>，参数与 VoxTell v1.1 plan 一致。</td>\\\\\\\\\\\\\\\\n            <td>加载 VoxTell <code>encoder.*</code> 权重，shape mismatch 必须报错。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td><code>decoder</code></td>\\\\\\\\\\\\\\\\n            <td>移植 VoxTell <code>VoxTellDecoder</code>，保留 5 个 stage、<code>StackedConvBlocks</code>、<code>seg_layers</code> always-built 语义。</td>\\\\\\\\\\\\\\\\n            <td>加载 VoxTell <code>decoder.*</code> 权重；为了严格兼容，可保留 <code>self.encoder = encoder</code> 这一共享引用。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td><code>transformer_decoder</code></td>\\\\\\\\\\\\\\\\n            <td>与 VoxTell 的 <code>TransformerDecoderLayer</code> 行为一致：默认 <code>relu</code>，pre-norm 不执行 self-attention。</td>\\\\\\\\\\\\\\\\n            <td>同名加载 VoxTell transformer 权重；保留 self-attention 参数，即使 active path 不使用。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td><code>project_bottleneck_embed</code></td>\\\\\\\\\\\\\\\\n            <td>使用 VoxTell 命名，替代当前 <code>project_visual_embed</code>；结构仍为 <code>320 -&gt; 2048 -&gt; 2048</code>。</td>\\\\\\\\\\\\\\\\n            <td>直接加载 VoxTell <code>project_bottleneck_embed.*</code>。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td><code>project_text_embed</code></td>\\\\\\\\\\\\\\\\n            <td>保持 <code>2560 -&gt; 2048 -&gt; 2048</code>。</td>\\\\\\\\\\\\\\\\n            <td>直接加载 VoxTell <code>project_text_embed.*</code>。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td><code>project_to_decoder_channels</code> + <code>num_heads</code></td>\\\\\\\\\\\\\\\\n            <td>使用 VoxTell 命名，替代当前 <code>mask_projections</code>；5 级；输出维度 = encoder 各级 channels × <code>num_heads</code>。<strong>条件性对齐</strong>（父表 #13，域差异豁免）：如果实验目标是<strong>直接复用 VoxTell <code>project_to_decoder_channels.*</code> 和 mask fusion 权重</strong>，则必须设 <code>num_heads=1</code>，实际输出 <code>[32, 64, 128, 256, 320]</code> 量级；如果仅做结构对齐而不复用这部分权重（更符合 Body-Tell occupancy grid 任务的需求，因为 <code>num_heads=32</code> 提供 32× mask fusion 容量是为该任务调过的），则保留 <code>num_heads=32</code>。</td>\\\\\\\\\\\\\\\\n            <td>选 <code>num_heads=1</code>：直接加载 VoxTell <code>project_to_decoder_channels.*</code>。选保留 <code>num_heads=32</code>：必须把 <code>project_to_decoder_channels.*</code> 与 mask fusion 相关 key 全部加入跳过白名单，并在 audit 中登记\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"为保留 Body-Tell mask fusion 容量而跳过这部分权重复用\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td><code>pos_embed</code></td>\\\\\\\\\\\\\\\\n            <td>提供两种 policy：<code>dynamic_hwd</code> 用于当前非 192³ Body-Tell 输入；<code>fixed_voxtell_192</code> 用于严格复刻 VoxTell patch。</td>\\\\\\\\\\\\\\\\n            <td><code>dynamic_hwd</code> 模式跳过 checkpoint 中 <code>pos_embed</code>；<code>fixed_voxtell_192</code> 模式要求 shape 完全匹配。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n        </tbody>\\\\\\\\\\\\\\\\n      </table>\\\\\\\\\\\\\\\\n    </section>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    <section>\\\\\\\\\\\\\\\\n      <h2>实施阶段</h2>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n      <h3>P0：建立兼容性基线</h3>\\\\\\\\\\\\\\\\n      <ol>\\\\\\\\\\\\\\\\n        <li><strong>（2026-05-24 新增）<code>num_heads</code> 与 projection shape 显式审计</strong>：新增 <code>Body-Tell/scripts/audit_voxtell_alignment.py</code>（如果与已有 <code>scripts/parameter_audit.py</code> 重合，应共享 utilities）。<strong>脚本第一步必须打印两侧 <code>num_heads</code> 值和每级 <code>project_to_decoder_channels</code> 实际输出 shape</strong>，确认 VoxTell 为 <code>num_heads=1</code> + 输出 <code>[32, 64, 128, 256, 320]</code> 量级，Body-Tell 当前为 <code>num_heads=32</code> + 输出 <code>[32, 2048, 4096, 8192]</code>。该审计是父表 #13 <code>num_heads</code> 决议（路径 A vs 路径 B）的输入材料，audit 完成后才能在 P4 选定路径。</li>\\\\\\\\\\\\\\\\n        <li>实例化 Body-Tell aligned model 和 VoxTell v1.1 model，输出总参数、模块参数、state dict key/shape 覆盖率。</li>\\\\\\\\\\\\\\\\n        <li>新增 transformer golden test <code>Body-Tell/tests/test_voxtell_transformer_compat.py</code>：同一小尺寸 state dict、相同输入、dropout=0 时，Body-Tell aligned transformer 输出必须与 VoxTell transformer 完全一致或在 <code>1e-6</code> 内。</li>\\\\\\\\\\\\\\\\n        <li>新增 weight key audit：读取 <code>VoxTell/models-weight/voxtell/voxtell_v1.1/fold_0/checkpoint_final.pth</code>（已确认文件存在）的 <code>network_weights</code>，检查除 <code>pos_embed</code> 外的目标 key 是否全部可加载。</li>\\\\\\\\\\\\\\\\n      </ol>\\\\\\\\\\\\\\\\n      <p>验收：当前轻量模型仍可跑旧测试；新增审计能明确报告哪些 key 会加载、哪些 key 因 policy 跳过；<strong>且 <code>num_heads</code> 决议（设为 1 / 保留 32）必须先于 P4 落地</strong>。</p>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n      <h3>P1：先修 transformer decoder 语义</h3>\\\\\\\\\\\\\\\\n      <ol>\\\\\\\\\\\\\\\\n        <li>把 <code>Body-Tell/body_tell/models/transformer.py</code> 的 active <code>forward_pre</code> 改为 VoxTell 版本：从 <code>norm2 -&gt; cross_attn -&gt; norm3 -&gt; FFN</code> 开始，不执行 self-attention。</li>\\\\\\\\\\\\\\\\n        <li>构造层时去掉 <code>activation=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"gelu\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"</code>，或显式设为 <code>relu</code>，与 VoxTell 默认一致。</li>\\\\\\\\\\\\\\\\n        <li>保留 <code>self_attn</code>、<code>norm1</code> 等参数名和 shape，保证 checkpoint key 不变。</li>\\\\\\\\\\\\\\\\n      </ol>\\\\\\\\\\\\\\\\n      <p>验收：Body-Tell aligned transformer 与 VoxTell transformer 小模型 parity test 通过；加载 VoxTell <code>transformer_decoder.*</code> 后无 missing/unexpected/shape mismatch。</p>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n      <h3>P2：替换 encoder 为 VoxTell residual encoder</h3>\\\\\\\\\\\\\\\\n      <ol>\\\\\\\\\\\\\\\\n        <li>新增配置文件 <code>Body-Tell/configs/phase1_voxtell_aligned.yaml</code>，设置 <code>encoder_channels: [32,64,128,256,320,320]</code>、<code>n_blocks_per_stage: [1,3,4,6,6,6]</code>、<code>decoder_layer: 4</code>、<code>num_maskformer_stages: 5</code>。</li>\\\\\\\\\\\\\\\\n        <li>在模型配置中加入 <code>architecture: voxtell_v1_1</code> 或 <code>backbone: residual_encoder</code>，让旧轻量模型和 aligned 模型可并存。</li>\\\\\\\\\\\\\\\\n        <li>使用 VoxTell 相同构造参数：<code>conv_bias=true</code>、<code>InstanceNorm3d(eps=1e-5, affine=True)</code>、<code>LeakyReLU(inplace=True)</code>、<code>BasicBlockD</code>、<code>return_skips=True</code>、<code>disable_default_stem=False</code>。</li>\\\\\\\\\\\\\\\\n        <li>把依赖写入 Body-Tell 环境声明：<code>dynamic-network-architectures&gt;=0.4.1,&lt;0.5</code> 和 <code>einops</code>。若采用 VoxTell 原始位置编码实现，再加入 <code>positional-encodings</code>。</li>\\\\\\\\\\\\\\\\n      </ol>\\\\\\\\\\\\\\\\n      <p>验收：encoder 参数约 <code>90.30M</code>；输出 6 个 skip；<code>encoder.output_channels</code> 和 <code>encoder.strides</code> 与 VoxTell 一致；VoxTell <code>encoder.*</code> 权重可加载。</p>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n      <h3>P3：替换 decoder 为 VoxTellDecoder</h3>\\\\\\\\\\\\\\\\n      <ol>\\\\\\\\\\\\\\\\n        <li>移植 <code>VoxTellDecoder</code> 到 Body-Tell 模型代码或独立模块，优先保持源码结构、字段名和 state dict key 兼容。</li>\\\\\\\\\\\\\\\\n        <li>使用 <code>n_conv_per_stage_decoder=[1,1,1,1,1]</code>，并继承 encoder 的 conv/norm/nonlin/dropout/bias。</li>\\\\\\\\\\\\\\\\n        <li>即使 <code>deep_supervision=false</code>，也总是构造 5 个 <code>seg_layers</code>，与 VoxTell checkpoint 兼容。</li>\\\\\\\\\\\\\\\\n        <li>移除 Body-Tell 当前 decoder 中 upconv 后的自动 <code>F.interpolate</code> fallback；如果输入尺寸不能通过转置卷积对齐，应在测试中显式暴露，或在数据裁剪 policy 中解决。</li>\\\\\\\\\\\\\\\\n      </ol>\\\\\\\\\\\\\\\\n      <p>验收：decoder 本体参数约 <code>12.18M</code>；5 个 stage / 5 个 transposed conv / 5 个 seg layer；VoxTell <code>decoder.*</code> 权重可加载。统计 decoder 参数时需扣除共享 encoder，避免误读为 <code>102.47M</code>。</p>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n      <h3>P4：对齐 projection、mask head、<code>num_heads</code> 决议和 forward 排列</h3>\\\\\\\\\\\\\\\\n      <div class=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"callout warnbox\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"><strong>P4 <code>num_heads</code> 决议（父表 #13，域差异豁免）</strong>：在执行 P4 前必须先选定路径——\\\\\\\\\\\\\\\\n        <ul>\\\\\\\\\\\\\\\\n          <li><strong>路径 A（强对齐，复用权重）</strong>：<code>num_heads=1</code>，projection 输出 <code>[32, 64, 128, 256, 320]</code>，可直接加载 VoxTell <code>project_to_decoder_channels.*</code> 与 mask fusion 权重。代价：失去 Body-Tell 现有 32× mask fusion 容量。</li>\\\\\\\\\\\\\\\\n          <li><strong>路径 B（结构对齐但放弃这部分权重复用，推荐）</strong>：保留 <code>num_heads=32</code>，projection 输出维持 <code>[32, 2048, 4096, 8192, 10240]</code>（encoder 升 6 级后扩展），<code>project_to_decoder_channels.*</code> 与 mask fusion 权重 <strong>不加载</strong>，加入 P6 跳过白名单。理由：Body-Tell 处理 occupancy grid 与 VoxTell 医学影像任务差异显著，这部分权重的可迁移性弱，而 mask fusion 容量对当前任务更有价值。</li>\\\\\\\\\\\\\\\\n        </ul>\\\\\\\\\\\\\\\\n        默认建议路径 B，并在 P0 audit 中显式打印决议来源。如果 audit 没有给出明确收益对比，<strong>保持现状（路径 B）即可，不强制对齐 <code>num_heads</code></strong>。\\\\\\\\\\\\\\\\n      </div>\\\\\\\\\\\\\\\\n      <ol>\\\\\\\\\\\\\\\\n        <li><strong>（2026-05-24 修订）<code>num_heads</code> 决议生效</strong>：按上方选定路径执行。路径 A 需把配置 <code>num_heads</code> 默认值改为 <code>1</code>，同时审计 Body-Tell 中所有依赖 <code>num_heads</code> 的 reshape（如 <code>view(B, num_heads, C//num_heads)</code>）和 decoder stage 内 <code>input_features + num_heads</code> 的通道拼接是否正确退化；路径 B 不改 <code>num_heads</code>，但需要在 P6 把 <code>project_to_decoder_channels.*</code> 与 mask fusion 相关 key 加入跳过白名单。</li>\\\\\\\\\\\\\\\\n        <li>把当前 <code>project_visual_embed</code> 改为 VoxTell 命名 <code>project_bottleneck_embed</code>；把 <code>mask_projections</code> 改为 <code>project_to_decoder_channels</code>。</li>\\\\\\\\\\\\\\\\n        <li>encoder 变为 6-stage 后，projection stage 自然恢复为 5 级，不再用 <code>len(encoder_channels)-1</code> 隐式截断配置。</li>\\\\\\\\\\\\\\\\n        <li>forward 中使用 VoxTell 的 memory 排列：<code>b c d h w -&gt; b h w d c -&gt; (h w d) b c</code>。</li>\\\\\\\\\\\\\\\\n        <li>decoder 输出仍保持 Body-Tell 训练和推理需要的 <code>(B, N, D, H, W)</code> 语义；如果内部沿用 VoxTell 注释中的 <code>h,w,d</code> 命名，需要在单测里用非立方输入验证轴没有被误换。</li>\\\\\\\\\\\\\\\\n      </ol>\\\\\\\\\\\\\\\\n      <p>验收：5 个 projection 输出维度按选定路径（路径 A: <code>[32, 64, 128, 256, 320]</code>；路径 B: <code>[32, 2048, 4096, 8192, 10240]</code>）；非立方输入的输出 shape 与 target mask 完全一致；mask fusion 模块在选定 <code>num_heads</code> 下有显式单测；audit 报告记录选定路径与原因。</p>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n      <h3>P5：位置编码策略</h3>\\\\\\\\\\\\\\\\n      <table>\\\\\\\\\\\\\\\\n        <thead>\\\\\\\\\\\\\\\\n          <tr><th>策略</th><th>适用场景</th><th>实现方式</th><th>权重加载</th></tr>\\\\\\\\\\\\\\\\n        </thead>\\\\\\\\\\\\\\\\n        <tbody>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td><code>dynamic_hwd</code></td>\\\\\\\\\\\\\\\\n            <td>推荐用于当前 Body-Tell 数据，因为 <code>[129,108,256]</code>（commit <code>5c31e57</code> 后的实际 crop 尺寸）不是 VoxTell 的 192³ patch。</td>\\\\\\\\\\\\\\\\n            <td>按 selected feature 的实时 <code>H,W,D</code> 生成 deterministic 3D positional encoding，并缓存到 device/dtype。</td>\\\\\\\\\\\\\\\\n            <td>跳过 VoxTell checkpoint 的 <code>pos_embed</code>，其余权重严格加载。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td><code>fixed_voxtell_192</code></td>\\\\\\\\\\\\\\\\n            <td>用于做完全复刻实验，或想验证整份 VoxTell state dict 可严格加载。</td>\\\\\\\\\\\\\\\\n            <td>把 Body-Tell 数据裁剪/填充到 <code>[192,192,192]</code>，注册 shape 为 <code>(1728,1,2048)</code> 的 <code>pos_embed</code>。</td>\\\\\\\\\\\\\\\\n            <td>要求 checkpoint 中 <code>pos_embed</code> 直接加载；数据体素尺寸也必须配套调整。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n        </tbody>\\\\\\\\\\\\\\\\n      </table>\\\\\\\\\\\\\\\\n      <p>建议先落地 <code>dynamic_hwd</code>。它牺牲的是固定 buffer 的逐元素复用，不牺牲 transformer 权重语义；对当前非立方 Body-Tell 数据更可实现。</p>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n      <h3>P6：权重加载入口</h3>\\\\\\\\\\\\\\\\n      <ol>\\\\\\\\\\\\\\\\n        <li>新增训练参数 <code>--init-from-voxtell VoxTell/models-weight/voxtell/voxtell_v1.1</code>，在 optimizer 构造前加载。</li>\\\\\\\\\\\\\\\\n        <li>新增 loader：读取 <code>fold_0/checkpoint_final.pth</code> 的 <code>network_weights</code>，按当前 aligned 模型 key 直接加载。</li>\\\\\\\\\\\\\\\\n        <li><strong>（2026-05-24 修订）显式 <code>unexpected_keys</code> 白名单</strong>：调用 <code>model.load_state_dict(state_dict, strict=False)</code> 后，断言 <code>set(unexpected_keys) ⊆ POLICY_ALLOWED_SKIP</code>（默认 <code>{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pos_embed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}</code>；若 P4 决定保留 <code>num_heads=32</code>，再扩展到 <code>{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"pos_embed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"project_to_decoder_channels.*\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"decoder.<mask_fusion_keys>\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}</code>）。<strong>任何 shape mismatch 必须抛错，不得静默跳过</strong>；<code>missing_keys</code> 不为空时打印完整列表并要求显式确认。</li>\\\\\\\\\\\\\\\\n        <li>日志记录 loaded tensor 数、loaded 参数数、skipped key、missing key、unexpected key，并写入训练 checkpoint 的 <code>config.init_from_voxtell</code>。</li>\\\\\\\\\\\\\\\\n        <li>不要把旧 Body-Tell checkpoint 与 aligned 模型静默混用。旧 checkpoint 应只用于旧架构；aligned checkpoint 应带 <code>architecture: voxtell_v1_1</code>。</li>\\\\\\\\\\\\\\\\n      </ol>\\\\\\\\\\\\\\\\n      <p>验收：在 CPU 上能完成权重加载审计；<code>unexpected_keys</code> 与 policy 白名单一致；在 GPU 上能完成至少 1 个 batch 的 forward/loss/backward smoke。</p>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n      <h3>P7：训练实验矩阵</h3>\\\\\\\\\\\\\\\\n      <table>\\\\\\\\\\\\\\\\n        <thead>\\\\\\\\\\\\\\\\n          <tr><th>实验</th><th>初始化</th><th>目的</th><th>建议</th></tr>\\\\\\\\\\\\\\\\n        </thead>\\\\\\\\\\\\\\\\n        <tbody>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td>A：当前基线</td>\\\\\\\\\\\\\\\\n            <td>现有轻量 Body-Tell checkpoint</td>\\\\\\\\\\\\\\\\n            <td>保持可回退基线。</td>\\\\\\\\\\\\\\\\n            <td>记录当前 val foreground Dice 约 <code>0.3257</code>。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td>B：aligned random</td>\\\\\\\\\\\\\\\\n            <td>VoxTell-aligned 结构，随机初始化</td>\\\\\\\\\\\\\\\\n            <td>分离“结构变大”与“VoxTell 权重”的收益。</td>\\\\\\\\\\\\\\\\n            <td>先跑短程，确认显存和 loss 曲线。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td>C：aligned prompt-only</td>\\\\\\\\\\\\\\\\n            <td>只加载 transformer / text / projection 权重</td>\\\\\\\\\\\\\\\\n            <td>评估 prompt decoder 复用本身的收益。</td>\\\\\\\\\\\\\\\\n            <td>可作为中间回退，因为 encoder 输入域差异最大。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n          <tr>\\\\\\\\\\\\\\\\n            <td>D：aligned full</td>\\\\\\\\\\\\\\\\n            <td>加载 encoder、decoder、projection、transformer；按 policy 跳过或加载 <code>pos_embed</code></td>\\\\\\\\\\\\\\\\n            <td>完整复用 VoxTell 权重，验证性能上限。</td>\\\\\\\\\\\\\\\\n            <td>使用分组学习率：prompt/transformer 较低，encoder/decoder 可稍高；不要一开始冻结全部 encoder。</td>\\\\\\\\\\\\\\\\n          </tr>\\\\\\\\\\\\\\\\n        </tbody>\\\\\\\\\\\\\\\\n      </table>\\\\\\\\\\\\\\\\n    </section>\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    <section>\\\\\\\\\\\\\\\\n      <h2>验收命令</h2>\\\\\\\\\\\\\\\\n      <pre><code># 1. Transformer 行为必须与 VoxTell 对齐\\\\\\\\\\\\\\\\npython -m pytest Body-Tell/tests/test_voxtell_transformer_compat.py\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n# 2. 架构和 state dict key/shape 审计\\\\\\\\\\\\\\\\npython Body-Tell/scripts/audit_voxtell_alignment.py \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n  --config Body-Tell/configs/phase1_voxtell_aligned.yaml \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n  --voxtell-dir VoxTell/models-weight/voxtell/voxtell_v1.1 \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n  --pos-embed-policy dynamic_hwd\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n# 3. 训练 smoke，验证 forward/loss/backward/checkpoint\\\\\\\\\\\\\\\\ncd Body-Tell\\\\\\\\\\\\\\\\npython train.py \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n  --config configs/phase1_voxtell_aligned.yaml \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n  --init-from-voxtell ../VoxTell/models-weight/voxtell/voxtell_v1.1 \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n  --smoke --epochs 2 --batch-size 1 --num-workers 0 --amp\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":0,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"completed\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_13\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,260p' Body-Tell/body_tell/models/voxtell_body_model.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"VoxTell-style prompt-conditioned model adapted for Body-Tell occupancy grids.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nfrom __future__ import annotations\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport math\\\\\\\\\\\\\\\\nfrom dataclasses import dataclass\\\\\\\\\\\\\\\\nfrom typing import List, Sequence, Tuple\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport torch\\\\\\\\\\\\\\\\nimport torch.nn.functional as F\\\\\\\\\\\\\\\\nfrom torch import Tensor, nn\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nfrom .transformer import TransformerDecoder, TransformerDecoderLayer\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n@dataclass(frozen=True)\\\\\\\\\\\\\\\\nclass VoxTellBodyConfig:\\\\\\\\\\\\\\\\n    input_channels: int = 1\\\\\\\\\\\\\\\\n    encoder_channels: Tuple[int, ...] = (32, 64, 128, 256, 320)\\\\\\\\\\\\\\\\n    text_embedding_dim: int = 2560\\\\\\\\\\\\\\\\n    query_dim: int = 2048\\\\\\\\\\\\\\\\n    text_projection_hidden_dim: int = 2048\\\\\\\\\\\\\\\\n    transformer_num_heads: int = 8\\\\\\\\\\\\\\\\n    transformer_layers: int = 6\\\\\\\\\\\\\\\\n    transformer_feedforward_dim: int = 2048\\\\\\\\\\\\\\\\n    transformer_dropout: float = 0.1\\\\\\\\\\\\\\\\n    decoder_layer: int = -1\\\\\\\\\\\\\\\\n    num_maskformer_stages: int = 5\\\\\\\\\\\\\\\\n    num_heads: int = 32\\\\\\\\\\\\\\\\n    deep_supervision: bool = False\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass VoxTellBodyModel(nn.Module):\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Prompt-conditioned binary mask model using VoxTell-style dynamic heads.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def __init__(self, config: VoxTellBodyConfig | None = None) -> None:\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\n        self.config = config or VoxTellBodyConfig()\\\\\\\\\\\\\\\\n        if self.config.query_dim % self.config.transformer_num_heads != 0:\\\\\\\\\\\\\\\\n            raise ValueError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"query_dim must be divisible by transformer_num_heads\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n        if len(self.config.encoder_channels) < 2:\\\\\\\\\\\\\\\\n            raise ValueError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"encoder_channels must contain at least two stages\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n        if self.config.num_maskformer_stages < 1:\\\\\\\\\\\\\\\\n            raise ValueError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"num_maskformer_stages must be at least 1 for the dynamic mask head\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        self.encoder = _BodyEncoder(\\\\\\\\\\\\\\\\n            input_channels=self.config.input_channels,\\\\\\\\\\\\\\\\n            channels=self.config.encoder_channels,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        selected_stage = self.config.decoder_layer\\\\\\\\\\\\\\\\n        if selected_stage < 0:\\\\\\\\\\\\\\\\n            selected_stage = len(self.config.encoder_channels) + selected_stage\\\\\\\\\\\\\\\\n        if selected_stage < 0 or selected_stage >= len(self.config.encoder_channels):\\\\\\\\\\\\\\\\n            raise ValueError(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"decoder_layer selects no encoder stage\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\")\\\\\\\\\\\\\\\\n        self.selected_stage = selected_stage\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        selected_channels = self.config.encoder_channels[self.selected_stage]\\\\\\\\\\\\\\\\n        self.project_visual_embed = nn.Sequential(\\\\\\\\\\\\\\\\n            nn.Linear(selected_channels, self.config.query_dim),\\\\\\\\\\\\\\\\n            nn.GELU(),\\\\\\\\\\\\\\\\n            nn.Linear(self.config.query_dim, self.config.query_dim),\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        self.project_text_embed = nn.Sequential(\\\\\\\\\\\\\\\\n            nn.Linear(self.config.text_embedding_dim, self.config.text_projection_hidden_dim),\\\\\\\\\\\\\\\\n            nn.GELU(),\\\\\\\\\\\\\\\\n            nn.Linear(self.config.text_projection_hidden_dim, self.config.query_dim),\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        layer = TransformerDecoderLayer(\\\\\\\\\\\\\\\\n            d_model=self.config.query_dim,\\\\\\\\\\\\\\\\n            nhead=self.config.transformer_num_heads,\\\\\\\\\\\\\\\\n            dim_feedforward=self.config.transformer_feedforward_dim,\\\\\\\\\\\\\\\\n            dropout=self.config.transformer_dropout,\\\\\\\\\\\\\\\\n            activation=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"gelu\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n            normalize_before=True,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        self.transformer_decoder = TransformerDecoder(\\\\\\\\\\\\\\\\n            decoder_layer=layer,\\\\\\\\\\\\\\\\n            num_layers=self.config.transformer_layers,\\\\\\\\\\\\\\\\n            norm=nn.LayerNorm(self.config.query_dim),\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        self.fused_stage_count = min(\\\\\\\\\\\\\\\\n            self.config.num_maskformer_stages,\\\\\\\\\\\\\\\\n            len(self.config.encoder_channels) - 1,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        self.mask_projections = nn.ModuleList()\\\\\\\\\\\\\\\\n        for stage_index, channels in enumerate(self.config.encoder_channels[: self.fused_stage_count]):\\\\\\\\\\\\\\\\n            output_dim = channels if stage_index == 0 else channels * self.config.num_heads\\\\\\\\\\\\\\\\n            self.mask_projections.append(\\\\\\\\\\\\\\\\n                nn.Sequential(\\\\\\\\\\\\\\\\n                    nn.Linear(self.config.query_dim, self.config.text_projection_hidden_dim),\\\\\\\\\\\\\\\\n                    nn.GELU(),\\\\\\\\\\\\\\\\n                    nn.Linear(self.config.text_projection_hidden_dim, output_dim),\\\\\\\\\\\\\\\\n                )\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        self.decoder = _VoxTellBodyDecoder(\\\\\\\\\\\\\\\\n            encoder_channels=self.config.encoder_channels,\\\\\\\\\\\\\\\\n            num_heads=self.config.num_heads,\\\\\\\\\\\\\\\\n            fused_stage_count=self.fused_stage_count,\\\\\\\\\\\\\\\\n            deep_supervision=self.config.deep_supervision,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward(self, occupancy: Tensor, text_embeddings: Tensor) -> Tensor | List[Tensor]:\\\\\\\\\\\\\\\\n        if text_embeddings.ndim == 4 and text_embeddings.shape[2] == 1:\\\\\\\\\\\\\\\\n            text_embeddings = text_embeddings.squeeze(2)\\\\\\\\\\\\\\\\n        if text_embeddings.ndim != 3:\\\\\\\\\\\\\\\\n            raise ValueError(\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"text_embeddings must have shape (B, N, E) or (B, N, 1, E), \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n                f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"got {tuple(text_embeddings.shape)}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        skips = self.encoder(occupancy)\\\\\\\\\\\\\\\\n        selected_feature = skips[self.selected_stage]\\\\\\\\\\\\\\\\n        batch_size, channels, depth, height, width = selected_feature.shape\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        memory = selected_feature.permute(2, 3, 4, 0, 1).reshape(-1, batch_size, channels)\\\\\\\\\\\\\\\\n        memory = self.project_visual_embed(memory)\\\\\\\\\\\\\\\\n        pos = sinusoidal_position_encoding_3d(\\\\\\\\\\\\\\\\n            (depth, height, width),\\\\\\\\\\\\\\\\n            self.config.query_dim,\\\\\\\\\\\\\\\\n            device=memory.device,\\\\\\\\\\\\\\\\n            dtype=memory.dtype,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        text_queries = text_embeddings.permute(1, 0, 2)\\\\\\\\\\\\\\\\n        text_queries = self.project_text_embed(text_queries)\\\\\\\\\\\\\\\\n        mask_embedding, _ = self.transformer_decoder(\\\\\\\\\\\\\\\\n            tgt=text_queries,\\\\\\\\\\\\\\\\n            memory=memory,\\\\\\\\\\\\\\\\n            pos=pos,\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        mask_embedding = mask_embedding.permute(1, 0, 2)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        stage_embeddings = [projection(mask_embedding) for projection in self.mask_projections]\\\\\\\\\\\\\\\\n        num_prompts = text_embeddings.shape[1]\\\\\\\\\\\\\\\\n        per_prompt_outputs: List[List[Tensor]] = []\\\\\\\\\\\\\\\\n        for prompt_index in range(num_prompts):\\\\\\\\\\\\\\\\n            prompt_stage_embeddings = [\\\\\\\\\\\\\\\\n                embedding[:, prompt_index : prompt_index + 1, :]\\\\\\\\\\\\\\\\n                for embedding in stage_embeddings\\\\\\\\\\\\\\\\n            ]\\\\\\\\\\\\\\\\n            per_prompt_outputs.append(self.decoder(skips, prompt_stage_embeddings))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        outputs = [\\\\\\\\\\\\\\\\n            torch.cat(scale_outputs, dim=1)\\\\\\\\\\\\\\\\n            for scale_outputs in zip(*per_prompt_outputs)\\\\\\\\\\\\\\\\n        ]\\\\\\\\\\\\\\\\n        if self.config.deep_supervision:\\\\\\\\\\\\\\\\n            return outputs\\\\\\\\\\\\\\\\n        return outputs[0]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass _BodyEncoder(nn.Module):\\\\\\\\\\\\\\\\n    def __init__(self, input_channels: int, channels: Sequence[int]) -> None:\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\n        stages = []\\\\\\\\\\\\\\\\n        current_channels = input_channels\\\\\\\\\\\\\\\\n        for stage_index, output_channels in enumerate(channels):\\\\\\\\\\\\\\\\n            stride = 1 if stage_index == 0 else 2\\\\\\\\\\\\\\\\n            stages.append(_ConvBlock(current_channels, output_channels, stride=stride))\\\\\\\\\\\\\\\\n            current_channels = output_channels\\\\\\\\\\\\\\\\n        self.stages = nn.ModuleList(stages)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward(self, x: Tensor) -> List[Tensor]:\\\\\\\\\\\\\\\\n        skips = []\\\\\\\\\\\\\\\\n        for stage in self.stages:\\\\\\\\\\\\\\\\n            x = stage(x)\\\\\\\\\\\\\\\\n            skips.append(x)\\\\\\\\\\\\\\\\n        return skips\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass _VoxTellBodyDecoder(nn.Module):\\\\\\\\\\\\\\\\n    def __init__(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        encoder_channels: Sequence[int],\\\\\\\\\\\\\\\\n        num_heads: int,\\\\\\\\\\\\\\\\n        fused_stage_count: int,\\\\\\\\\\\\\\\\n        deep_supervision: bool,\\\\\\\\\\\\\\\\n    ) -> None:\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\n        self.encoder_channels = tuple(int(x) for x in encoder_channels)\\\\\\\\\\\\\\\\n        self.num_heads = int(num_heads)\\\\\\\\\\\\\\\\n        self.fused_stage_count = int(fused_stage_count)\\\\\\\\\\\\\\\\n        self.deep_supervision = bool(deep_supervision)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        upconvs = []\\\\\\\\\\\\\\\\n        blocks = []\\\\\\\\\\\\\\\\n        seg_layers = []\\\\\\\\\\\\\\\\n        current_channels = self.encoder_channels[-1]\\\\\\\\\\\\\\\\n        for target_stage in reversed(range(len(self.encoder_channels) - 1)):\\\\\\\\\\\\\\\\n            target_channels = self.encoder_channels[target_stage]\\\\\\\\\\\\\\\\n            upconvs.append(\\\\\\\\\\\\\\\\n                nn.ConvTranspose3d(\\\\\\\\\\\\\\\\n                    current_channels,\\\\\\\\\\\\\\\\n                    target_channels,\\\\\\\\\\\\\\\\n                    kernel_size=2,\\\\\\\\\\\\\\\\n                    stride=2,\\\\\\\\\\\\\\\\n                )\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n            blocks.append(_ConvBlock(target_channels * 2, target_channels))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            uses_intermediate_fusion = self._uses_fusion(target_stage) and target_stage > 0\\\\\\\\\\\\\\\\n            if uses_intermediate_fusion:\\\\\\\\\\\\\\\\n                if self.deep_supervision:\\\\\\\\\\\\\\\\n                    seg_layers.append(nn.Conv3d(target_channels + self.num_heads, 1, kernel_size=1))\\\\\\\\\\\\\\\\n                else:\\\\\\\\\\\\\\\\n                    seg_layers.append(nn.Identity())\\\\\\\\\\\\\\\\n                current_channels = target_channels + self.num_heads\\\\\\\\\\\\\\\\n            else:\\\\\\\\\\\\\\\\n                seg_layers.append(nn.Identity())\\\\\\\\\\\\\\\\n                current_channels = target_channels\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        self.upconvs = nn.ModuleList(upconvs)\\\\\\\\\\\\\\\\n        self.blocks = nn.ModuleList(blocks)\\\\\\\\\\\\\\\\n        self.seg_layers = nn.ModuleList(seg_layers)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward(self, skips: Sequence[Tensor], mask_embeddings: Sequence[Tensor]) -> List[Tensor]:\\\\\\\\\\\\\\\\n        x = skips[-1]\\\\\\\\\\\\\\\\n        outputs = []\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        for decoder_index, target_stage in enumerate(reversed(range(len(skips) - 1))):\\\\\\\\\\\\\\\\n            skip = skips[target_stage]\\\\\\\\\\\\\\\\n            x = self.upconvs[decoder_index](x)\\\\\\\\\\\\\\\\n            if x.shape[2:] != skip.shape[2:]:\\\\\\\\\\\\\\\\n                x = F.interpolate(x, size=skip.shape[2:], mode=\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"trilinear\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", align_corners=False)\\\\\\\\\\\\\\\\n            x = torch.cat((x, skip), dim=1)\\\\\\\\\\\\\\\\n            x = self.blocks[decoder_index](x)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            if target_stage == 0:\\\\\\\\\\\\\\\\n                mask_embedding = mask_embeddings[0]\\\\\\\\\\\\\\\\n                outputs.append(torch.einsum(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"b c d h w, b n c -> b n d h w\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", x, mask_embedding))\\\\\\\\\\\\\\\\n                continue\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            if self._uses_fusion(target_stage):\\\\\\\\\\\\\\\\n                mask_embedding = mask_embeddings[target_stage]\\\\\\\\\\\\\\\\n                batch_size, _, channels = mask_embedding.shape\\\\\\\\\\\\\\\\n                mask_embedding = mask_embedding.view(batch_size, self.num_heads, channels // self.num_heads)\\\\\\\\\\\\\\\\n                fusion = torch.einsum(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"b c d h w, b n c -> b n d h w\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", x, mask_embedding)\\\\\\\\\\\\\\\\n                x = torch.cat((x, fusion), dim=1)\\\\\\\\\\\\\\\\n                if self.deep_supervision:\\\\\\\\\\\\\\\\n                    outputs.append(self.seg_layers[decoder_index](x))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        outputs = outputs[::-1]\\\\\\\\\\\\\\\\n        if not self.deep_supervision:\\\\\\\\\\\\\\\\n            return outputs[:1]\\\\\\\\\\\\\\\\n        return outputs\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def _uses_fusion(self, stage_index: int) -> bool:\\\\\\\\\\\\\\\\n        return stage_index < self.fused_stage_count\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass _ConvBlock(nn.Module):\\\\\\\\\\\\\\\\n    def __init__(self, in_channels: int, out_channels: int, stride: int = 1) -> None:\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\n        self.block = nn.Sequential(\\\\\\\\\\\\\\\\n            nn.Conv3d(in_channels, out_channels, kernel_size=3, stride=stride, padding=1, bias=False),\\\\\\\\\\\\\\\\n            nn.GroupNorm(_num_groups(out_channels), out_channels),\\\\\\\\\\\\\\\\n            nn.GELU(),\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":0,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"completed\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.started\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_16\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,460p' VoxTell/voxtell/model/voxtell_model.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":null,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"in_progress\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.started\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_17\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,340p' VoxTell/voxtell/model/transformer.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":null,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"in_progress\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.started\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_18\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"find VoxTell/models-weight/voxtell/voxtell_v1.1 -maxdepth 3 -type f -printf '%p %s bytes\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n' | sort\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":null,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"in_progress\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.started\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_19\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,220p' VoxTell/models-weight/voxtell/voxtell_v1.1/plans.json\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":null,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"in_progress\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_16\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,460p' VoxTell/voxtell/model/voxtell_model.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"import torch\\\\\\\\\\\\\\\\nfrom torch import nn\\\\\\\\\\\\\\\\nfrom torch.nn.modules.conv import _ConvNd\\\\\\\\\\\\\\\\nfrom torch.nn.modules.dropout import _DropoutNd\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nfrom typing import List, Type, Union, Tuple\\\\\\\\\\\\\\\\nfrom dynamic_network_architectures.building_blocks.helper import get_matching_convtransp\\\\\\\\\\\\\\\\nfrom dynamic_network_architectures.building_blocks.plain_conv_encoder import PlainConvEncoder\\\\\\\\\\\\\\\\nfrom dynamic_network_architectures.building_blocks.residual import BasicBlockD, BottleneckD\\\\\\\\\\\\\\\\nfrom dynamic_network_architectures.building_blocks.residual_encoders import ResidualEncoder\\\\\\\\\\\\\\\\nfrom dynamic_network_architectures.building_blocks.simple_conv_blocks import StackedConvBlocks\\\\\\\\\\\\\\\\nfrom dynamic_network_architectures.initialization.weight_init import InitWeights_He, init_last_bn_before_add_to_0\\\\\\\\\\\\\\\\nfrom einops import rearrange, repeat\\\\\\\\\\\\\\\\nfrom positional_encodings.torch_encodings import PositionalEncoding3D\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nfrom voxtell.model.transformer import TransformerDecoder, TransformerDecoderLayer\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass VoxTellModel(nn.Module):\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    VoxTell segmentation model with text-prompted decoder.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    This model combines a ResidualEncoder backbone with a transformer-based decoder\\\\\\\\\\\\\\\\n    that uses text embeddings to generate segmentation masks. It supports multi-stage\\\\\\\\\\\\\\\\n    decoding with optional deep supervision.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    Attributes:\\\\\\\\\\\\\\\\n        encoder: ResidualEncoder backbone for feature extraction.\\\\\\\\\\\\\\\\n        decoder: VoxTellDecoder for multi-scale feature decoding.\\\\\\\\\\\\\\\\n        transformer_decoder: Transformer for fusing text and image features.\\\\\\\\\\\\\\\\n        deep_supervision: Whether to return multi-scale predictions.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    # Class constants for transformer architecture (text prompt decoder)\\\\\\\\\\\\\\\\n    TRANSFORMER_NUM_HEADS = 8\\\\\\\\\\\\\\\\n    TRANSFORMER_NUM_LAYERS = 6\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    # Decoder configuration for different stages\\\\\\\\\\\\\\\\n    DECODER_CONFIGS = {\\\\\\\\\\\\\\\\n        0: {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"channels\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 32, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (192, 192, 192)},\\\\\\\\\\\\\\\\n        1: {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"channels\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 64, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (96, 96, 96)},\\\\\\\\\\\\\\\\n        2: {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"channels\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 128, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (48, 48, 48)},\\\\\\\\\\\\\\\\n        3: {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"channels\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 256, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (24, 24, 24)},\\\\\\\\\\\\\\\\n        4: {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"channels\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 320, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (12, 12, 12)},\\\\\\\\\\\\\\\\n        5: {\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"channels\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": 320, \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\": (6, 6, 6)},\\\\\\\\\\\\\\\\n    }\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    def __init__(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        input_channels: int,\\\\\\\\\\\\\\\\n        n_stages: int,\\\\\\\\\\\\\\\\n        features_per_stage: Union[int, List[int], Tuple[int, ...]],\\\\\\\\\\\\\\\\n        conv_op: Type[_ConvNd],\\\\\\\\\\\\\\\\n        kernel_sizes: Union[int, List[int], Tuple[int, ...]],\\\\\\\\\\\\\\\\n        strides: Union[int, List[int], Tuple[int, ...]],\\\\\\\\\\\\\\\\n        n_blocks_per_stage: Union[int, List[int], Tuple[int, ...]],\\\\\\\\\\\\\\\\n        n_conv_per_stage_decoder: Union[int, Tuple[int, ...], List[int]],\\\\\\\\\\\\\\\\n        conv_bias: bool = False,\\\\\\\\\\\\\\\\n        norm_op: Union[None, Type[nn.Module]] = None,\\\\\\\\\\\\\\\\n        norm_op_kwargs: dict = None,\\\\\\\\\\\\\\\\n        dropout_op: Union[None, Type[_DropoutNd]] = None,\\\\\\\\\\\\\\\\n        dropout_op_kwargs: dict = None,\\\\\\\\\\\\\\\\n        nonlin: Union[None, Type[torch.nn.Module]] = None,\\\\\\\\\\\\\\\\n        nonlin_kwargs: dict = None,\\\\\\\\\\\\\\\\n        deep_supervision: bool = False,\\\\\\\\\\\\\\\\n        block: Union[Type[BasicBlockD], Type[BottleneckD]] = BasicBlockD,\\\\\\\\\\\\\\\\n        bottleneck_channels: Union[int, List[int], Tuple[int, ...]] = None,\\\\\\\\\\\\\\\\n        stem_channels: int = None,\\\\\\\\\\\\\\\\n        # Text-prompted segmentation parameters\\\\\\\\\\\\\\\\n        num_maskformer_stages: int = 5,\\\\\\\\\\\\\\\\n        query_dim: int = 864,\\\\\\\\\\\\\\\\n        decoder_layer: int = 4,\\\\\\\\\\\\\\\\n        text_embedding_dim: int = 1024,\\\\\\\\\\\\\\\\n        num_heads: int = 1,\\\\\\\\\\\\\\\\n        project_to_decoder_hidden_dim: int = 432\\\\\\\\\\\\\\\\n    ) -> None:\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        Initialize the VoxTell model.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        Args:\\\\\\\\\\\\\\\\n            input_channels: Number of input channels.\\\\\\\\\\\\\\\\n            n_stages: Number of encoder stages.\\\\\\\\\\\\\\\\n            features_per_stage: Number of features at each stage.\\\\\\\\\\\\\\\\n            conv_op: Convolution operation type.\\\\\\\\\\\\\\\\n            kernel_sizes: Kernel sizes for convolutions.\\\\\\\\\\\\\\\\n            strides: Strides for downsampling.\\\\\\\\\\\\\\\\n            n_blocks_per_stage: Number of residual blocks per stage.\\\\\\\\\\\\\\\\n            n_conv_per_stage_decoder: Number of convolutions per stage.\\\\\\\\\\\\\\\\n            conv_bias: Whether to use bias in convolutions.\\\\\\\\\\\\\\\\n            norm_op: Normalization operation.\\\\\\\\\\\\\\\\n            norm_op_kwargs: Normalization operation keyword arguments.\\\\\\\\\\\\\\\\n            dropout_op: Dropout operation.\\\\\\\\\\\\\\\\n            dropout_op_kwargs: Dropout operation keyword arguments.\\\\\\\\\\\\\\\\n            nonlin: Non-linearity operation.\\\\\\\\\\\\\\\\n            nonlin_kwargs: Non-linearity keyword arguments.\\\\\\\\\\\\\\\\n            deep_supervision: Whether to use deep supervision.\\\\\\\\\\\\\\\\n            block: Residual block type (BasicBlockD or BottleneckD).\\\\\\\\\\\\\\\\n            bottleneck_channels: Channels in bottleneck layers.\\\\\\\\\\\\\\\\n            stem_channels: Channels in stem layer.\\\\\\\\\\\\\\\\n            num_maskformer_stages: Number of stages to fuse text-image embeddings in decoder.\\\\\\\\\\\\\\\\n            query_dim: Dimension of query embeddings.\\\\\\\\\\\\\\\\n            decoder_layer: Which decoder layer to use as memory for text prompt decoder (0-5).\\\\\\\\\\\\\\\\n            text_embedding_dim: Dimension of text embeddings.\\\\\\\\\\\\\\\\n            num_heads: Number of channels added per U-Net stage for mask embedding fusion.\\\\\\\\\\\\\\\\n            project_to_decoder_hidden_dim: Hidden dimension for projection to decoder.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\n        if isinstance(n_blocks_per_stage, int):\\\\\\\\\\\\\\\\n            n_blocks_per_stage = [n_blocks_per_stage] * n_stages\\\\\\\\\\\\\\\\n        if isinstance(n_conv_per_stage_decoder, int):\\\\\\\\\\\\\\\\n            n_conv_per_stage_decoder = [n_conv_per_stage_decoder] * (n_stages - 1)\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        assert len(n_blocks_per_stage) == n_stages, (\\\\\\\\\\\\\\\\n            f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"n_blocks_per_stage must have as many entries as we have resolution stages. \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n            f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Expected: {n_stages}, got: {len(n_blocks_per_stage)} ({n_blocks_per_stage})\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        assert len(n_conv_per_stage_decoder) == (n_stages - 1), (\\\\\\\\\\\\\\\\n            f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"n_conv_per_stage_decoder must have one less entry than resolution stages. \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n            f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Expected: {n_stages - 1}, got: {len(n_conv_per_stage_decoder)} ({n_conv_per_stage_decoder})\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        if num_maskformer_stages != 5:\\\\\\\\\\\\\\\\n            assert not deep_supervision, (\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Deep supervision is not supported for num_maskformer_stages != 5.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n        self.deep_supervision = deep_supervision\\\\\\\\\\\\\\\\n        self.num_heads = num_heads\\\\\\\\\\\\\\\\n        self.query_dim = query_dim\\\\\\\\\\\\\\\\n        self.project_to_decoder_hidden_dim = project_to_decoder_hidden_dim\\\\\\\\\\\\\\\\n        self.text_embedding_dim = text_embedding_dim\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        # Initialize encoder backbone\\\\\\\\\\\\\\\\n        self.encoder = ResidualEncoder(\\\\\\\\\\\\\\\\n            input_channels, n_stages, features_per_stage, conv_op, kernel_sizes, strides,\\\\\\\\\\\\\\\\n            n_blocks_per_stage, conv_bias, norm_op, norm_op_kwargs, dropout_op,\\\\\\\\\\\\\\\\n            dropout_op_kwargs, nonlin, nonlin_kwargs, block, bottleneck_channels,\\\\\\\\\\\\\\\\n            return_skips=True, disable_default_stem=False, stem_channels=stem_channels\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        # Initialize decoder\\\\\\\\\\\\\\\\n        self.decoder = VoxTellDecoder(\\\\\\\\\\\\\\\\n            self.encoder, 1, n_conv_per_stage_decoder, deep_supervision,\\\\\\\\\\\\\\\\n            num_maskformer_stages, num_heads=self.num_heads\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        # Select decoder layer configuration\\\\\\\\\\\\\\\\n        self.selected_decoder_layer = decoder_layer\\\\\\\\\\\\\\\\n        if decoder_layer not in self.DECODER_CONFIGS:\\\\\\\\\\\\\\\\n            raise ValueError(\\\\\\\\\\\\\\\\n                f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"decoder_layer must be in {list(self.DECODER_CONFIGS.keys())}, got {decoder_layer}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n        selected_config = self.DECODER_CONFIGS[decoder_layer]\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        h, w, d = selected_config[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Project bottleneck embeddings to query dimension\\\\\\\\\\\\\\\\n        self.project_bottleneck_embed = nn.Sequential(\\\\\\\\\\\\\\\\n            nn.Linear(selected_config[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"channels\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"], query_dim),\\\\\\\\\\\\\\\\n            nn.GELU(),\\\\\\\\\\\\\\\\n            nn.Linear(query_dim, query_dim),\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Project text embeddings to query dimension\\\\\\\\\\\\\\\\n        text_hidden_dim = 2048\\\\\\\\\\\\\\\\n        self.project_text_embed = nn.Sequential(\\\\\\\\\\\\\\\\n            nn.Linear(self.text_embedding_dim, text_hidden_dim),\\\\\\\\\\\\\\\\n            nn.GELU(),\\\\\\\\\\\\\\\\n            nn.Linear(text_hidden_dim, query_dim),\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Project decoder output to image channels for each mask-former stage\\\\\\\\\\\\\\\\n        self.project_to_decoder_channels = nn.ModuleList([\\\\\\\\\\\\\\\\n            nn.Sequential(\\\\\\\\\\\\\\\\n                nn.Linear(query_dim, self.project_to_decoder_hidden_dim),\\\\\\\\\\\\\\\\n                nn.GELU(),\\\\\\\\\\\\\\\\n                nn.Linear(\\\\\\\\\\\\\\\\n                    self.project_to_decoder_hidden_dim,\\\\\\\\\\\\\\\\n                    decoder_config[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"channels\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"] * self.num_heads if stage_idx != 0 else decoder_config[\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"channels\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"]\\\\\\\\\\\\\\\\n                )\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n            for stage_idx, decoder_config in enumerate(\\\\\\\\\\\\\\\\n                list(self.DECODER_CONFIGS.values())[:num_maskformer_stages]\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n        ])\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        # Initialize 3D positional encoding\\\\\\\\\\\\\\\\n        # Shape: (H*W*D, batch_size, query_dim)\\\\\\\\\\\\\\\\n        pos_embed = PositionalEncoding3D(query_dim)(torch.zeros(1, h, w, d, query_dim))\\\\\\\\\\\\\\\\n        pos_embed = rearrange(pos_embed, 'b h w d c -> (h w d) b c')\\\\\\\\\\\\\\\\n        self.register_buffer('pos_embed', pos_embed)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Initialize transformer decoder for fusing text and image features (prompt decoder)\\\\\\\\\\\\\\\\n        transformer_layer = TransformerDecoderLayer(\\\\\\\\\\\\\\\\n            d_model=query_dim,\\\\\\\\\\\\\\\\n            nhead=self.TRANSFORMER_NUM_HEADS,\\\\\\\\\\\\\\\\n            normalize_before=True\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        decoder_norm = nn.LayerNorm(query_dim)\\\\\\\\\\\\\\\\n        self.transformer_decoder = TransformerDecoder(\\\\\\\\\\\\\\\\n            decoder_layer=transformer_layer,\\\\\\\\\\\\\\\\n            num_layers=self.TRANSFORMER_NUM_LAYERS,\\\\\\\\\\\\\\\\n            norm=decoder_norm\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        img: torch.Tensor,\\\\\\\\\\\\\\\\n        text_embedding: torch.Tensor = None\\\\\\\\\\\\\\\\n    ) -> Union[torch.Tensor, List[torch.Tensor]]:\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        Forward pass through VoxTell model.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        Args:\\\\\\\\\\\\\\\\n            img: Input image tensor of shape (B, C, D, H, W).\\\\\\\\\\\\\\\\n            text_embedding: Pre-computed text embeddings of shape (B, N, D) where\\\\\\\\\\\\\\\\n                N is number of prompts and D is embedding dimension.\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\n        Returns:\\\\\\\\\\\\\\\\n            If deep_supervision is False, returns single prediction tensor of shape (B, N, D, H, W).\\\\\\\\\\\\\\\\n            If deep_supervision is True, returns list of prediction tensors at different scales.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        # Extract multi-scale features from encoder\\\\\\\\\\\\\\\\n        skips = self.encoder(img)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Select encoder features \\\\\\\\\\\\\\\\n        selected_feature = skips[self.selected_decoder_layer]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Reshape and project features to query dimension\\\\\\\\\\\\\\\\n        # Shape: (B, C, D, H, W) -> (B, H, W, D, C) -> (B, H, W, D, query_dim)\\\\\\\\\\\\\\\\n        bottleneck_embed = rearrange(selected_feature, 'b c d h w -> b h w d c')\\\\\\\\\\\\\\\\n        bottleneck_embed = self.project_bottleneck_embed(bottleneck_embed)\\\\\\\\\\\\\\\\n        # Shape: (B, H, W, D, query_dim) -> (H*W*D, B, query_dim) for transformer\\\\\\\\\\\\\\\\n        bottleneck_embed = rearrange(bottleneck_embed, 'b h w d c -> (h w d) b c')\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Remove singleton dimension from text embeddings and project\\\\\\\\\\\\\\\\n        # Shape: (B, N, 1, D) -> (B, N, D)\\\\\\\\\\\\\\\\n        text_embedding = text_embedding.squeeze(2)\\\\\\\\\\\\\\\\n        # Shape: (B, N, D) -> (N, B, D) as required by transformer decoder\\\\\\\\\\\\\\\\n        text_embed = repeat(text_embedding, 'b n dim -> n b dim')\\\\\\\\\\\\\\\\n        text_embed = self.project_text_embed(text_embed)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Fuse text and image features through transformer decoder\\\\\\\\\\\\\\\\n        # Output shape: (N, B, query_dim)\\\\\\\\\\\\\\\\n        mask_embedding, _ = self.transformer_decoder(\\\\\\\\\\\\\\\\n            tgt=text_embed,\\\\\\\\\\\\\\\\n            memory=bottleneck_embed,\\\\\\\\\\\\\\\\n            pos=self.pos_embed,\\\\\\\\\\\\\\\\n            memory_key_padding_mask=None\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        # Shape: (N, B, query_dim) -> (B, N, query_dim)\\\\\\\\\\\\\\\\n        mask_embedding = repeat(mask_embedding, 'n b dim -> b n dim')\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Project mask embeddings to decoder channel dimensions for each stage\\\\\\\\\\\\\\\\n        mask_embeddings = [\\\\\\\\\\\\\\\\n            projection(mask_embedding)\\\\\\\\\\\\\\\\n            for projection in self.project_to_decoder_channels\\\\\\\\\\\\\\\\n        ]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Generate segmentation outputs for each text prompt\\\\\\\\\\\\\\\\n        outs = []\\\\\\\\\\\\\\\\n        num_prompts = text_embedding.shape[1]\\\\\\\\\\\\\\\\n        for prompt_idx in range(num_prompts):\\\\\\\\\\\\\\\\n            # Extract embeddings for this prompt across all stages\\\\\\\\\\\\\\\\n            prompt_embeds = [m[:, prompt_idx:prompt_idx + 1] for m in mask_embeddings]\\\\\\\\\\\\\\\\n            outs.append(self.decoder(skips, prompt_embeds))\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        # Concatenate outputs across prompts for each scale\\\\\\\\\\\\\\\\n        outs = [torch.cat(scale_outs, dim=1) for scale_outs in zip(*outs)]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        if not self.deep_supervision:\\\\\\\\\\\\\\\\n            outs = outs[0]\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        return outs\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    @staticmethod\\\\\\\\\\\\\\\\n    def initialize(module):\\\\\\\\\\\\\\\\n        InitWeights_He(1e-2)(module)\\\\\\\\\\\\\\\\n        init_last_bn_before_add_to_0(module)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass VoxTellDecoder(nn.Module):\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    Decoder for VoxTell with mask-embedding fusion.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    This decoder upsamples features from the encoder and fuses them with\\\\\\\\\\\\\\\\n    mask embeddings from text prompts at multiple scales. It supports\\\\\\\\\\\\\\\\n    deep supervision for multi-scale training.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    The decoder processes features from bottleneck to highest resolution,\\\\\\\\\\\\\\\\n    incorporating mask embeddings through einsum operations at each stage.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    def __init__(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        encoder: Union[PlainConvEncoder, ResidualEncoder],\\\\\\\\\\\\\\\\n        num_classes: int,\\\\\\\\\\\\\\\\n        n_conv_per_stage: Union[int, Tuple[int, ...], List[int]],\\\\\\\\\\\\\\\\n        deep_supervision: bool,\\\\\\\\\\\\\\\\n        num_maskformer_stages: int = 5,\\\\\\\\\\\\\\\\n        nonlin_first: bool = False,\\\\\\\\\\\\\\\\n        norm_op: Union[None, Type[nn.Module]] = None,\\\\\\\\\\\\\\\\n        norm_op_kwargs: dict = None,\\\\\\\\\\\\\\\\n        dropout_op: Union[None, Type[_DropoutNd]] = None,\\\\\\\\\\\\\\\\n        dropout_op_kwargs: dict = None,\\\\\\\\\\\\\\\\n        nonlin: Union[None, Type[torch.nn.Module]] = None,\\\\\\\\\\\\\\\\n        nonlin_kwargs: dict = None,\\\\\\\\\\\\\\\\n        conv_bias: bool = None,\\\\\\\\\\\\\\\\n        num_heads: int = 1\\\\\\\\\\\\\\\\n    ) -> None:\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        Initialize VoxTell decoder.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        The decoder upsamples features from encoder stages and fuses them with\\\\\\\\\\\\\\\\n        mask embeddings. Each stage consists of:\\\\\\\\\\\\\\\\n        1) Transpose convolution to upsample lower resolution features\\\\\\\\\\\\\\\\n        2) Concatenation with skip connections from encoder\\\\\\\\\\\\\\\\n        3) Convolutional blocks to merge features\\\\\\\\\\\\\\\\n        4) Fusion with mask embeddings via einsum\\\\\\\\\\\\\\\\n        5) Optional segmentation output for deep supervision\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        Args:\\\\\\\\\\\\\\\\n            encoder: Encoder module (PlainConvEncoder or ResidualEncoder).\\\\\\\\\\\\\\\\n            num_classes: Number of output classes (typically 1 for binary segmentation).\\\\\\\\\\\\\\\\n            n_conv_per_stage: Number of convolution blocks per decoder stage.\\\\\\\\\\\\\\\\n            deep_supervision: Whether to output predictions at multiple scales.\\\\\\\\\\\\\\\\n            num_maskformer_stages: Number of stages to fuse mask embeddings.\\\\\\\\\\\\\\\\n            nonlin_first: Whether to apply non-linearity before convolution.\\\\\\\\\\\\\\\\n            norm_op: Normalization operation (inherited from encoder if None).\\\\\\\\\\\\\\\\n            norm_op_kwargs: Normalization keyword arguments.\\\\\\\\\\\\\\\\n            dropout_op: Dropout operation (inherited from encoder if None).\\\\\\\\\\\\\\\\n            dropout_op_kwargs: Dropout keyword arguments.\\\\\\\\\\\\\\\\n            nonlin: Non-linearity operation (inherited from encoder if None).\\\\\\\\\\\\\\\\n            nonlin_kwargs: Non-linearity keyword arguments.\\\\\\\\\\\\\\\\n            conv_bias: Whether to use bias in convolutions (inherited from encoder if None).\\\\\\\\\\\\\\\\n            num_heads: Number of attention heads for mask embedding fusion.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\n        self.deep_supervision = deep_supervision\\\\\\\\\\\\\\\\n        self.encoder = encoder\\\\\\\\\\\\\\\\n        self.num_classes = num_classes\\\\\\\\\\\\\\\\n        self.num_heads = num_heads\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        n_stages_encoder = len(encoder.output_channels)\\\\\\\\\\\\\\\\n        if isinstance(n_conv_per_stage, int):\\\\\\\\\\\\\\\\n            n_conv_per_stage = [n_conv_per_stage] * (n_stages_encoder - 1)\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        assert len(n_conv_per_stage) == n_stages_encoder - 1, (\\\\\\\\\\\\\\\\n            f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"n_conv_per_stage must have one less entry than encoder stages. \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n            f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Expected: {n_stages_encoder - 1}, got: {len(n_conv_per_stage)}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Inherit hyperparameters from encoder if not specified\\\\\\\\\\\\\\\\n        transpconv_op = get_matching_convtransp(conv_op=encoder.conv_op)\\\\\\\\\\\\\\\\n        conv_bias = encoder.conv_bias if conv_bias is None else conv_bias\\\\\\\\\\\\\\\\n        norm_op = encoder.norm_op if norm_op is None else norm_op\\\\\\\\\\\\\\\\n        norm_op_kwargs = encoder.norm_op_kwargs if norm_op_kwargs is None else norm_op_kwargs\\\\\\\\\\\\\\\\n        dropout_op = encoder.dropout_op if dropout_op is None else dropout_op\\\\\\\\\\\\\\\\n        dropout_op_kwargs = encoder.dropout_op_kwargs if dropout_op_kwargs is None else dropout_op_kwargs\\\\\\\\\\\\\\\\n        nonlin = encoder.nonlin if nonlin is None else nonlin\\\\\\\\\\\\\\\\n        nonlin_kwargs = encoder.nonlin_kwargs if nonlin_kwargs is None else nonlin_kwargs\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Build decoder stages from bottleneck to highest resolution\\\\\\\\\\\\\\\\n        stages = []\\\\\\\\\\\\\\\\n        transpconvs = []\\\\\\\\\\\\\\\\n        seg_layers = []\\\\\\\\\\\\\\\\n        for stage_idx in range(1, n_stages_encoder):\\\\\\\\\\\\\\\\n            # Determine input channels: add num_heads for stages with mask embedding fusion\\\\\\\\\\\\\\\\n            if stage_idx <= n_stages_encoder - num_maskformer_stages:\\\\\\\\\\\\\\\\n                input_features_below = encoder.output_channels[-stage_idx]\\\\\\\\\\\\\\\\n            else:\\\\\\\\\\\\\\\\n                input_features_below = encoder.output_channels[-stage_idx] + num_heads\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\n            input_features_skip = encoder.output_channels[-(stage_idx + 1)]\\\\\\\\\\\\\\\\n            stride_for_transpconv = encoder.strides[-stage_idx]\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\n            # Transpose convolution for upsampling\\\\\\\\\\\\\\\\n            transpconvs.append(transpconv_op(\\\\\\\\\\\\\\\\n                input_features_below, input_features_skip,\\\\\\\\\\\\\\\\n                stride_for_transpconv, stride_for_transpconv,\\\\\\\\\\\\\\\\n                bias=conv_bias\\\\\\\\\\\\\\\\n            ))\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\n            # Convolutional blocks for feature merging\\\\\\\\\\\\\\\\n            # Input features: 2x input_features_skip (concatenated skip + upsampled features)\\\\\\\\\\\\\\\\n            stages.append(StackedConvBlocks(\\\\\\\\\\\\\\\\n                n_conv_per_stage[stage_idx - 1], encoder.conv_op,\\\\\\\\\\\\\\\\n                2 * input_features_skip, input_features_skip,\\\\\\\\\\\\\\\\n                encoder.kernel_sizes[-(stage_idx + 1)], 1,\\\\\\\\\\\\\\\\n                conv_bias, norm_op, norm_op_kwargs,\\\\\\\\\\\\\\\\n                dropout_op, dropout_op_kwargs,\\\\\\\\\\\\\\\\n                nonlin, nonlin_kwargs, nonlin_first\\\\\\\\\\\\\\\\n            ))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n            # Segmentation output layer (always built for parameter loading compatibility)\\\\\\\\\\\\\\\\n            # This allows models trained with deep_supervision=True to be loaded\\\\\\\\\\\\\\\\n            # for inference with deep_supervision=False\\\\\\\\\\\\\\\\n            seg_layers.append(encoder.conv_op(\\\\\\\\\\\\\\\\n                input_features_skip + num_heads, num_classes,\\\\\\\\\\\\\\\\n                1, 1, 0, bias=True\\\\\\\\\\\\\\\\n            ))\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        self.stages = nn.ModuleList(stages)\\\\\\\\\\\\\\\\n        self.transpconvs = nn.ModuleList(transpconvs)\\\\\\\\\\\\\\\\n        self.seg_layers = nn.ModuleList(seg_layers)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        skips: List[torch.Tensor],\\\\\\\\\\\\\\\\n        mask_embeddings: List[torch.Tensor]\\\\\\\\\\\\\\\\n    ) -> List[torch.Tensor]:\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        Forward pass through decoder with mask embedding fusion.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        Processes features from bottleneck to highest resolution, fusing\\\\\\\\\\\\\\\\n        mask embeddings at multiple stages via einsum operations.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        Args:\\\\\\\\\\\\\\\\n            skips: List of encoder skip connections in computation order.\\\\\\\\\\\\\\\\n                Last entry should be bottleneck features.\\\\\\\\\\\\\\\\n            mask_embeddings: List of mask embeddings for each decoder stage,\\\\\\\\\\\\\\\\n                in order from lowest to highest resolution.\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\n        Returns:\\\\\\\\\\\\\\\\n            List of segmentation predictions. If deep_supervision=False,\\\\\\\\\\\\\\\\n            returns single-element list with highest resolution prediction.\\\\\\\\\\\\\\\\n            If deep_supervision=True, returns predictions at all scales\\\\\\\\\\\\\\\\n            from highest to lowest resolution.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        lres_input = skips[-1]\\\\\\\\\\\\\\\\n        seg_outputs = []\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        # Reverse mask embeddings to match decoder stage order (bottleneck first)\\\\\\\\\\\\\\\\n        mask_embeddings = mask_embeddings[::-1]\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        for stage_idx in range(len(self.stages)):\\\\\\\\\\\\\\\\n            # Upsample and concatenate with skip connection\\\\\\\\\\\\\\\\n            x = self.transpconvs[stage_idx](lres_input)\\\\\\\\\\\\\\\\n            x = torch.cat((x, skips[-(stage_idx + 2)]), dim=1)\\\\\\\\\\\\\\\\n            x = self.stages[stage_idx](x)\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\n            # Apply mask embedding fusion for relevant stages\\\\\\\\\\\\\\\\n            if stage_idx == (len(self.stages) - 1):\\\\\\\\\\\\\\\\n                # Final stage: generate segmentation via einsum\\\\\\\\\\\\\\\\n                # x: (B, C, H, W, D), mask_embeddings[-1]: (B, N, C)\\\\\\\\\\\\\\\\n                # Output: (B, N, H, W, D)\\\\\\\\\\\\\\\\n                seg_pred = torch.einsum('b c h w d, b n c -> b n h w d', x, mask_embeddings[-1])\\\\\\\\\\\\\\\\n                seg_outputs.append(seg_pred)\\\\\\\\\\\\\\\\n            elif stage_idx >= len(self.stages) - len(mask_embeddings):\\\\\\\\\\\\\\\\n                # Intermediate stages with mask embedding fusion\\\\\\\\\\\\\\\\n                mask_embedding = mask_embeddings.pop(0)\\\\\\\\\\\\\\\\n                batch_size, _, channels = mask_embedding.shape\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\n                # Reshape for multi-head fusion and compute attention-weighted features\\\\\\\\\\\\\\\\n                # Shape: (B, num_heads, C // num_heads)\\\\\\\\\\\\\\\\n                mask_embedding_reshaped = mask_embedding.view(batch_size, self.num_heads, -1)\\\\\\\\\\\\\\\\n                fusion_features = torch.einsum(\\\\\\\\\\\\\\\\n                    'b c h w d, b n c -> b n h w d',\\\\\\\\\\\\\\\\n                    x, mask_embedding_reshaped\\\\\\\\\\\\\\\\n                )\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\n                # Concatenate fused features with spatial features\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\":0,\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"completed\\\\\\\\\\\\\\\"}}\\\\\\\\n{\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"item_17\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,340p' VoxTell/voxtell/model/transformer.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\nText prompt decoder implementation for VoxTell.\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nCode modified from DETR transformer:\\\\\\\\\\\\\\\\nhttps://github.com/facebookresearch/detr\\\\\\\\\\\\\\\\nCopyright (c) Facebook, Inc. and its affiliates. All Rights Reserved\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport copy\\\\\\\\\\\\\\\\nfrom typing import Callable, List, Optional, Tuple, Union\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nimport torch\\\\\\\\\\\\\\\\nimport torch.nn.functional as F\\\\\\\\\\\\\\\\nfrom torch import nn, Tensor\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass TransformerDecoder(nn.Module):\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    Transformer decoder consisting of multiple decoder layers.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    This decoder processes target sequences with attention to memory (encoder output),\\\\\\\\\\\\\\\\n    optionally returning intermediate layer outputs. It receives the text prompt embeddings\\\\\\\\\\\\\\\\n    as queries and attends to image features from the encoder. It outputs refined text-image\\\\\\\\\\\\\\\\n    fused features for segmentation mask prediction.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    Args:\\\\\\\\\\\\\\\\n        decoder_layer: A single transformer decoder layer to be cloned.\\\\\\\\\\\\\\\\n        num_layers: Number of decoder layers to stack.\\\\\\\\\\\\\\\\n        norm: Optional normalization layer applied to the final output.\\\\\\\\\\\\\\\\n        return_intermediate: If True, returns outputs from all layers stacked together.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def __init__(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        decoder_layer: nn.Module,\\\\\\\\\\\\\\\\n        num_layers: int,\\\\\\\\\\\\\\\\n        norm: Optional[nn.Module] = None,\\\\\\\\\\\\\\\\n        return_intermediate: bool = False\\\\\\\\\\\\\\\\n    ) -> None:\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\n        self.layers = _get_clones(decoder_layer, num_layers)\\\\\\\\\\\\\\\\n        self.num_layers = num_layers\\\\\\\\\\\\\\\\n        self.norm = norm\\\\\\\\\\\\\\\\n        self.return_intermediate = return_intermediate\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        tgt: Tensor,\\\\\\\\\\\\\\\\n        memory: Tensor,\\\\\\\\\\\\\\\\n        tgt_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        tgt_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        query_pos: Optional[Tensor] = None\\\\\\\\\\\\\\\\n    ) -> Union[Tensor, Tuple[Tensor, List[Tensor]]]:\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        Forward pass through all decoder layers.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        Args:\\\\\\\\\\\\\\\\n            tgt: Target sequence tensor of shape [T, B, C].\\\\\\\\\\\\\\\\n            memory: Memory (encoder output) tensor of shape [T, B, C].\\\\\\\\\\\\\\\\n            tgt_mask: Attention mask for target self-attention.\\\\\\\\\\\\\\\\n            memory_mask: Attention mask for cross-attention to memory.\\\\\\\\\\\\\\\\n            tgt_key_padding_mask: Padding mask for target keys.\\\\\\\\\\\\\\\\n            memory_key_padding_mask: Padding mask for memory keys.\\\\\\\\\\\\\\\\n            pos: Positional embeddings for memory.\\\\\\\\\\\\\\\\n            query_pos: Positional embeddings for queries.\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\n        Returns:\\\\\\\\\\\\\\\\n            If return_intermediate is True, returns stacked intermediate outputs.\\\\\\\\\\\\\\\\n            Otherwise, returns tuple of (final_output, attention_weights_list).\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        output = tgt\\\\\\\\\\\\\\\\n        T, B, C = memory.shape\\\\\\\\\\\\\\\\n        intermediate = []\\\\\\\\\\\\\\\\n        atten_layers = []\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        for n, layer in enumerate(self.layers):\\\\\\\\\\\\\\\\n            residual = True\\\\\\\\\\\\\\\\n            output, ws = layer(\\\\\\\\\\\\\\\\n                output, memory,\\\\\\\\\\\\\\\\n                tgt_mask=tgt_mask,\\\\\\\\\\\\\\\\n                memory_mask=memory_mask,\\\\\\\\\\\\\\\\n                tgt_key_padding_mask=tgt_key_padding_mask,\\\\\\\\\\\\\\\\n                memory_key_padding_mask=memory_key_padding_mask,\\\\\\\\\\\\\\\\n                pos=pos,\\\\\\\\\\\\\\\\n                query_pos=query_pos,\\\\\\\\\\\\\\\\n                residual=residual\\\\\\\\\\\\\\\\n            )\\\\\\\\\\\\\\\\n            atten_layers.append(ws)\\\\\\\\\\\\\\\\n            if self.return_intermediate:\\\\\\\\\\\\\\\\n                intermediate.append(self.norm(output))\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\n        if self.norm is not None:\\\\\\\\\\\\\\\\n            output = self.norm(output)\\\\\\\\\\\\\\\\n            if self.return_intermediate:\\\\\\\\\\\\\\\\n                intermediate.pop()\\\\\\\\\\\\\\\\n                intermediate.append(output)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        if self.return_intermediate:\\\\\\\\\\\\\\\\n            return torch.stack(intermediate)\\\\\\\\\\\\\\\\n        return output, atten_layers\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\nclass TransformerDecoderLayer(nn.Module):\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n    Single transformer decoder layer with self-attention, cross-attention, and FFN.\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    This layer implements:\\\\\\\\\\\\\\\\n    1. Self-attention on the target sequence\\\\\\\\\\\\\\\\n    2. Cross-attention between target and memory (image encoder output)\\\\\\\\\\\\\\\\n    3. Position-wise feed-forward network\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\n    Args:\\\\\\\\\\\\\\\\n        d_model: Dimension of the model (embedding dimension).\\\\\\\\\\\\\\\\n        nhead: Number of attention heads.\\\\\\\\\\\\\\\\n        dim_feedforward: Dimension of the feedforward network.\\\\\\\\\\\\\\\\n        dropout: Dropout probability.\\\\\\\\\\\\\\\\n        activation: Activation function name ('relu', 'gelu', or 'glu').\\\\\\\\\\\\\\\\n        normalize_before: If True, applies layer norm before attention/FFN (pre-norm).\\\\\\\\\\\\\\\\n                         If False, applies after (post-norm).\\\\\\\\\\\\\\\\n    \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def __init__(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        d_model: int,\\\\\\\\\\\\\\\\n        nhead: int,\\\\\\\\\\\\\\\\n        dim_feedforward: int = 2048,\\\\\\\\\\\\\\\\n        dropout: float = 0.1,\\\\\\\\\\\\\\\\n        activation: str = \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"relu\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        normalize_before: bool = False\\\\\\\\\\\\\\\\n    ) -> None:\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\n        self.self_attn = nn.MultiheadAttention(d_model, nhead, dropout=dropout)\\\\\\\\\\\\\\\\n        self.multihead_attn = nn.MultiheadAttention(d_model, nhead, dropout=dropout)\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        # Feed-forward network\\\\\\\\\\\\\\\\n        self.linear1 = nn.Linear(d_model, dim_feedforward)\\\\\\\\\\\\\\\\n        self.dropout = nn.Dropout(dropout)\\\\\\\\\\\\\\\\n        self.linear2 = nn.Linear(dim_feedforward, d_model)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Normalization layers\\\\\\\\\\\\\\\\n        self.norm1 = nn.LayerNorm(d_model)\\\\\\\\\\\\\\\\n        self.norm2 = nn.LayerNorm(d_model)\\\\\\\\\\\\\\\\n        self.norm3 = nn.LayerNorm(d_model)\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        # Dropout layers\\\\\\\\\\\\\\\\n        self.dropout1 = nn.Dropout(dropout)\\\\\\\\\\\\\\\\n        self.dropout2 = nn.Dropout(dropout)\\\\\\\\\\\\\\\\n        self.dropout3 = nn.Dropout(dropout)\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        self.activation = _get_activation_fn(activation)\\\\\\\\\\\\\\\\n        self.normalize_before = normalize_before\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n    def with_pos_embed(self, tensor: Tensor, pos: Optional[Tensor]) -> Tensor:\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        Add positional embeddings to tensor if provided.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        Args:\\\\\\\\\\\\\\\\n            tensor: Input tensor.\\\\\\\\\\\\\\\\n            pos: Optional positional embeddings to add.\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\n        Returns:\\\\\\\\\\\\\\\\n            Tensor with positional embeddings added, or original tensor if pos is None.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        return tensor if pos is None else tensor + pos\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward_post(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        tgt: Tensor,\\\\\\\\\\\\\\\\n        memory: Tensor,\\\\\\\\\\\\\\\\n        tgt_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        tgt_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        query_pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        residual: bool = True\\\\\\\\\\\\\\\\n    ) -> Tuple[Tensor, Tensor]:\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        Post-norm forward pass: attention/FFN first, then normalization.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        Args:\\\\\\\\\\\\\\\\n            tgt: Target sequence.\\\\\\\\\\\\\\\\n            memory: Memory (encoder output).\\\\\\\\\\\\\\\\n            tgt_mask: Self-attention mask for target.\\\\\\\\\\\\\\\\n            memory_mask: Cross-attention mask.\\\\\\\\\\\\\\\\n            tgt_key_padding_mask: Padding mask for target keys.\\\\\\\\\\\\\\\\n            memory_key_padding_mask: Padding mask for memory keys.\\\\\\\\\\\\\\\\n            pos: Positional embeddings for memory.\\\\\\\\\\\\\\\\n            query_pos: Positional embeddings for queries.\\\\\\\\\\\\\\\\n            residual: Whether to use residual connections.\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\n        Returns:\\\\\\\\\\\\\\\\n            Tuple of (output_tensor, attention_weights).\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        q = k = self.with_pos_embed(tgt, query_pos)\\\\\\\\\\\\\\\\n        tgt2, ws = self.self_attn(\\\\\\\\\\\\\\\\n            q, k, value=tgt,\\\\\\\\\\\\\\\\n            attn_mask=tgt_mask,\\\\\\\\\\\\\\\\n            key_padding_mask=tgt_key_padding_mask\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n        tgt = self.norm1(tgt)\\\\\\\\\\\\\\\\n        tgt2, ws = self.multihead_attn(\\\\\\\\\\\\\\\\n            query=self.with_pos_embed(tgt, query_pos),\\\\\\\\\\\\\\\\n            key=self.with_pos_embed(memory, pos),\\\\\\\\\\\\\\\\n            value=memory,\\\\\\\\\\\\\\\\n            attn_mask=memory_mask,\\\\\\\\\\\\\\\\n            key_padding_mask=memory_key_padding_mask\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n        # Cross-attention with residual connection\\\\\\\\\\\\\\\\n        tgt = tgt + self.dropout2(tgt2)\\\\\\\\\\\\\\\\n        tgt = self.norm2(tgt)\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        # Feed-forward network\\\\\\\\\\\\\\\\n        tgt2 = self.linear2(self.dropout(self.activation(self.linear1(tgt))))\\\\\\\\\\\\\\\\n        tgt = tgt + self.dropout3(tgt2)\\\\\\\\\\\\\\\\n        tgt = self.norm3(tgt)\\\\\\\\\\\\\\\\n        return tgt, ws\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\n    def forward_pre(\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\n        tgt: Tensor,\\\\\\\\\\\\\\\\n        memory: Tensor,\\\\\\\\\\\\\\\\n        tgt_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        tgt_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        memory_key_padding_mask: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        pos: Optional[Tensor] = None,\\\\\\\\\\\\\\\\n        query_pos: Optional[Tensor] = None\\\\\\\\\\\\\\\\n    ) -> Tuple[Tensor, Tensor]:\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        Pre-norm forward pass: normalization first, then attention/FFN.\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\n        Args:\\\\\\\\\\\\\\\\n            tgt: Target sequence.\\\\\\\\\\\\\\\\n            memory: Memory (encoder output).\\\\\\\\\\\\\\\\n            tgt_mask: Self-attention mask for target.\\\\\\\\\\\\\\\\n            memory_mask: Cross-attention mask.\\\\\\\\\\\\\\\\n            tgt_key_padding_mask: Padding mask for target keys.\\\\\\\\\\\\\\\\n            memory_key_padding_mask: Padding mask for memory keys.\\\\\\\\\\\\\\\\n            pos: Positional embeddings for memory.\\\\\\\\\\\\\\\\n            query_pos: Positional embeddings for queries.\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\n        Returns:\\\\\\\\\\\\\\\\n            Tuple of (output_tensor, attention_weights).\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\n        tgt2 = self.norm2(tgt)\\\\\\\\\\\\\\\\n        tgt2, attn_weights = self.multihead_attn(\\\\\\\\\\\\\\\\n            query=self.with_pos_embed(tgt2, query_pos),\\\\\\\\\\\\\\\\n            key=self.with_pos_embed(memory, pos),\\\\\\\\\\\\\\\\n            value=memory,\\\\\\\\\\\\\\\\n            at