"command\\\":\\\"/bin/bash -lc \\\\\\\"sed -n '1,260p' Body-Tell/scripts/audit_voxtell_alignment.py\\\\\\\"\\\",\\\"aggregated_output\\\":\\\"#!/usr/bin/env python3\\\\n\\\\\\\"\\\\\\\"\\\\\\\"SP-A.P0 compatibility audit for Body-Tell and VoxTell v1.1.\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\nfrom __future__ import annotations\\\\n\\\\nimport argparse\\\\nimport ast\\\\nimport html\\\\nimport json\\\\nimport re\\\\nimport sys\\\\nfrom dataclasses import asdict\\\\nfrom pathlib import Path\\\\nfrom typing import Any\\\\n\\\\n\\\\nREPO_ROOT = Path(__file__).resolve().parents[2]\\\\nBODY_TELL_ROOT = Path(__file__).resolve().parents[1]\\\\nVOXTELL_ROOT = REPO_ROOT / \\\\\\\"VoxTell\\\\\\\"\\\\nDEFAULT_BODY_CONFIG = BODY_TELL_ROOT / \\\\\\\"configs\\\\\\\" / \\\\\\\"phase1_voxtell_body.yaml\\\\\\\"\\\\nDEFAULT_VOXTELL_DIR = VOXTELL_ROOT / \\\\\\\"models-weight\\\\\\\" / \\\\\\\"voxtell\\\\\\\" / \\\\\\\"voxtell_v1.1\\\\\\\"\\\\nPROJECT_TO_DECODER_RE = re.compile(r\\\\\\\"^project_to_decoder_channels\\\\\\\\.(\\\\\\\\d+)\\\\\\\\.2\\\\\\\\.weight$\\\\\\\")\\\\n\\\\n\\\\ndef _literal(node: ast.AST) -> Any:\\\\n    try:\\\\n        return ast.literal_eval(node)\\\\n    except Exception:\\\\n        return None\\\\n\\\\n\\\\ndef _shape(value: Any) -> tuple[int, ...]:\\\\n    return tuple(int(x) for x in value.shape)\\\\n\\\\n\\\\ndef _prefix(name: str) -> str:\\\\n    return name.split(\\\\\\\".\\\\\\\", 1)[0]\\\\n\\\\n\\\\ndef _numel(shape: tuple[int, ...]) -> int:\\\\n    total = 1\\\\n    for item in shape:\\\\n        total *= int(item)\\\\n    return total\\\\n\\\\n\\\\ndef load_body_config(config_path: Path) -> Any:\\\\n    import yaml\\\\n\\\\n    if str(BODY_TELL_ROOT) not in sys.path:\\\\n        sys.path.insert(0, str(BODY_TELL_ROOT))\\\\n    from body_tell.models.voxtell_body_model import VoxTellBodyConfig\\\\n\\\\n    raw = yaml.safe_load(config_path.read_text(encoding=\\\\\\\"utf-8\\\\\\\")) or {}\\\\n    model_raw = dict(raw.get(\\\\\\\"model\\\\\\\", {}))\\\\n    model_raw.pop(\\\\\\\"name\\\\\\\", None)\\\\n    cfg = asdict(VoxTellBodyConfig())\\\\n    cfg.update(model_raw)\\\\n    cfg[\\\\\\\"encoder_channels\\\\\\\"] = tuple(int(x) for x in cfg[\\\\\\\"encoder_channels\\\\\\\"])\\\\n    return VoxTellBodyConfig(**cfg)\\\\n\\\\n\\\\ndef body_projection_rows(config: Any) -> list[dict[str, Any]]:\\\\n    fused_stage_count = min(\\\\n        int(config.num_maskformer_stages),\\\\n        len(config.encoder_channels) - 1,\\\\n    )\\\\n    rows = []\\\\n    for stage_index, channels in enumerate(config.encoder_channels[:fused_stage_count]):\\\\n        output_dim = int(channels) if stage_index == 0 else int(channels) * int(config.num_heads)\\\\n        rows.append(\\\\n            {\\\\n                \\\\\\\"stage\\\\\\\": stage_index,\\\\n                \\\\\\\"channels\\\\\\\": int(channels),\\\\n                \\\\\\\"output_dim\\\\\\\": output_dim,\\\\n                \\\\\\\"weight_shape\\\\\\\": (output_dim, int(config.text_projection_hidden_dim)),\\\\n                \\\\\\\"bias_shape\\\\\\\": (output_dim,),\\\\n                \\\\\\\"key\\\\\\\": f\\\\\\\"mask_projections.{stage_index}.2\\\\\\\",\\\\n                \\\\\\\"target_key\\\\\\\": f\\\\\\\"project_to_decoder_channels.{stage_index}.2\\\\\\\",\\\\n            }\\\\n        )\\\\n    return rows\\\\n\\\\n\\\\ndef load_body_state_shapes(config: Any) -> dict[str, tuple[int, ...]]:\\\\n    import torch\\\\n\\\\n    if str(BODY_TELL_ROOT) not in sys.path:\\\\n        sys.path.insert(0, str(BODY_TELL_ROOT))\\\\n    from body_tell.models.voxtell_body_model import VoxTellBodyModel\\\\n\\\\n    with torch.device(\\\\\\\"meta\\\\\\\"):\\\\n        model = VoxTellBodyModel(config)\\\\n    return {name: _shape(tensor) for name, tensor in model.state_dict().items()}\\\\n\\\\n\\\\ndef parse_voxtell_model_source(source_path: Path) -> dict[str, Any]:\\\\n    tree = ast.parse(source_path.read_text(encoding=\\\\\\\"utf-8\\\\\\\"))\\\\n    model_class = next(\\\\n        node for node in tree.body if isinstance(node, ast.ClassDef) and node.name == \\\\\\\"VoxTellModel\\\\\\\"\\\\n    )\\\\n    decoder_configs: dict[int, dict[str, Any]] = {}\\\\n    defaults: dict[str, Any] = {}\\\\n\\\\n    for node in model_class.body:\\\\n        if isinstance(node, ast.Assign):\\\\n            for target in node.targets:\\\\n                if isinstance(target, ast.Name) and target.id == \\\\\\\"DECODER_CONFIGS\\\\\\\":\\\\n                    decoder_configs = _literal(node.value) or {}\\\\n        if isinstance(node, ast.FunctionDef) and node.name == \\\\\\\"__init__\\\\\\\":\\\\n            positional_args = [arg.arg for arg in node.args.args]\\\\n            default_values = list(node.args.defaults)\\\\n            default_names = positional_args[-len(default_values) :] if default_values else []\\\\n            defaults = {\\\\n                name: _literal(default)\\\\n                for name, default in zip(default_names, default_values)\\\\n            }\\\\n            break\\\\n\\\\n    return {\\\\n        \\\\\\\"decoder_configs\\\\\\\": decoder_configs,\\\\n        \\\\\\\"defaults\\\\\\\": defaults,\\\\n    }\\\\n\\\\n\\\\ndef parse_voxtell_predictor_overrides(predictor_path: Path) -> dict[str, Any]:\\\\n    tree = ast.parse(predictor_path.read_text(encoding=\\\\\\\"utf-8\\\\\\\"))\\\\n    overrides: dict[str, Any] = {}\\\\n    for node in ast.walk(tree):\\\\n        if not isinstance(node, ast.Call):\\\\n            continue\\\\n        func = node.func\\\\n        is_model_call = (\\\\n            isinstance(func, ast.Name)\\\\n            and func.id == \\\\\\\"VoxTellModel\\\\\\\"\\\\n            or isinstance(func, ast.Attribute)\\\\n            and func.attr == \\\\\\\"VoxTellModel\\\\\\\"\\\\n        )\\\\n        if not is_model_call:\\\\n            continue\\\\n        for keyword in node.keywords:\\\\n            if keyword.arg is not None:\\\\n                value = _literal(keyword.value)\\\\n                if value is not None:\\\\n                    overrides[keyword.arg] = value\\\\n        break\\\\n    return overrides\\\\n\\\\n\\\\ndef voxtell_projection_rows(\\\\n    decoder_configs: dict[int, dict[str, Any]],\\\\n    num_maskformer_stages: int,\\\\n    num_heads: int,\\\\n    hidden_dim: int,\\\\n) -> list[dict[str, Any]]:\\\\n    rows = []\\\\n    for stage_index, config in list(sorted(decoder_configs.items()))[:num_maskformer_stages]:\\\\n        channels = int(config[\\\\\\\"channels\\\\\\\"])\\\\n        output_dim = channels if int(stage_index) == 0 else channels * int(num_heads)\\\\n        rows.append(\\\\n            {\\\\n                \\\\\\\"stage\\\\\\\": int(stage_index),\\\\n                \\\\\\\"channels\\\\\\\": channels,\\\\n                \\\\\\\"output_dim\\\\\\\": output_dim,\\\\n                \\\\\\\"weight_shape\\\\\\\": (output_dim, int(hidden_dim)),\\\\n                \\\\\\\"bias_shape\\\\\\\": (output_dim,),\\\\n                \\\\\\\"key\\\\\\\": f\\\\\\\"project_to_decoder_channels.{stage_index}.2\\\\\\\",\\\\n            }\\\\n        )\\\\n    return rows\\\\n\\\\n\\\\ndef load_checkpoint_shapes(voxtell_dir: Path) -> dict[str, Any]:\\\\n    import torch\\\\n\\\\n    checkpoint_path = voxtell_dir / \\\\\\\"fold_0\\\\\\\" / \\\\\\\"checkpoint_final.pth\\\\\\\"\\\\n    if not checkpoint_path.exists():\\\\n        return {\\\\n            \\\\\\\"available\\\\\\\": False,\\\\n            \\\\\\\"checkpoint_path\\\\\\\": str(checkpoint_path),\\\\n            \\\\\\\"error\\\\\\\": \\\\\\\"checkpoint file does not exist\\\\\\\",\\\\n        }\\\\n\\\\n    try:\\\\n        checkpoint = torch.load(\\\\n            str(checkpoint_path),\\\\n            map_location=\\\\\\\"cpu\\\\\\\",\\\\n            weights_only=False,\\\\n            mmap=True,\\\\n        )\\\\n    except TypeError:\\\\n        checkpoint = torch.load(\\\\n            str(checkpoint_path),\\\\n            map_location=\\\\\\\"cpu\\\\\\\",\\\\n            weights_only=False,\\\\n        )\\\\n\\\\n    state_dict = checkpoint.get(\\\\\\\"network_weights\\\\\\\", checkpoint)\\\\n    shapes = {name: _shape(tensor) for name, tensor in state_dict.items()}\\\\n    rows = []\\\\n    for name, shape in sorted(shapes.items()):\\\\n        match = PROJECT_TO_DECODER_RE.match(name)\\\\n        if not match:\\\\n            continue\\\\n        stage = int(match.group(1))\\\\n        rows.append(\\\\n            {\\\\n                \\\\\\\"stage\\\\\\\": stage,\\\\n                \\\\\\\"output_dim\\\\\\\": int(shape[0]),\\\\n                \\\\\\\"weight_shape\\\\\\\": shape,\\\\n                \\\\\\\"bias_shape\\\\\\\": shapes.get(f\\\\\\\"project_to_decoder_channels.{stage}.2.bias\\\\\\\"),\\\\n                \\\\\\\"key\\\\\\\": f\\\\\\\"project_to_decoder_channels.{stage}.2\\\\\\\",\\\\n            }\\\\n        )\\\\n\\\\n    return {\\\\n        \\\\\\\"available\\\\\\\": True,\\\\n        \\\\\\\"checkpoint_path\\\\\\\": str(checkpoint_path),\\\\n        \\\\\\\"key_count\\\\\\\": len(shapes),\\\\n        \\\\\\\"state_shapes\\\\\\\": shapes,\\\\n        \\\\\\\"projection_rows\\\\\\\": sorted(rows, key=lambda row: row[\\\\\\\"stage\\\\\\\"]),\\\\n        \\\\\\\"pos_embed_shape\\\\\\\": shapes.get(\\\\\\\"pos_embed\\\\\\\"),\\\\n    }\\\\n\\\\n\\\\ndef infer_num_heads_from_projection_rows(\\\\n    rows: list[dict[str, Any]],\\\\n    decoder_configs: dict[int, dict[str, Any]],\\\\n) -> int | None:\\\\n    ratios = []\\\\n    for row in rows:\\\\n        stage = int(row[\\\\\\\"stage\\\\\\\"])\\\\n        if stage == 0:\\\\n            continue\\\\n        channels = int(decoder_configs[stage][\\\\\\\"channels\\\\\\\"])\\\\n        output_dim = int(row[\\\\\\\"output_dim\\\\\\\"])\\\\n        if output_dim % channels != 0:\\\\n            return None\\\\n        ratios.append(output_dim // channels)\\\\n    if not ratios:\\\\n        return None\\\\n    first = ratios[0]\\\\n    return first if all(item == first for item in ratios) else None\\\\n\\\\n\\\\ndef compare_state_shapes(\\\\n    checkpoint_shapes: dict[str, tuple[int, ...]] | None,\\\\n    body_shapes: dict[str, tuple[int, ...]] | None,\\\\n) -> dict[str, Any]:\\\\n    if checkpoint_shapes is None or body_shapes is None:\\\\n        return {\\\\\\\"available\\\\\\\": False}\\\\n\\\\n    matching = []\\\\n    mismatched = []\\\\n    for name, body_shape in sorted(body_shapes.items()):\\\\n        checkpoint_shape = checkpoint_shapes.get(name)\\\\n        if checkpoint_shape is None:\\\\n            continue\\\\n        if checkpoint_shape == body_shape:\\\\n            matching.append(name)\\\\n\\\",\\\"exit_code\\\":0,\\\"status\\\":\\\"completed\\\"}}\\nBody-Tell/reports/26-05-24/runs/SP-A.P0/review-events.jsonl:30:{\\\"type\\\":\\\"item.completed\\\",\\\"item\\\":{\\\"id\\\":\\\"item_12\\\",\\\"type\\\":\\\"command_execution\\\",\\\"command\\\":\\\"/bin/bash -lc \\\\\\\"grep -nE \\\\\\\\\\\\\\\"SP-A\\\\\\\\\\\\\\\\.P0|SP-A P0|P0|golden|whitelist|num_heads|projection\\\\\\\\\\\\\\\" Body-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html Body-Tell/reports/26-05-24/lead.html\\\\\\\"\\\",\\\"aggregated_output\\\":\\\"Body-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:224:            <td>Mask projections（含 <code>num_heads</code>）</td>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:225:            <td><span class=\\\\\\\"tag bad\\\\\\\">真实存在</span> 两层根因：(1) Body-Tell 配置写 5，但运行时被 <code>min(num_maskformer_stages, len(encoder_channels)-1)</code> 截成 4 级；(2) Body-Tell <code>num_heads=32</code>（<code>voxtell_body_model.py:29</code>）vs VoxTell <code>num_heads=1</code>（<code>voxtell_model.py:74</code>）。两者乘积决定实际 projection 输出。</td>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:226:            <td>Body-Tell 实际输出 <code>[32, 2048, 4096, 8192]</code>（<code>channels × 32</code>，stage 0 例外）；VoxTell 实际输出 <strong><code>[32, 64, 128, 256, 320]</code> 量级</strong>（<code>channels × 1</code>）。<strong>原报告写 VoxTell 最高级 <code>10240</code> 是错误的。</strong> 即使 encoder 升到 6 级、stage 截断消除，<code>num_heads</code> 不同会导致 <code>project_to_decoder_channels.*</code> 与下游 mask fusion 模块的 shape 不匹配，权重无法直接复用。</td>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:280:            <td><code>project_to_decoder_channels</code> + <code>num_heads</code></td>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:281:            <td>使用 VoxTell 命名，替代当前 <code>mask_projections</code>；5 级；输出维度 = encoder 各级 channels × <code>num_heads</code>。<strong>条件性对齐</strong>（父表 #13，域差异豁免）：如果实验目标是<strong>直接复用 VoxTell <code>project_to_decoder_channels.*</code> 和 mask fusion 权重</strong>，则必须设 <code>num_heads=1</code>，实际输出 <code>[32, 64, 128, 256, 320]</code> 量级；如果仅做结构对齐而不复用这部分权重（更符合 Body-Tell occupancy grid 任务的需求，因为 <code>num_heads=32</code> 提供 32× mask fusion 容量是为该任务调过的），则保留 <code>num_heads=32</code>。</td>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:282:            <td>选 <code>num_heads=1</code>：直接加载 VoxTell <code>project_to_decoder_channels.*</code>。选保留 <code>num_heads=32</code>：必须把 <code>project_to_decoder_channels.*</code> 与 mask fusion 相关 key 全部加入跳过白名单，并在 audit 中登记\\\\\\\"为保留 Body-Tell mask fusion 容量而跳过这部分权重复用\\\\\\\"。</td>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:296:      <h3>P0：建立兼容性基线</h3>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:298:        <li><strong>（2026-05-24 新增）<code>num_heads</code> 与 projection shape 显式审计</strong>：新增 <code>Body-Tell/scripts/audit_voxtell_alignment.py</code>（如果与已有 <code>scripts/parameter_audit.py</code> 重合，应共享 utilities）。<strong>脚本第一步必须打印两侧 <code>num_heads</code> 值和每级 <code>project_to_decoder_channels</code> 实际输出 shape</strong>，确认 VoxTell 为 <code>num_heads=1</code> + 输出 <code>[32, 64, 128, 256, 320]</code> 量级，Body-Tell 当前为 <code>num_heads=32</code> + 输出 <code>[32, 2048, 4096, 8192]</code>。该审计是父表 #13 <code>num_heads</code> 决议（路径 A vs 路径 B）的输入材料，audit 完成后才能在 P4 选定路径。</li>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:300:        <li>新增 transformer golden test <code>Body-Tell/tests/test_voxtell_transformer_compat.py</code>：同一小尺寸 state dict、相同输入、dropout=0 时，Body-Tell aligned transformer 输出必须与 VoxTell transformer 完全一致或在 <code>1e-6</code> 内。</li>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:303:      <p>验收：当前轻量模型仍可跑旧测试；新增审计能明确报告哪些 key 会加载、哪些 key 因 policy 跳过；<strong>且 <code>num_heads</code> 决议（设为 1 / 保留 32）必须先于 P4 落地</strong>。</p>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:331:      <h3>P4：对齐 projection、mask head、<code>num_heads</code> 决议和 forward 排列</h3>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:332:      <div class=\\\\\\\"callout warnbox\\\\\\\"><strong>P4 <code>num_heads</code> 决议（父表 #13，域差异豁免）</strong>：在执行 P4 前必须先选定路径——\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:334:          <li><strong>路径 A（强对齐，复用权重）</strong>：<code>num_heads=1</code>，projection 输出 <code>[32, 64, 128, 256, 320]</code>，可直接加载 VoxTell <code>project_to_decoder_channels.*</code> 与 mask fusion 权重。代价：失去 Body-Tell 现有 32× mask fusion 容量。</li>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:335:          <li><strong>路径 B（结构对齐但放弃这部分权重复用，推荐）</strong>：保留 <code>num_heads=32</code>，projection 输出维持 <code>[32, 2048, 4096, 8192, 10240]</code>（encoder 升 6 级后扩展），<code>project_to_decoder_channels.*</code> 与 mask fusion 权重 <strong>不加载</strong>，加入 P6 跳过白名单。理由：Body-Tell 处理 occupancy grid 与 VoxTell 医学影像任务差异显著，这部分权重的可迁移性弱，而 mask fusion 容量对当前任务更有价值。</li>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:337:        默认建议路径 B，并在 P0 audit 中显式打印决议来源。如果 audit 没有给出明确收益对比，<strong>保持现状（路径 B）即可，不强制对齐 <code>num_heads</code></strong>。\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:340:        <li><strong>（2026-05-24 修订）<code>num_heads</code> 决议生效</strong>：按上方选定路径执行。路径 A 需把配置 <code>num_heads</code> 默认值改为 <code>1</code>，同时审计 Body-Tell 中所有依赖 <code>num_heads</code> 的 reshape（如 <code>view(B, num_heads, C//num_heads)</code>）和 decoder stage 内 <code>input_features + num_heads</code> 的通道拼接是否正确退化；路径 B 不改 <code>num_heads</code>，但需要在 P6 把 <code>project_to_decoder_channels.*</code> 与 mask fusion 相关 key 加入跳过白名单。</li>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:341:        <li>把当前 <code>project_visual_embed</code> 改为 VoxTell 命名 <code>project_bottleneck_embed</code>；把 <code>mask_projections</code> 改为 <code>project_to_decoder_channels</code>。</li>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:342:        <li>encoder 变为 6-stage 后，projection stage 自然恢复为 5 级，不再用 <code>len(encoder_channels)-1</code> 隐式截断配置。</li>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:346:      <p>验收：5 个 projection 输出维度按选定路径（路径 A: <code>[32, 64, 128, 256, 320]</code>；路径 B: <code>[32, 2048, 4096, 8192, 10240]</code>）；非立方输入的输出 shape 与 target mask 完全一致；mask fusion 模块在选定 <code>num_heads</code> 下有显式单测；audit 报告记录选定路径与原因。</p>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:374:        <li><strong>（2026-05-24 修订）显式 <code>unexpected_keys</code> 白名单</strong>：调用 <code>model.load_state_dict(state_dict, strict=False)</code> 后，断言 <code>set(unexpected_keys) ⊆ POLICY_ALLOWED_SKIP</code>（默认 <code>{\\\\\\\"pos_embed\\\\\\\"}</code>；若 P4 决定保留 <code>num_heads=32</code>，再扩展到 <code>{\\\\\\\"pos_embed\\\\\\\", \\\\\\\"project_to_decoder_channels.*\\\\\\\", \\\\\\\"decoder.<mask_fusion_keys>\\\\\\\"}</code>）。<strong>任何 shape mismatch 必须抛错，不得静默跳过</strong>；<code>missing_keys</code> 不为空时打印完整列表并要求显式确认。</li>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:400:            <td>只加载 transformer / text / projection 权重</td>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:406:            <td>加载 encoder、decoder、projection、transformer；按 policy 跳过或加载 <code>pos_embed</code></td>\\\\nBody-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html:480:        <li><strong>（2026-05-24 上调）P0 <code>num_heads</code> 与 projection shape 审计</strong>。这是父表 #13 <code>num_heads</code> 决议的输入材料；不在 P4 落地前完成审计，P3/P4/P6 都会建立在未经确认的输出维度假设上。允许 audit 结论是\\\\\\\"保留 <code>num_heads=32</code>\\\\\\\"（路径 B），但必须显式记录。</li>\\\\nBody-Tell/reports/26-05-24/lead.html:181:    <p class=\\\\\\\"note warn\\\\\\\">2026-05-24 修订：原 11 项基础上新增 #12 BCE+Dice loss 等价性、#13 <code>num_heads</code> mismatch（Body-Tell=32 vs VoxTell=1）。其中 #13 同时修正了原 SP-A 中\\\\\\\"VoxTell projection 输出 <code>[32,2048,4096,8192,10240]</code>\\\\\\\"的错误表述（实际为 <code>[32,64,128,256,320]</code> 量级，<code>num_heads</code> 才是根因）。</p>\\\\nBody-Tell/reports/26-05-24/lead.html:182:    <div class=\\\\\\\"note warn\\\\\\\"><strong>域差异豁免（2026-05-24 重要约束）</strong>：Body-Tell 处理 occupancy grid，VoxTell 处理医学影像（CT/MRI/PET）。任务输入模态、特征统计、噪声特性都不同。<strong>本计划中\\\\\\\"对齐\\\\\\\"是手段不是目的，目的是支持 VoxTell 权重复用与实现一致性。任何一项不一致，若实现阶段 audit 后发现对齐会损害性能、或对当前任务没有可观察收益、或与权重复用无关，允许显式跳过并在子计划中记录原因。</strong> #12（loss 公式）与 #13（<code>num_heads</code>）尤其适用此豁免。</div>\\\\nBody-Tell/reports/26-05-24/lead.html:206:          <td>模型结构对齐：transformer decoder 语义、ResidualEncoder、VoxTellDecoder、5-scale projection、位置编码策略、VoxTell 权重加载入口、训练实验矩阵。</td>\\\\nBody-Tell/reports/26-05-24/lead.html:227:    <p>按下面顺序开工。SP-C 不需要整体等到 SP-A/SP-B 完成；只有 deep supervision、长训通过和最终评估需要等结构与 patch-level sampler 到位。<strong>（2026-05-24 修订）阶段 1 新增 SP-A P0 audit 作为首项；阶段 2 P4 内部包含 <code>num_heads</code> 路径决议（路径 A vs 路径 B），决议依赖 P0 audit 输出；阶段 3 Task 5 与 P6 的具体实现内容随 P4 决议变化。</strong></p>\\\\nBody-Tell/reports/26-05-24/lead.html:242:              <li><strong><a class=\\\\\\\"child-link\\\\\\\" href=\\\\\\\"bodytell_voxtell_alignment_plan_2026-05-24.html\\\\\\\">SP-A P0</a>（新增首项）</strong>：建立兼容性基线 audit—— <code>num_heads</code> + projection shape 双侧打印、transformer golden test、weight key audit。产出三份输入材料：(a) 父表 #13 <code>num_heads</code> 路径决议输入，(b) P1 transformer parity 验收测试，(c) P6 权重加载白名单。</li>\\\\nBody-Tell/reports/26-05-24/lead.html:243:              <li><a class=\\\\\\\"child-link\\\\\\\" href=\\\\\\\"bodytell_voxtell_alignment_plan_2026-05-24.html\\\\\\\">SP-A P1</a>：Transformer decoder 语义对齐（验收使用 P0 的 transformer golden test）。</li>\\\\nBody-Tell/reports/26-05-24/lead.html:248:          <td>可以并行。P0 audit 不修改 Body-Tell 代码，只输出审计材料；P1 transformer 改动可与 P0 同步进行。</td>\\\\nBody-Tell/reports/26-05-24/lead.html:249:          <td>形成可复现训练 loop 骨架；<strong>完成 P0 后必须显式记录 <code>num_heads</code> 路径决议（默认路径 B：保留 32）</strong>；但还不能宣称 paper-aligned 长训通过。</td>\\\\nBody-Tell/reports/26-05-24/lead.html:255:              <li>SP-A P2-P5：Residual encoder、VoxTellDecoder、projection/forward 排列、位置编码策略（<code>dynamic_hwd</code> 默认，适配 <code>[129,108,256]</code>）。<strong>P4 内部按 P0 选定的 <code>num_heads</code> 路径执行</strong>——路径 A 改 <code>num_heads=1</code>；路径 B 保留 <code>num_heads=32</code>，把 <code>project_to_decoder_channels.*</code> 与 mask fusion 相关 key 加入 P6 跳过白名单候选。</li>\\\\nBody-Tell/reports/26-05-24/lead.html:279:              <li>SP-A P7：random / prompt-only / full 三组 warm-start 对照实验。若 P4 选路径 B，<code>full</code> 实际等价于\\\\\\\"除 mask fusion 与 projection 外全部加载\\\\\\\"，需在实验日志显式区分。</li>\\\\nBody-Tell/reports/26-05-24/lead.html:288:    <p class=\\\\\\\"note warn\\\\\\\">关键路径串行依赖（2026-05-24 修订后）：<strong>SP-A P0 audit → P4 <code>num_heads</code> 路径决议 → P6 跳过白名单</strong>；<strong>SP-A P3 → SP-C Task 5</strong>；<strong>SP-B Step 1 → Step 2 → Step 3/4 → Step 5 → Step 6</strong>。其余环节可并行。</p>\\\\nBody-Tell/reports/26-05-24/lead.html:293:    <p>下表是本文件的核心。每一项不一致都必须被某一个子计划领走；当前 13 项已全部分发，其中结构类由 SP-A 负责（含 #13 <code>num_heads</code>，标记为条件性对齐），数据构造类由 SP-B 负责，训练机制与评估协议类由 SP-C 负责（含 #12 loss 等价性，标记为 audit 后可跳过）。</p>\\\\nBody-Tell/reports/26-05-24/lead.html:350:          <td><a class=\\\\\\\"child-link\\\\\\\" href=\\\\\\\"bodytell_voxtell_alignment_plan_2026-05-24.html\\\\\\\">SP-A P3/P4 — VoxTellDecoder + projection</a></td>\\\\nBody-Tell/reports/26-05-24/lead.html:378:          <td><span class=\\\\\\\"tag warn\\\\\\\"><code>num_heads</code> mismatch<br><span class=\\\\\\\"small\\\\\\\">（条件性对齐）</span></span></td>\\\\nBody-Tell/reports/26-05-24/lead.html:379:          <td>VoxTell <code>num_heads=1</code>（<code>voxtell/model/voxtell_model.py:74</code>）；Body-Tell <code>num_heads=32</code>（<code>body_tell/models/voxtell_body_model.py:29</code>）。projection 输出 = <code>channels × num_heads</code>，因此原 SP-A \\\\\\\"VoxTell 输出 <code>10240</code>\\\\\\\"的说法错误，实际为 <code>320</code> 量级。<strong>域差异豁免</strong>：<code>num_heads=32</code> 给 Body-Tell mask fusion 提供 32× 容量，是为 occupancy grid 任务设计的；强行降到 1 可能损害 capacity。<strong>对齐前提</strong>：只有在\\\\\\\"目标是直接复用 VoxTell <code>project_to_decoder_channels.*</code> 与 mask fusion 权重\\\\\\\"的实验中才必要；若仅做结构对齐（不复用这部分权重），可以保留 <code>num_heads=32</code>，但<strong>必须在 SP-A P0 audit 中显式打印 num_heads 并把这些 key 加入跳过白名单</strong>，避免错误判断为权重已加载。</td>\\\\nBody-Tell/reports/26-05-24/lead.html:380:          <td><a class=\\\\\\\"child-link\\\\\\\" href=\\\\\\\"bodytell_voxtell_alignment_plan_2026-05-24.html\\\\\\\">SP-A P0 + P4 — num_heads 审计与对齐决议</a></td>\\\\nBody-Tell/reports/26-05-24/lead.html:403:    <p class=\\\\\\\"note\\\\\\\">关键串行依赖（2026-05-24 修订后）：<strong>SP-A P0 audit → P4 <code>num_heads</code> 路径决议 → P6 跳过白名单组装</strong>；<strong>SP-A P0 transformer golden test → P1 验收</strong>；<strong>SP-B Step 1 → Step 2 → Step 3 / Step 4</strong>；<strong>SP-B Step 4 → Step 5 → Step 6</strong>；<strong>SP-A P3 → SP-C Task 5 deep supervision</strong>；<strong>SP-A P2/P3/P4 → SP-A P6</strong>。SP-A 结构对齐与 SP-B 数据构造可并行，但二者必须早于 deep supervision、权重加载和正式长训。</p>\\\\nBody-Tell/reports/26-05-24/lead.html:417:        <li><strong>结构闸门</strong>（SP-A P0 完成后）：<code>audit_voxtell_alignment.py</code> 报告 transformer parity test 通过（输出差异 &lt; <code>1e-6</code>，dropout=0）；<code>num_heads</code> 与每级 projection 实际 shape 已显式打印。</li>\\\\nBody-Tell/reports/26-05-24/lead.html:427:    <p><strong>可以按本文件开始执行。</strong> 13 项明确不一致已全部分发：SP-A 覆盖结构类（含 #13 <code>num_heads</code>），SP-B 覆盖数据构造类，SP-C 覆盖训练机制、checkpoint、评估协议和测试矩阵（含 #12 loss 等价性 audit）。<strong>#12 和 #13 适用域差异豁免</strong>：audit 后允许在保留 Body-Tell 当前实现并显式记录偏差的前提下跳过对齐。</p>\\\\nBody-Tell/reports/26-05-24/lead.html:428:    <p>短期优先顺序是：SP-A P0（含 <code>num_heads</code> + projection 实际 shape 审计）、SP-B Step 1、SP-C Task 0-4 并行启动；随后推进 SP-A P1-P5 和 SP-B Step 2-Step 4；最后启用 SP-C Task 5（含 BCE+Dice 等价性 audit，可仅记录偏差）、权重加载、评估与训练实验。</p>\\\\nBody-Tell/reports/26-05-24/lead.html:429:    <p class=\\\\\\\"small\\\\\\\">本报告仅维护审计与索引，未修改训练代码。2026-05-24 修订：增列 #12 loss 等价性、#13 <code>num_heads</code>（带域差异豁免），新增 baseline 评估闸门。</p>\\\\n\\\",\\\"exit_code\\\":0,\\\"status\\\":\\\"completed\\\"}}\\nBody-Tell/reports/26-05-24/runs/SP-A.P0/review-events.jsonl:31:{\\\"type\\\":\\\"item.completed\\\",\\\"item\\\":{\\\"id\\\":\\\"item_13\\\",\\\"type\\\":\\\"command_execution\\\",\\\"command\\\":\\\"/bin/bash -lc \\\\\\\"sed -n '261,620p' Body-Tell/scripts/audit_voxtell_alignment.py\\\\\\\"\\\",\\\"aggregated_output\\\":\\\"        else:\\\\n            mismatched.append(\\\\n                {\\\\n                    \\\\\\\"name\\\\\\\": name,\\\\n                    \\\\\\\"body_shape\\\\\\\": body_shape,\\\\n                    \\\\\\\"checkpoint_shape\\\\\\\": checkpoint_shape,\\\\n                }\\\\n            )\\\\n\\\\n    missing_in_checkpoint = sorted(set(body_shapes) - set(checkpoint_shapes))\\\\n    unexpected_in_checkpoint = sorted(set(checkpoint_shapes) - set(body_shapes))\\\\n    prefix_rows = []\\\\n    for prefix in sorted({_prefix(name) for name in set(body_shapes) | set(checkpoint_shapes)}):\\\\n        body_keys = {name for name in body_shapes if _prefix(name) == prefix}\\\\n        checkpoint_keys = {name for name in checkpoint_shapes if _prefix(name) == prefix}\\\\n        matching_keys = {name for name in matching if _prefix(name) == prefix}\\\\n        prefix_rows.append(\\\\n            {\\\\n                \\\\\\\"prefix\\\\\\\": prefix,\\\\n                \\\\\\\"body_keys\\\\\\\": len(body_keys),\\\\n                \\\\\\\"checkpoint_keys\\\\\\\": len(checkpoint_keys),\\\\n                \\\\\\\"shape_compatible_same_name\\\\\\\": len(matching_keys),\\\\n            }\\\\n        )\\\\n\\\\n    matched_param_count = sum(_numel(body_shapes[name]) for name in matching)\\\\n    body_param_count = sum(_numel(shape) for shape in body_shapes.values())\\\\n\\\\n    return {\\\\n        \\\\\\\"available\\\\\\\": True,\\\\n        \\\\\\\"matching_count\\\\\\\": len(matching),\\\\n        \\\\\\\"mismatch_count\\\\\\\": len(mismatched),\\\\n        \\\\\\\"missing_in_checkpoint_count\\\\\\\": len(missing_in_checkpoint),\\\\n        \\\\\\\"unexpected_in_checkpoint_count\\\\\\\": len(unexpected_in_checkpoint),\\\\n        \\\\\\\"matching\\\\\\\": matching,\\\\n        \\\\\\\"mismatched\\\\\\\": mismatched,\\\\n        \\\\\\\"missing_in_checkpoint\\\\\\\": missing_in_checkpoint,\\\\n        \\\\\\\"unexpected_in_checkpoint\\\\\\\": unexpected_in_checkpoint,\\\\n        \\\\\\\"prefix_rows\\\\\\\": prefix_rows,\\\\n        \\\\\\\"matched_param_count\\\\\\\": matched_param_count,\\\\n        \\\\\\\"body_param_count\\\\\\\": body_param_count,\\\\n    }\\\\n\\\\n\\\\ndef build_whitelist_input(\\\\n    *,\\\\n    pos_embed_policy: str,\\\\n    body_num_heads: int,\\\\n    source_default_num_heads: int,\\\\n    checkpoint_num_heads: int | None,\\\\n) -> dict[str, Any]:\\\\n    effective_checkpoint_heads = checkpoint_num_heads\\\\n    exact_skips = []\\\\n    conditional_skips = []\\\\n    no_skip_notes = []\\\\n\\\\n    if pos_embed_policy == \\\\\\\"dynamic_hwd\\\\\\\":\\\\n        exact_skips.append(\\\\n            {\\\\n                \\\\\\\"pattern\\\\\\\": \\\\\\\"pos_embed\\\\\\\",\\\\n                \\\\\\\"reason\\\\\\\": \\\\\\\"Body-Tell current non-192^3 crop uses dynamic positional encoding.\\\\\\\",\\\\n            }\\\\n        )\\\\n\\\\n    if effective_checkpoint_heads is not None and effective_checkpoint_heads != body_num_heads:\\\\n        conditional_skips.extend(\\\\n            [\\\\n                {\\\\n                    \\\\\\\"pattern\\\\\\\": \\\\\\\"project_to_decoder_channels.[1-4].*\\\\\\\",\\\\n                    \\\\\\\"reason\\\\\\\": \\\\\\\"projection output channels scale with num_heads for stages 1-4\\\\\\\",\\\\n                },\\\\n                {\\\\n                    \\\\\\\"pattern\\\\\\\": \\\\\\\"decoder.transpconvs.[1-4].*\\\\\\\",\\\\n                    \\\\\\\"reason\\\\\\\": \\\\\\\"intermediate decoder inputs include num_heads fused mask channels\\\\\\\",\\\\n                },\\\\n                {\\\\n                    \\\\\\\"pattern\\\\\\\": \\\\\\\"decoder.seg_layers.*\\\\\\\",\\\\n                    \\\\\\\"reason\\\\\\\": \\\\\\\"segmentation heads take input_features_skip + num_heads channels\\\\\\\",\\\\n                },\\\\n            ]\\\\n        )\\\\n    elif effective_checkpoint_heads is not None:\\\\n        no_skip_notes.append(\\\\n            \\\\\\\"checkpoint-derived num_heads matches Body-Tell current num_heads; \\\\\\\"\\\\n            \\\\\\\"do not skip project_to_decoder_channels.* or decoder mask-fusion keys for this reason\\\\\\\"\\\\n        )\\\\n\\\\n    if source_default_num_heads != body_num_heads:\\\\n        conditional_skips.append(\\\\n            {\\\\n                \\\\\\\"pattern\\\\\\\": \\\\\\\"project_to_decoder_channels.[1-4].*, decoder.transpconvs.[1-4].*, decoder.seg_layers.*\\\\\\\",\\\\n                \\\\\\\"reason\\\\\\\": (\\\\n                    \\\\\\\"only apply if loading a checkpoint generated from the VoxTellModel source \\\\\\\"\\\\n                    \\\\\\\"default num_heads=1 into a Body-Tell num_heads=32 model\\\\\\\"\\\\n                ),\\\\n            }\\\\n        )\\\\n\\\\n    return {\\\\n        \\\\\\\"pos_embed_policy\\\\\\\": pos_embed_policy,\\\\n        \\\\\\\"body_num_heads\\\\\\\": body_num_heads,\\\\n        \\\\\\\"voxtell_source_default_num_heads\\\\\\\": source_default_num_heads,\\\\n        \\\\\\\"voxtell_checkpoint_num_heads\\\\\\\": checkpoint_num_heads,\\\\n        \\\\\\\"required_exact_skip_patterns\\\\\\\": exact_skips,\\\\n        \\\\\\\"conditional_skip_patterns\\\\\\\": conditional_skips,\\\\n        \\\\\\\"no_skip_notes\\\\\\\": no_skip_notes,\\\\n    }\\\\n\\\\n\\\\ndef make_audit(args: argparse.Namespace) -> dict[str, Any]:\\\\n    body_config = load_body_config(args.config)\\\\n    body_rows = body_projection_rows(body_config)\\\\n    source_info = parse_voxtell_model_source(VOXTELL_ROOT / \\\\\\\"voxtell\\\\\\\" / \\\\\\\"model\\\\\\\" / \\\\\\\"voxtell_model.py\\\\\\\")\\\\n    predictor_overrides = parse_voxtell_predictor_overrides(\\\\n        VOXTELL_ROOT / \\\\\\\"voxtell\\\\\\\" / \\\\\\\"inference\\\\\\\" / \\\\\\\"predictor.py\\\\\\\"\\\\n    )\\\\n\\\\n    defaults = source_info[\\\\\\\"defaults\\\\\\\"]\\\\n    decoder_configs = source_info[\\\\\\\"decoder_configs\\\\\\\"]\\\\n    source_default_num_heads = int(defaults[\\\\\\\"num_heads\\\\\\\"])\\\\n    source_default_hidden_dim = int(defaults[\\\\\\\"project_to_decoder_hidden_dim\\\\\\\"])\\\\n    source_default_num_stages = int(defaults[\\\\\\\"num_maskformer_stages\\\\\\\"])\\\\n    source_rows = voxtell_projection_rows(\\\\n        decoder_configs,\\\\n        source_default_num_stages,\\\\n        source_default_num_heads,\\\\n        source_default_hidden_dim,\\\\n    )\\\\n\\\\n    predictor_num_heads = int(predictor_overrides.get(\\\\\\\"num_heads\\\\\\\", source_default_num_heads))\\\\n    predictor_hidden_dim = int(\\\\n        predictor_overrides.get(\\\\\\\"project_to_decoder_hidden_dim\\\\\\\", source_default_hidden_dim)\\\\n    )\\\\n    predictor_num_stages = int(\\\\n        predictor_overrides.get(\\\\\\\"num_maskformer_stages\\\\\\\", source_default_num_stages)\\\\n    )\\\\n    predictor_rows = voxtell_projection_rows(\\\\n        decoder_configs,\\\\n        predictor_num_stages,\\\\n        predictor_num_heads,\\\\n        predictor_hidden_dim,\\\\n    )\\\\n\\\\n    checkpoint = None if args.skip_checkpoint else load_checkpoint_shapes(args.voxtell_dir)\\\\n    checkpoint_num_heads = None\\\\n    if checkpoint and checkpoint[\\\\\\\"available\\\\\\\"]:\\\\n        checkpoint_num_heads = infer_num_heads_from_projection_rows(\\\\n            checkpoint[\\\\\\\"projection_rows\\\\\\\"],\\\\n            decoder_configs,\\\\n        )\\\\n        for row in checkpoint[\\\\\\\"projection_rows\\\\\\\"]:\\\\n            stage = row[\\\\\\\"stage\\\\\\\"]\\\\n            row[\\\\\\\"channels\\\\\\\"] = int(decoder_configs[stage][\\\\\\\"channels\\\\\\\"])\\\\n\\\\n    body_shapes = None if args.skip_state_dict_compare else load_body_state_shapes(body_config)\\\\n    checkpoint_shapes = (\\\\n        checkpoint.get(\\\\\\\"state_shapes\\\\\\\")\\\\n        if checkpoint is not None and checkpoint.get(\\\\\\\"available\\\\\\\")\\\\n        else None\\\\n    )\\\\n    state_compare = compare_state_shapes(checkpoint_shapes, body_shapes)\\\\n\\\\n    whitelist_input = build_whitelist_input(\\\\n        pos_embed_policy=args.pos_embed_policy,\\\\n        body_num_heads=int(body_config.num_heads),\\\\n        source_default_num_heads=source_default_num_heads,\\\\n        checkpoint_num_heads=checkpoint_num_heads,\\\\n    )\\\\n\\\\n    return {\\\\n        \\\\\\\"body\\\\\\\": {\\\\n            \\\\\\\"config_path\\\\\\\": str(args.config),\\\\n            \\\\\\\"num_heads\\\\\\\": int(body_config.num_heads),\\\\n            \\\\\\\"num_maskformer_stages_config\\\\\\\": int(body_config.num_maskformer_stages),\\\\n            \\\\\\\"fused_stage_count_actual\\\\\\\": len(body_rows),\\\\n            \\\\\\\"encoder_channels\\\\\\\": list(body_config.encoder_channels),\\\\n            \\\\\\\"projection_prefix\\\\\\\": \\\\\\\"mask_projections\\\\\\\",\\\\n            \\\\\\\"target_projection_prefix\\\\\\\": \\\\\\\"project_to_decoder_channels\\\\\\\",\\\\n            \\\\\\\"projection_rows\\\\\\\": body_rows,\\\\n        },\\\\n        \\\\\\\"voxtell\\\\\\\": {\\\\n            \\\\\\\"source_default\\\\\\\": {\\\\n                \\\\\\\"num_heads\\\\\\\": source_default_num_heads,\\\\n                \\\\\\\"hidden_dim\\\\\\\": source_default_hidden_dim,\\\\n                \\\\\\\"projection_rows\\\\\\\": source_rows,\\\\n            },\\\\n            \\\\\\\"predictor_v1_1\\\\\\\": {\\\\n                \\\\\\\"num_heads\\\\\\\": predictor_num_heads,\\\\n                \\\\\\\"hidden_dim\\\\\\\": predictor_hidden_dim,\\\\n                \\\\\\\"projection_rows\\\\\\\": predictor_rows,\\\\n                \\\\\\\"overrides\\\\\\\": predictor_overrides,\\\\n            },\\\\n            \\\\\\\"checkpoint\\\\\\\": checkpoint,\\\\n            \\\\\\\"checkpoint_num_heads\\\\\\\": checkpoint_num_heads,\\\\n        },\\\\n        \\\\\\\"state_compare_current_body_vs_checkpoint\\\\\\\": state_compare,\\\\n        \\\\\\\"whitelist_input\\\\\\\": whitelist_input,\\\\n    }\\\\n\\\\n\\\\ndef fmt_shape(shape: Any) -> str:\\\\n    if shape is None:\\\\n        return \\\\\\\"n/a\\\\\\\"\\\\n    return \\\\\\\"(\\\\\\\" + \\\\\\\", \\\\\\\".join(str(int(x)) for x in shape) + \\\\\\\")\\\\\\\"\\\\n\\\\n\\\\ndef projection_line(row: dict[str, Any]) -> str:\\\\n    return (\\\\n        f\\\\\\\"  stage {row['stage']}: channels={row.get('channels', 'n/a')} \\\\\\\"\\\\n        f\\\\\\\"output_dim={row['output_dim']} weight={fmt_shape(row['weight_shape'])} \\\\\\\"\\\\n        f\\\\\\\"key={row['key']}\\\\\\\"\\\\n    )\\\\n\\\\n\\\\ndef print_text_report(audit: dict[str, Any]) -> None:\\\\n    body = audit[\\\\\\\"body\\\\\\\"]\\\\n    voxtell = audit[\\\\\\\"voxtell\\\\\\\"]\\\\n    print(\\\\\\\"SP-A.P0 VoxTell compatibility baseline\\\\\\\")\\\\n    print()\\\\n    print(\\\\\\\"Body-Tell current\\\\\\\")\\\\n    print(f\\\\\\\"  config: {body['config_path']}\\\\\\\")\\\\n    print(f\\\\\\\"  num_heads: {body['num_heads']}\\\\\\\")\\\\n    print(\\\\n        \\\\\\\"  fused projection stages: \\\\\\\"\\\\n        f\\\\\\\"{body['fused_stage_count_actual']} \\\\\\\"\\\\n        f\\\\\\\"(configured {body['num_maskformer_stages_config']})\\\\\\\"\\\\n    )\\\\n    for row in body[\\\\\\\"projection_rows\\\\\\\"]:\\\\n        print(projection_line(row))\\\\n    print()\\\\n    print(\\\\\\\"VoxTell v1.1 source default\\\\\\\")\\\\n    print(f\\\\\\\"  num_heads: {voxtell['source_default']['num_heads']}\\\\\\\")\\\\n    for row in voxtell[\\\\\\\"source_default\\\\\\\"][\\\\\\\"projection_rows\\\\\\\"]:\\\\n        print(projection_line(row))\\\\n    print()\\\\n    print(\\\\\\\"VoxTell v1.1 predictor/checkpoint profile\\\\\\\")\\\\n    print(f\\\\\\\"  predictor num_heads: {voxtell['predictor_v1_1']['num_heads']}\\\\\\\")\\\\n    if voxtell[\\\\\\\"checkpoint\\\\\\\"] and voxtell[\\\\\\\"checkpoint\\\\\\\"].get(\\\\\\\"available\\\\\\\"):\\\\n        print(f\\\\\\\"  checkpoint: {voxtell['checkpoint']['checkpoint_path']}\\\\\\\")\\\\n        print(f\\\\\\\"  checkpoint keys: {voxtell['checkpoint']['key_count']}\\\\\\\")\\\\n        print(f\\\\\\\"  checkpoint pos_embed: {fmt_shape(voxtell['checkpoint']['pos_embed_shape'])}\\\\\\\")\\\\n        print(f\\\\\\\"  checkpoint inferred num_heads: {voxtell['checkpoint_num_heads']}\\\\\\\")\\\\n        for row in voxtell[\\\\\\\"checkpoint\\\\\\\"][\\\\\\\"projection_rows\\\\\\\"]:\\\\n            print(projection_line(row))\\\\n    elif voxtell[\\\\\\\"checkpoint\\\\\\\"]:\\\\n        print(f\\\\\\\"  checkpoint unavailable: {voxtell['checkpoint']['error']}\\\\\\\")\\\\n    else:\\\\n        print(\\\\\\\"  checkpoint inspection skipped\\\\\\\")\\\\n        for row in voxtell[\\\\\\\"predictor_v1_1\\\\\\\"][\\\\\\\"projection_rows\\\\\\\"]:\\\\n            print(projection_line(row))\\\\n    print()\\\\n    print(\\\\\\\"P6 whitelist input\\\\\\\")\\\\n    for item in audit[\\\\\\\"whitelist_input\\\\\\\"][\\\\\\\"required_exact_skip_patterns\\\\\\\"]:\\\\n        print(f\\\\\\\"  required skip: {item['pattern']} ({item['reason']})\\\\\\\")\\\\n    for item in audit[\\\\\\\"whitelist_input\\\\\\\"][\\\\\\\"conditional_skip_patterns\\\\\\\"]:\\\\n        print(f\\\\\\\"  conditional skip: {item['pattern']} ({item['reason']})\\\\\\\")\\\\n    for note in audit[\\\\\\\"whitelist_input\\\\\\\"][\\\\\\\"no_skip_notes\\\\\\\"]:\\\\n        print(f\\\\\\\"  note: {note}\\\\\\\")\\\\n    compare = audit[\\\\\\\"state_compare_current_body_vs_checkpoint\\\\\\\"]\\\\n    if compare[\\\\\\\"available\\\\\\\"]:\\\\n        print()\\\\n        print(\\\\\\\"Current Body-Tell same-name checkpoint shape coverage\\\\\\\")\\\\n        print(f\\\\\\\"  matching keys: {compare['matching_count']}\\\\\\\")\\\\n        print(f\\\\\\\"  shape mismatches: {compare['mismatch_count']}\\\\\\\")\\\\n        print(f\\\\\\\"  missing in checkpoint: {compare['missing_in_checkpoint_count']}\\\\\\\")\\\\n        print(f\\\\\\\"  unexpected in checkpoint: {compare['unexpected_in_checkpoint_count']}\\\\\\\")\\\\n        print(f\\\\\\\"  matched params: {compare['matched_param_count']:,} / {compare['body_param_count']:,}\\\\\\\")\\\\n\\\\n\\\\ndef table_row(cells: list[Any], code_first: bool = False) -> str:\\\\n    rendered = []\\\\n    for index, cell in enumerate(cells):\\\\n        value = html.escape(str(cell))\\\\n        if code_first and index == 0:\\\\n            value = f\\\\\\\"<code>{value}</code>\\\\\\\"\\\\n        rendered.append(f\\\\\\\"<td>{value}</td>\\\\\\\")\\\\n    return \\\\\\\"<tr>\\\\\\\" + \\\\\\\"\\\\\\\".join(rendered) + \\\\\\\"</tr>\\\\\\\"\\\\n\\\\n\\\\ndef projection_table(rows: list[dict[str, Any]]) -> str:\\\\n    body = \\\\\\\"\\\\\\\\n\\\\\\\".join(\\\\n        table_row(\\\\n            [\\\\n                row[\\\\\\\"stage\\\\\\\"],\\\\n                row.get(\\\\\\\"channels\\\\\\\", \\\\\\\"n/a\\\\\\\"),\\\\n                row[\\\\\\\"output_dim\\\\\\\"],\\\\n                fmt_shape(row[\\\\\\\"weight_shape\\\\\\\"]),\\\\n                row[\\\\\\\"key\\\\\\\"],\\\\n            ]\\\\n        )\\\\n        for row in rows\\\\n    )\\\\n    return (\\\\n        \\\\\\\"<table><thead><tr>\\\\\\\"\\\\n        \\\\\\\"<th>Stage</th><th>Channels</th><th>Output dim</th><th>Final linear weight</th><th>Key</th>\\\\\\\"\\\\n        \\\\\\\"</tr></thead><tbody>\\\\\\\"\\\\n        f\\\\\\\"{body}</tbody></table>\\\\\\\"\\\\n    )\\\\n\\\\n\\\\ndef render_html_report(audit: dict[str, Any]) -> str:\\\\n    body = audit[\\\\\\\"body\\\\\\\"]\\\\n    voxtell = audit[\\\\\\\"voxtell\\\\\\\"]\\\\n    compare = audit[\\\\\\\"state_compare_current_body_vs_checkpoint\\\\\\\"]\\\\n    whitelist = audit[\\\\\\\"whitelist_input\\\\\\\"]\\\\n    checkpoint = voxtell[\\\\\\\"checkpoint\\\\\\\"]\\\\n    checkpoint_rows = (\\\\n        checkpoint[\\\\\\\"projection_rows\\\\\\\"]\\\\n        if checkpoint and checkpoint.get(\\\\\\\"available\\\\\\\")\\\\n        else voxtell[\\\\\\\"predictor_v1_1\\\\\\\"][\\\\\\\"projection_rows\\\\\\\"]\\\\n    )\\\\n    checkpoint_label = \\\\\\\"checkpoint-derived\\\\\\\" if checkpoint and checkpoint.get(\\\\\\\"available\\\\\\\") else \\\\\\\"predictor-derived\\\\\\\"\\\\n\\\\n    prefix_table = \\\\\\\"\\\\\\\"\\\\n    if compare[\\\\\\\"available\\\\\\\"]:\\\\n        prefix_rows = \\\\\\\"\\\\\\\\n\\\\\\\".join(\\\\n            table_row(\\\\n                [\\\\n                    row[\\\\\\\"prefix\\\\\\\"],\\\\n                    row[\\\\\\\"body_keys\\\\\\\"],\\\\n                    row[\\\\\\\"checkpoint_keys\\\\\\\"],\\\\n                    row[\\\\\\\"shape_compatible_same_name\\\\\\\"],\\\\n                ],\\\\n                code_first=True,\\\\n            )\\\\n            for row in compare[\\\\\\\"prefix_rows\\\\\\\"]\\\\n        )\\\\n        prefix_table = (\\\\n            \\\\\\\"<table><thead><tr