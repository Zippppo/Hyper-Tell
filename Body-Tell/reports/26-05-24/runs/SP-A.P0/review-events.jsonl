nels\",\n   339\t                },\n   340\t            ]\n   341\t        )\n   342\t    elif effective_checkpoint_heads is not None:\n   343\t        no_skip_notes.append(\n   344\t            \"checkpoint-derived num_heads matches Body-Tell current num_heads; \"\n   345\t            \"do not skip project_to_decoder_channels.* or decoder mask-fusion keys for this reason\"\n   346\t        )\n   347\t\n   348\t    if source_default_num_heads != body_num_heads:\n   349\t        conditional_skips.append(\n   350\t            {\n   351\t                \"pattern\": \"project_to_decoder_channels.[1-4].*, decoder.transpconvs.[1-4].*, decoder.seg_layers.*\",\n   352\t                \"reason\": (\n   353\t                    \"only apply if loading a checkpoint generated from the VoxTellModel source \"\n   354\t                    \"default num_heads=1 into a Body-Tell num_heads=32 model\"\n   355\t                ),\n   356\t            }\n   357\t        )\n   358\t\n   359\t    return {\n   360\t        \"pos_embed_policy\": pos_embed_policy,\n   361\t        \"body_num_heads\": body_num_heads,\n   362\t        \"voxtell_source_default_num_heads\": source_default_num_heads,\n   363\t        \"voxtell_checkpoint_num_heads\": checkpoint_num_heads,\n   364\t        \"required_exact_skip_patterns\": exact_skips,\n   365\t        \"conditional_skip_patterns\": conditional_skips,\n   366\t        \"no_skip_notes\": no_skip_notes,\n   367\t    }\n   368\t\n   369\t\n   370\tdef make_audit(args: argparse.Namespace) -> dict[str, Any]:\n   371\t    body_config = load_body_config(args.config)\n   372\t    body_rows = body_projection_rows(body_config)\n   373\t    source_info = parse_voxtell_model_source(VOXTELL_ROOT / \"voxtell\" / \"model\" / \"voxtell_model.py\")\n   374\t    predictor_overrides = parse_voxtell_predictor_overrides(\n   375\t        VOXTELL_ROOT / \"voxtell\" / \"inference\" / \"predictor.py\"\n   376\t    )\n   377\t\n   378\t    defaults = source_info[\"defaults\"]\n   379\t    decoder_configs = source_info[\"decoder_configs\"]\n   380\t    source_default_num_heads = int(defaults[\"num_heads\"])\n   381\t    source_default_hidden_dim = int(defaults[\"project_to_decoder_hidden_dim\"])\n   382\t    source_default_num_stages = int(defaults[\"num_maskformer_stages\"])\n   383\t    source_rows = voxtell_projection_rows(\n   384\t        decoder_configs,\n   385\t        source_default_num_stages,\n   386\t        source_default_num_heads,\n   387\t        source_default_hidden_dim,\n   388\t    )\n   389\t\n   390\t    predictor_num_heads = int(predictor_overrides.get(\"num_heads\", source_default_num_heads))\n   391\t    predictor_hidden_dim = int(\n   392\t        predictor_overrides.get(\"project_to_decoder_hidden_dim\", source_default_hidden_dim)\n   393\t    )\n   394\t    predictor_num_stages = int(\n   395\t        predictor_overrides.get(\"num_maskformer_stages\", source_default_num_stages)\n   396\t    )\n   397\t    predictor_rows = voxtell_projection_rows(\n   398\t        decoder_configs,\n   399\t        predictor_num_stages,\n   400\t        predictor_num_heads,\n   401\t        predictor_hidden_dim,\n   402\t    )\n   403\t\n   404\t    checkpoint = None if args.skip_checkpoint else load_checkpoint_shapes(args.voxtell_dir)\n   405\t    checkpoint_num_heads = None\n   406\t    if checkpoint and checkpoint[\"available\"]:\n   407\t        checkpoint_num_heads = infer_num_heads_from_projection_rows(\n   408\t            checkpoint[\"projection_rows\"],\n   409\t            decoder_configs,\n   410\t        )\n   411\t        for row in checkpoint[\"projection_rows\"]:\n   412\t            stage = row[\"stage\"]\n   413\t            row[\"channels\"] = int(decoder_configs[stage][\"channels\"])\n   414\t\n   415\t    body_shapes = None if args.skip_state_dict_compare else load_body_state_shapes(body_config)\n   416\t    checkpoint_shapes = (\n   417\t        checkpoint.get(\"state_shapes\")\n   418\t        if checkpoint is not None and checkpoint.get(\"available\")\n   419\t        else None\n   420\t    )\n   421\t    state_compare = compare_state_shapes(checkpoint_shapes, body_shapes)\n   422\t\n   423\t    whitelist_input = build_whitelist_input(\n   424\t        pos_embed_policy=args.pos_embed_policy,\n   425\t        body_num_heads=int(body_config.num_heads),\n   426\t        source_default_num_heads=source_default_num_heads,\n   427\t        checkpoint_num_heads=checkpoint_num_heads,\n   428\t    )\n   429\t\n   430\t    return {\n   431\t        \"body\": {\n   432\t            \"config_path\": str(args.config),\n   433\t            \"num_heads\": int(body_config.num_heads),\n   434\t            \"num_maskformer_stages_config\": int(body_config.num_maskformer_stages),\n   435\t            \"fused_stage_count_actual\": len(body_rows),\n   436\t            \"encoder_channels\": list(body_config.encoder_channels),\n   437\t            \"projection_prefix\": \"mask_projections\",\n   438\t            \"target_projection_prefix\": \"project_to_decoder_channels\",\n   439\t            \"projection_rows\": body_rows,\n   440\t        },\n   441\t        \"voxtell\": {\n   442\t            \"source_default\": {\n   443\t                \"num_heads\": source_default_num_heads,\n   444\t                \"hidden_dim\": source_default_hidden_dim,\n   445\t                \"projection_rows\": source_rows,\n   446\t            },\n   447\t            \"predictor_v1_1\": {\n   448\t                \"num_heads\": predictor_num_heads,\n   449\t                \"hidden_dim\": predictor_hidden_dim,\n   450\t                \"projection_rows\": predictor_rows,\n   451\t                \"overrides\": predictor_overrides,\n   452\t            },\n   453\t            \"checkpoint\": checkpoint,\n   454\t            \"checkpoint_num_heads\": checkpoint_num_heads,\n   455\t        },\n   456\t        \"state_compare_current_body_vs_checkpoint\": state_compare,\n   457\t        \"whitelist_input\": whitelist_input,\n   458\t    }\n   459\t\n   460\t\n   461\tdef fmt_shape(shape: Any) -> str:\n   462\t    if shape is None:\n   463\t        return \"n/a\"\n   464\t    return \"(\" + \", \".join(str(int(x)) for x in shape) + \")\"\n   465\t\n   466\t\n   467\tdef projection_line(row: dict[str, Any]) -> str:\n   468\t    return (\n   469\t        f\"  stage {row['stage']}: channels={row.get('channels', 'n/a')} \"\n   470\t        f\"output_dim={row['output_dim']} weight={fmt_shape(row['weight_shape'])} \"\n   471\t        f\"key={row['key']}\"\n   472\t    )\n   473\t\n   474\t\n   475\tdef print_text_report(audit: dict[str, Any]) -> None:\n   476\t    body = audit[\"body\"]\n   477\t    voxtell = audit[\"voxtell\"]\n   478\t    print(\"SP-A.P0 VoxTell compatibility baseline\")\n   479\t    print()\n   480\t    print(\"Body-Tell current\")\n   481\t    print(f\"  config: {body['config_path']}\")\n   482\t    print(f\"  num_heads: {body['num_heads']}\")\n   483\t    print(\n   484\t        \"  fused projection stages: \"\n   485\t        f\"{body['fused_stage_count_actual']} \"\n   486\t        f\"(configured {body['num_maskformer_stages_config']})\"\n   487\t    )\n   488\t    for row in body[\"projection_rows\"]:\n   489\t        print(projection_line(row))\n   490\t    print()\n   491\t    print(\"VoxTell v1.1 source default\")\n   492\t    print(f\"  num_heads: {voxtell['source_default']['num_heads']}\")\n   493\t    for row in voxtell[\"source_default\"][\"projection_rows\"]:\n   494\t        print(projection_line(row))\n   495\t    print()\n   496\t    print(\"VoxTell v1.1 predictor/checkpoint profile\")\n   497\t    print(f\"  predictor num_heads: {voxtell['predictor_v1_1']['num_heads']}\")\n   498\t    if voxtell[\"checkpoint\"] and voxtell[\"checkpoint\"].get(\"available\"):\n   499\t        print(f\"  checkpoint: {voxtell['checkpoint']['checkpoint_path']}\")\n   500\t        print(f\"  checkpoint keys: {voxtell['checkpoint']['key_count']}\")\n   501\t        print(f\"  checkpoint pos_embed: {fmt_shape(voxtell['checkpoint']['pos_embed_shape'])}\")\n   502\t        print(f\"  checkpoint inferred num_heads: {voxtell['checkpoint_num_heads']}\")\n   503\t        for row in voxtell[\"checkpoint\"][\"projection_rows\"]:\n   504\t            print(projection_line(row))\n   505\t    elif voxtell[\"checkpoint\"]:\n   506\t        print(f\"  checkpoint unavailable: {voxtell['checkpoint']['error']}\")\n   507\t    else:\n   508\t        print(\"  checkpoint inspection skipped\")\n   509\t        for row in voxtell[\"predictor_v1_1\"][\"projection_rows\"]:\n   510\t            print(projection_line(row))\n   511\t    print()\n   512\t    print(\"P6 whitelist input\")\n   513\t    for item in audit[\"whitelist_input\"][\"required_exact_skip_patterns\"]:\n   514\t        print(f\"  required skip: {item['pattern']} ({item['reason']})\")\n   515\t    for item in audit[\"whitelist_input\"][\"conditional_skip_patterns\"]:\n   516\t        print(f\"  conditional skip: {item['pattern']} ({item['reason']})\")\n   517\t    for note in audit[\"whitelist_input\"][\"no_skip_notes\"]:\n   518\t        print(f\"  note: {note}\")\n   519\t    compare = audit[\"state_compare_current_body_vs_checkpoint\"]\n   520\t    if compare[\"available\"]:\n   521\t        print()\n   522\t        print(\"Current Body-Tell same-name checkpoint shape coverage\")\n   523\t        print(f\"  matching keys: {compare['matching_count']}\")\n   524\t        print(f\"  shape mismatches: {compare['mismatch_count']}\")\n   525\t        print(f\"  missing in checkpoint: {compare['missing_in_checkpoint_count']}\")\n   526\t        print(f\"  unexpected in checkpoint: {compare['unexpected_in_checkpoint_count']}\")\n   527\t        print(f\"  matched params: {compare['matched_param_count']:,} / {compare['body_param_count']:,}\")\n   528\t\n   529\t\n   530\tdef table_row(cells: list[Any], code_first: bool = False) -> str:\n   531\t    rendered = []\n   532\t    for index, cell in enumerate(cells):\n   533\t        value = html.escape(str(cell))\n   534\t        if code_first and index == 0:\n   535\t            value = f\"<code>{value}</code>\"\n   536\t        rendered.append(f\"<td>{value}</td>\")\n   537\t    return \"<tr>\" + \"\".join(rendered) + \"</tr>\"\n   538\t\n   539\t\n   540\tdef projection_table(rows: list[dict[str, Any]]) -> str:\n   541\t    body = \"\\n\".join(\n   542\t        table_row(\n   543\t            [\n   544\t                row[\"stage\"],\n   545\t                row.get(\"channels\", \"n/a\"),\n   546\t                row[\"output_dim\"],\n   547\t                fmt_shape(row[\"weight_shape\"]),\n   548\t                row[\"key\"],\n   549\t            ]\n   550\t        )\n   551\t        for row in rows\n   552\t    )\n   553\t    return (\n   554\t        \"<table><thead><tr>\"\n   555\t        \"<th>Stage</th><th>Channels</th><th>Output dim</th><th>Final linear weight</th><th>Key</th>\"\n   556\t        \"</tr></thead><tbody>\"\n   557\t        f\"{body}</tbody></table>\"\n   558\t    )\n   559\t\n   560\t\n","exit_code":0,"status":"completed"}}
