        dropout=0.0,\n    51\t        activation=\"relu\",\n    52\t        normalize_before=True,\n    53\t    )\n    54\t    return BodyTransformerDecoder(layer, num_layers=2, norm=nn.LayerNorm(16))\n    55\t\n    56\t\n    57\tdef _golden_inputs():\n    58\t    generator = torch.Generator().manual_seed(20260524)\n    59\t    return {\n    60\t        \"tgt\": torch.randn(3, 2, 16, generator=generator),\n    61\t        \"memory\": torch.randn(5, 2, 16, generator=generator),\n    62\t        \"pos\": torch.randn(5, 2, 16, generator=generator),\n    63\t        \"query_pos\": torch.randn(3, 2, 16, generator=generator),\n    64\t    }\n    65\t\n    66\t\n    67\t@pytest.mark.xfail(\n    68\t    reason=\"SP-A.P1 must align Body-Tell TransformerDecoderLayer.forward_pre with VoxTell.\",\n    69\t    strict=True,\n    70\t)\n    71\tdef test_body_transformer_matches_voxtell_reference_with_shared_weights() -> None:\n    72\t    torch.manual_seed(0)\n    73\t    voxtell_decoder = _build_voxtell_reference_decoder()\n    74\t    body_decoder = _build_body_decoder()\n    75\t    body_decoder.load_state_dict(voxtell_decoder.state_dict())\n    76\t    voxtell_decoder.eval()\n    77\t    body_decoder.eval()\n    78\t\n    79\t    inputs = _golden_inputs()\n    80\t    with torch.no_grad():\n    81\t        expected, _ = voxtell_decoder(**inputs)\n    82\t        actual, _ = body_decoder(**inputs)\n    83\t\n    84\t    torch.testing.assert_close(actual, expected, rtol=0.0, atol=1e-6)\n","exit_code":0,"status":"completed"}}
