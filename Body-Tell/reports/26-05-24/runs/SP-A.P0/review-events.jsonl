8, 2048)</td><td>project_to_decoder_channels.1.2</td></tr>\n<tr><td>2</td><td>128</td><td>4096</td><td>(4096, 2048)</td><td>project_to_decoder_channels.2.2</td></tr>\n<tr><td>3</td><td>256</td><td>8192</td><td>(8192, 2048)</td><td>project_to_decoder_channels.3.2</td></tr>\n<tr><td>4</td><td>320</td><td>10240</td><td>(10240, 2048)</td><td>project_to_decoder_channels.4.2</td></tr></tbody></table>\n    <p class=\"warn\">Audit finding: the model class default is <code>num_heads=1</code>, but the v1.1 predictor and checkpoint metadata use <code>num_heads=32</code>. P4/P6 should key off the actual checkpoint being loaded.</p>\n  </section>\n\n  <section>\n    <h2>Weight-Key Audit Input</h2>\n    <p>Current Body-Tell can only directly reuse same-name/same-shape subsets before SP-A architecture work. This table is a baseline input for P6, not a claim that current Body-Tell is already checkpoint-compatible.</p>\n    <table><thead><tr><th>Prefix</th><th>Body keys</th><th>Checkpoint keys</th><th>Same-name shape-compatible</th></tr></thead><tbody><tr><td><code>decoder</code></td><td>32</td><td>508</td><td>0</td></tr>\n<tr><td><code>encoder</code></td><td>30</td><td>448</td><td>0</td></tr>\n<tr><td><code>mask_projections</code></td><td>16</td><td>0</td><td>0</td></tr>\n<tr><td><code>pos_embed</code></td><td>0</td><td>1</td><td>0</td></tr>\n<tr><td><code>project_bottleneck_embed</code></td><td>0</td><td>4</td><td>0</td></tr>\n<tr><td><code>project_text_embed</code></td><td>4</td><td>4</td><td>4</td></tr>\n<tr><td><code>project_to_decoder_channels</code></td><td>0</td><td>20</td><td>0</td></tr>\n<tr><td><code>project_visual_embed</code></td><td>4</td><td>0</td><td>0</td></tr>\n<tr><td><code>transformer_decoder</code></td><td>110</td><td>110</td><td>110</td></tr></tbody></table>\n    <p>Same-name compatible current Body-Tell keys: <code>114</code>; shape mismatches: <code>0</code>; checkpoint keys unexpected to current Body-Tell: <code>981</code>.</p>\n  </section>\n\n  <section>\n    <h2>P6 Whitelist Input</h2>\n    <h3>Required exact skips</h3>\n    <table><thead><tr><th>Pattern</th><th>Reason</th></tr></thead><tbody><tr><td><code>pos_embed</code></td><td>Body-Tell current non-192^3 crop uses dynamic positional encoding.</td></tr></tbody></table>\n    <h3>Conditional skips</h3>\n    <table><thead><tr><th>Pattern</th><th>Reason</th></tr></thead><tbody><tr><td><code>project_to_decoder_channels.[1-4].*, decoder.transpconvs.[1-4].*, decoder.seg_layers.*</code></td><td>only apply if loading a checkpoint generated from the VoxTellModel source default num_heads=1 into a Body-Tell num_heads=32 model</td></tr></tbody></table>\n    <ul><li>checkpoint-derived num_heads matches Body-Tell current num_heads; do not skip project_to_decoder_channels.* or decoder mask-fusion keys for this reason</li></ul>\n  </section>\n\n  <section>\n    <h2>Machine-Readable Audit Payload</h2>\n    <pre>{\n  &quot;body&quot;: {\n    &quot;config_path&quot;: &quot;/home/comp/csrkzhu/code/Hyper-Tell/Body-Tell/configs/phase1_voxtell_body.yaml&quot;,\n    &quot;encoder_channels&quot;: [\n      32,\n      64,\n      128,\n      256,\n      320\n    ],\n    &quot;fused_stage_count_actual&quot;: 4,\n    &quot;num_heads&quot;: 32,\n    &quot;num_maskformer_stages_config&quot;: 5,\n    &quot;projection_prefix&quot;: &quot;mask_projections&quot;,\n    &quot;projection_rows&quot;: [\n      {\n        &quot;bias_shape&quot;: [\n          32\n        ],\n        &quot;channels&quot;: 32,\n        &quot;key&quot;: &quot;mask_projections.0.2&quot;,\n        &quot;output_dim&quot;: 32,\n        &quot;stage&quot;: 0,\n        &quot;target_key&quot;: &quot;project_to_decoder_channels.0.2&quot;,\n        &quot;weight_shape&quot;: [\n          32,\n          2048\n        ]\n      },\n      {\n        &quot;bias_shape&quot;: [\n          2048\n        ],\n        &quot;channels&quot;: 64,\n        &quot;key&quot;: &quot;mask_projections.1.2&quot;,\n        &quot;output_dim&quot;: 2048,\n     