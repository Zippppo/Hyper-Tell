{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"/bin/bash -lc \"nl -ba Body-Tell/scripts/audit_voxtell_alignment.py | sed -n '1,260p'\"","aggregated_output":"     1\t#!/usr/bin/env python3\n     2\t\"\"\"SP-A.P0 compatibility audit for Body-Tell and VoxTell v1.1.\"\"\"\n     3\t\n     4\tfrom __future__ import annotations\n     5\t\n     6\timport argparse\n     7\timport ast\n     8\timport html\n     9\timport json\n    10\timport re\n    11\timport sys\n    12\tfrom dataclasses import asdict\n    13\tfrom pathlib import Path\n    14\tfrom typing import Any\n    15\t\n    16\t\n    17\tREPO_ROOT = Path(__file__).resolve().parents[2]\n    18\tBODY_TELL_ROOT = Path(__file__).resolve().parents[1]\n    19\tVOXTELL_ROOT = REPO_ROOT / \"VoxTell\"\n    20\tDEFAULT_BODY_CONFIG = BODY_TELL_ROOT / \"configs\" / \"phase1_voxtell_body.yaml\"\n    21\tDEFAULT_VOXTELL_DIR = VOXTELL_ROOT / \"models-weight\" / \"voxtell\" / \"voxtell_v1.1\"\n    22\tPROJECT_TO_DECODER_RE = re.compile(r\"^project_to_decoder_channels\\.(\\d+)\\.2\\.weight$\")\n    23\t\n    24\t\n    25\tdef _literal(node: ast.AST) -> Any:\n    26\t    try:\n    27\t        return ast.literal_eval(node)\n    28\t    except Exception:\n    29\t        return None\n    30\t\n    31\t\n    32\tdef _shape(value: Any) -> tuple[int, ...]:\n    33\t    return tuple(int(x) for x in value.shape)\n    34\t\n    35\t\n    36\tdef _prefix(name: str) -> str:\n    37\t    return name.split(\".\", 1)[0]\n    38\t\n    39\t\n    40\tdef _numel(shape: tuple[int, ...]) -> int:\n    41\t    total = 1\n    42\t    for item in shape:\n    43\t        total *= int(item)\n    44\t    return total\n    45\t\n    46\t\n    47\tdef load_body_config(config_path: Path) -> Any:\n    48\t    import yaml\n    49\t\n    50\t    if str(BODY_TELL_ROOT) not in sys.path:\n    51\t        sys.path.insert(0, str(BODY_TELL_ROOT))\n    52\t    from body_tell.models.voxtell_body_model import VoxTellBodyConfig\n    53\t\n    54\t    raw = yaml.safe_load(config_path.read_text(encoding=\"utf-8\")) or {}\n    55\t    model_raw = dict(raw.get(\"model\", {}))\n    56\t    model_raw.pop(\"name\", None)\n    57\t    cfg = asdict(VoxTellBodyConfig())\n    58\t    cfg.update(model_raw)\n    59\t    cfg[\"encoder_channels\"] = tuple(int(x) for x in cfg[\"encoder_channels\"])\n    60\t    return VoxTellBodyConfig(**cfg)\n    61\t\n    62\t\n    63\tdef body_projection_rows(config: Any) -> list[dict[str, Any]]:\n    64\t    fused_stage_count = min(\n    65\t        int(config.num_maskformer_stages),\n    66\t        len(config.encoder_channels) - 1,\n    67\t    )\n    68\t    rows = []\n    69\t    for stage_index, channels in enumerate(config.encoder_channels[:fused_stage_count]):\n    70\t        output_dim = int(channels) if stage_index == 0 else int(channels) * int(config.num_heads)\n    71\t        rows.append(\n    72\t            {\n    73\t                \"stage\": stage_index,\n    74\t                \"channels\": int(channels),\n    75\t                \"output_dim\": output_dim,\n    76\t                \"weight_shape\": (output_dim, int(config.text_projection_hidden_dim)),\n    77\t                \"bias_shape\": (output_dim,),\n    78\t                \"key\": f\"mask_projections.{stage_index}.2\",\n    79\t                \"target_key\": f\"project_to_decoder_channels.{stage_index}.2\",\n    80\t            }\n    81\t        )\n    82\t    return rows\n    83\t\n    84\t\n    85\tdef load_body_state_shapes(config: Any) -> dict[str, tuple[int, ...]]:\n    86\t    import torch\n    87\t\n    88\t    if str(BODY_TELL_ROOT) not in sys.path:\n    89\t        sys.path.insert(0, str(BODY_TELL_ROOT))\n    90\t    from body_tell.models.voxtell_body_model import VoxTellBodyModel\n    91\t\n    92\t    with torch.device(\"meta\"):\n    93\t        model = VoxTellBodyModel(config)\n    94\t    return {name: _shape(tensor) for name, tensor in model.state_dict().items()}\n    95\t\n    96\t\n    97\tdef parse_voxtell_model_source(source_path: Path) -> dict[str, Any]:\n    98\t    tree = ast.parse(source_path.read_text(encoding=\"utf-8\"))\n    99\t    model_class = next(\n   100\t        node for node in tree.body if isinstance(node, ast.ClassDef) and node.name == \"VoxTellModel\"\n   101\t    )\n   102\t    decoder_configs: dict[int, dict[str, Any]] = {}\n   103\t    defaults: dict[str, Any] = {}\n   104\t\n   105\t    for node in model_class.body:\n   106\t        if isinstance(node, ast.Assign):\n   107\t            for target in node.targets:\n   108\t                if isinstance(target, ast.Name) and target.id == \"DECODER_CONFIGS\":\n   109\t                    decoder_configs = _literal(node.value) or {}\n   110\t        if isinstance(node, ast.FunctionDef) and node.name == \"__init__\":\n   111\t            positional_args = [arg.arg for arg in node.args.args]\n   112\t            default_values = list(node.args.defaults)\n   113\t            default_names = positional_args[-len(default_values) :] if default_values else []\n   114\t            defaults = {\n   115\t                name: _literal(default)\n   116\t                for name, default in zip(default_names, default_values)\n   117\t            }\n   118\t            break\n   119\t\n   120\t    return {\n   121\t        \"decoder_configs\": decoder_configs,\n   122\t        \"defaults\": defaults,\n   123\t    }\n   124\t\n   125\t\n   126\tdef parse_voxtell_predictor_overrides(predictor_path: Path) -> dict[str, Any]:\n   127\t    tree = ast.parse(predictor_path.read_text(encoding=\"utf-8\"))\n   128\t    overrides: dict[str, Any] = {}\n   129\t    for node in ast.walk(tree):\n   130\t        if not isinstance(node, ast.Call):\n   131\t            continue\n   132\t        func = node.func\n   133\t        is_model_call = (\n   134\t            isinstance(func, ast.Name)\n   135\t            and func.id == \"VoxTellModel\"\n   136\t            or isinstance(func, ast.Attribute)\n   137\t            and func.attr == \"VoxTellModel\"\n   138\t        )\n   139\t        if not is_model_call:\n   140\t            continue\n   141\t        for keyword in node.keywords:\n   142\t            if keyword.arg is not None:\n   143\t                value = _literal(keyword.value)\n   144\t                if value is not None:\n   145\t                    overrides[keyword.arg] = value\n   146\t        break\n   147\t    return overrides\n   148\t\n   149\t\n   150\tdef voxtell_projection_rows(\n   151\t    decoder_configs: dict[int, dict[str, Any]],\n   152\t    num_maskformer_stages: int,\n   153\t    num_heads: int,\n   154\t    hidden_dim: int,\n   155\t) -> list[dict[str, Any]]:\n   156\t    rows = []\n   157\t    for stage_index, config in list(sorted(decoder_configs.items()))[:num_maskformer_stages]:\n   158\t        channels = int(config[\"channels\"])\n   159\t        output_dim = channels if int(stage_index) == 0 else channels * int(num_heads)\n   160\t        rows.append(\n   161\t            {\n   162\t                \"stage\": int(stage_index),\n   163\t                \"channels\": channels,\n   164\t                \"output_dim\": output_dim,\n   165\t                \"weight_shape\": (output_dim, int(hidden_dim)),\n   166\t                \"bias_shape\": (output_dim,),\n   167\t                \"key\": f\"project_to_decoder_channels.{stage_index}.2\",\n   168\t            }\n   169\t        )\n   170\t    return rows\n   171\t\n   172\t\n   173\tdef load_checkpoint_shapes(voxtell_dir: Path) -> dict[str, Any]:\n   174\t    import torch\n   175\t\n   176\t    checkpoint_path = voxtell_dir / \"fold_0\" / \"checkpoint_final.pth\"\n   177\t    if not checkpoint_path.exists():\n   178\t        return {\n   179\t            \"available\": False,\n   180\t            \"checkpoint_path\": str(checkpoint_path),\n   181\t            \"error\": \"checkpoint file does not exist\",\n   182\t        }\n   183\t\n   184\t    try:\n   185\t        checkpoint = torch.load(\n   186\t            str(checkpoint_path),\n   187\t            map_location=\"cpu\",\n   188\t            weights_only=False,\n   189\t            mmap=True,\n   190\t        )\n   191\t    except TypeError:\n   192\t        checkpoint = torch.load(\n   193\t            str(checkpoint_path),\n   194\t            map_location=\"cpu\",\n   195\t            weights_only=False,\n   196\t        )\n   197\t\n   198\t    state_dict = checkpoint.get(\"network_weights\", checkpoint)\n   199\t    shapes = {name: _shape(tensor) for name, tensor in state_dict.items()}\n   200\t    rows = []\n   201\t    for name, shape in sorted(shapes.items()):\n   202\t        match = PROJECT_TO_DECODER_RE.match(name)\n   203\t        if not match:\n   204\t            continue\n   205\t        stage = int(match.group(1))\n   206\t        rows.append(\n   207\t            {\n   208\t                \"stage\": stage,\n   209\t                \"output_dim\": int(shape[0]),\n   210\t                \"weight_shape\": shape,\n   211\t                \"bias_shape\": shapes.get(f\"project_to_decoder_channels.{stage}.2.bias\"),\n   212\t                \"key\": f\"project_to_decoder_channels.{stage}.2\",\n   213\t            }\n   214\t        )\n   215\t\n   216\t    return {\n   217\t        \"available\": True,\n   218\t        \"checkpoint_path\": str(checkpoint_path),\n   219\t        \"key_count\": len(shapes),\n   220\t        \"state_shapes\": shapes,\n   221\t        \"projection_rows\": sorted(rows, key=lambda row: row[\"stage\"]),\n   222\t        \"pos_embed_shape\": shapes.get(\"pos_embed\"),\n   223\t    }\n   224\t\n   225\t\n   226\tdef infer_num_heads_from_projection_rows(\n   227\t    rows: list[dict[str, Any]],\n   228\t    decoder_configs: dict[int, dict[str, Any]],\n   229\t) -> int | None:\n   230\t    ratios = []\n   231\t    for row in rows:\n   232\t        stage = int(row[\"stage\"])\n   233\t        if stage == 0:\n   234\t            continue\n   235\t        channels = int(decoder_configs[stage][\"channels\"])\n   236\t        output_dim = int(row[\"output_dim\"])\n   237\t        if output_dim % channels != 0:\n   238\t            return None\n   239\t        ratios.append(output_dim // channels)\n   240\t    if not ratios:\n   241\t        return None\n   242\t    first = ratios[0]\n   243\t    return first if all(item == first for item in ratios) else None\n   244\t\n   245\t\n   246\tdef compare_state_shapes(\n   247\t    checkpoint_shapes: dict[str, tuple[int, ...]] | None,\n   248\t    body_shapes: dict[str, tuple[int, ...]] | None,\n   249\t) -> dict[str, Any]:\n   250\t    if checkpoint_shapes is None or body_shapes is None:\n   251\t        return {\"available\": False}\n   252\t\n   253\t    matching = []\n   254\t    mismatched = []\n   255\t    for name, body_shape in sorted(body_shapes.items()):\n   256\t        checkpoint_shape = checkpoint_shapes.get(name)\n   257\t        if checkpoint_shape is None:\n   258\t            continue\n   259\t        if checkpoint_shape == body_shape:\n   260\t            matching.append(name)\n","exit_code":0,"status":"completed"}}
