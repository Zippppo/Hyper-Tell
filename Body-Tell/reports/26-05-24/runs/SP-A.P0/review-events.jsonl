onal_skip_rows = \"\\n\".join(\n   599\t        table_row([item[\"pattern\"], item[\"reason\"]], code_first=True)\n   600\t        for item in whitelist[\"conditional_skip_patterns\"]\n   601\t    )\n   602\t    no_skip_notes = \"\".join(\n   603\t        f\"<li>{html.escape(note)}</li>\" for note in whitelist[\"no_skip_notes\"]\n   604\t    )\n   605\t\n   606\t    embedded_json = html.escape(json.dumps(audit, indent=2, sort_keys=True, default=str))\n   607\t    return f\"\"\"<!doctype html>\n   608\t<html lang=\"en\">\n   609\t<head>\n   610\t  <meta charset=\"utf-8\">\n   611\t  <title>SP-A.P0 VoxTell Alignment Audit</title>\n   612\t  <style>\n   613\t    body {{ font: 15px/1.55 -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif; margin: 0; color: #17202a; background: #f6f8fa; }}\n   614\t    main {{ max-width: 1160px; margin: 0 auto; padding: 32px 24px 56px; }}\n   615\t    section {{ background: #fff; border: 1px solid #d8e0e7; border-radius: 8px; padding: 18px 20px; margin: 16px 0; }}\n   616\t    h1 {{ margin: 0 0 6px; font-size: 28px; }}\n   617\t    h2 {{ margin: 0 0 10px; font-size: 20px; }}\n   618\t    table {{ border-collapse: collapse; width: 100%; margin: 10px 0; font-size: 14px; }}\n   619\t    th, td {{ border: 1px solid #d8e0e7; padding: 8px 10px; text-align: left; vertical-align: top; }}\n   620\t    th {{ background: #eef3f7; }}\n   621\t    code, pre {{ font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }}\n   622\t    code {{ background: #edf3f7; border-radius: 4px; padding: 1px 4px; }}\n   623\t    pre {{ overflow-x: auto; background: #111827; color: #f8fafc; border-radius: 8px; padding: 14px; }}\n   624\t    .meta {{ color: #5d6875; }}\n   625\t    .warn {{ border-left: 4px solid #9a4a17; background: #fff7ed; padding: 10px 12px; }}\n   626\t    .ok {{ border-left: 4px solid #276749; background: #eef9f0; padding: 10px 12px; }}\n   627\t  </style>\n   628\t</head>\n   629\t<body>\n   630\t<main>\n   631\t  <header>\n   632\t    <h1>SP-A.P0 VoxTell Compatibility Baseline Audit</h1>\n   633\t    <p class=\"meta\">Body config: <code>{html.escape(body['config_path'])}</code>; VoxTell profile: <code>{html.escape(str(DEFAULT_VOXTELL_DIR))}</code>.</p>\n   634\t  </header>\n   635\t\n   636\t  <section>\n   637\t    <h2>Projection Shape Baseline</h2>\n   638\t    <p><strong>Body-Tell current</strong>: <code>num_heads={body['num_heads']}</code>, actual fused projection stages <code>{body['fused_stage_count_actual']}</code> from configured <code>{body['num_maskformer_stages_config']}</code>; prefix is <code>mask_projections</code>, target aligned prefix is <code>project_to_decoder_channels</code>.</p>\n   639\t    {projection_table(body['projection_rows'])}\n   640\t    <p><strong>VoxTell source default</strong>: <code>num_heads={voxtell['source_default']['num_heads']}</code>. This is the class default in <code>voxtell_model.py</code>, not necessarily the shipped v1.1 checkpoint profile.</p>\n   641\t    {projection_table(voxtell['source_default']['projection_rows'])}\n   642\t    <p><strong>VoxTell v1.1 {checkpoint_label}</strong>: predictor override <code>num_heads={voxtell['predictor_v1_1']['num_heads']}</code>; checkpoint inferred <code>num_heads={voxtell['checkpoint_num_heads']}</code>; pos_embed shape <code>{fmt_shape(checkpoint.get('pos_embed_shape') if checkpoint else None)}</code>.</p>\n   643\t    {projection_table(checkpoint_rows)}\n   644\t    <p class=\"warn\">Audit finding: the model class default is <code>num_heads=1</code>, but the v1.1 predictor and checkpoint metadata use <code>num_heads={voxtell['checkpoint_num_heads']}</code>. P4/P6 should key off the actual checkpoint being loaded.</p>\n   645\t  </section>\n   646\t\n   647\t  <section>\n   648\t    <h2>Weight-Key Audit Input</h2>\n   649\t    <p>Current Body-Tell can only directly reuse same-name/same-shape subsets before SP-A architecture work. This table is a baseline input for P6, not a claim that current Body-Tell is already checkpoint-compatible.</p>\n   650\t    {prefix_table}\n   651\t    <p>Same-name compatible current Body-Tell keys: <code>{compare.get('matching_count', 'n/a')}</code>; shape mismatches: <code>{compare.get('mismatch_count', 'n/a')}</code>; checkpoint keys unexpected to current Body-Tell: <code>{compare.get('unexpected_in_checkpoint_count', 'n/a')}</code>.</p>\n   652\t  </section>\n   653\t\n   654\t  <section>\n   655\t    <h2>P6 Whitelist Input</h2>\n   656\t    <h3>Required exact skips</h3>\n   657\t    <table><thead><tr><th>Pattern</th><th>Reason</th></tr></thead><tbody>{required_skip_rows}</tbody></table>\n   658\t    <h3>Conditional skips</h3>\n   659\t    <table><thead><tr><th>Pattern</th><th>Reason</th></tr></thead><tbody>{conditional_skip_rows}</tbody></table>\n   660\t    <ul>{no_skip_notes}</ul>\n   661\t  </section>\n   662\t\n   663\t  <section>\n   664\t    <h2>Machine-Readable Audit Payload</h2>\n   665\t    <pre>{embedded_json}</pre>\n   666\t  </section>\n   667\t</main>\n   668\t</body>\n   669\t</html>\n   670\t\"\"\"\n   671\t\n   672\t\n   673\tdef parse_args(argv: list[str] | None = None) -> argparse.Namespace:\n   674\t    parser = argparse.ArgumentParser(\n   675\t        description=(\n   676\t            \"Audit Body-Tell/VoxTell v1.1 num_heads, projection shapes, \"\n   677\t            \"current same-name state-dict coverage, and P6 whitelist input.\"\n   678\t        )\n   679\t    )\n   680\t    parser.add_argument(\n   681\t        \"--config\",\n   682\t        type=Path,\n   683\t        default=DEFAULT_BODY_CONFIG,\n   684\t        help=\"Body-Tell YAML config to audit.\",\n   685\t    )\n   686\t    parser.add_argument(\n   687\t        \"--voxtell-dir\",\n   688\t        type=Path,\n   689\t        default=DEFAULT_VOXTELL_DIR,\n   690\t        help=\"VoxTell v1.1 model directory containing plans.json and fold_0/checkpoint_final.pth.\",\n   691\t    )\n   692\t    parser.add_argument(\n   693\t        \"--pos-embed-policy\",\n   694\t        choices=(\"dynamic_hwd\", \"fixed_voxtell_192\"),\n   695\t        default=\"dynamic_hwd\",\n   696\t        help=\"Position embedding loading policy to reflect in the P6 whitelist input.\",\n   697\t    )\n   698\t    parser.add_argument(\n   699\t        \"--skip-checkpoint\",\n   700\t        action=\"store_true\",\n   701\t        help=\"Skip checkpoint metadata inspection and use source/predictor-derived shapes only.\",\n   702\t    )\n   703\t    parser.add_argument(\n   704\t        \"--skip-state-dict-compare\",\n   705\t        action=\"store_true\",\n   706\t        help=\"Skip current Body-Tell meta-device state-dict shape comparison.\",\n   707\t    )\n   708\t    parser.add_argument(\n   709\t        \"--html-output\",\n   710\t        type=Path,\n   711\t        help=\"Optional HTML report path.\",\n   712\t    )\n   713\t    return parser.parse_args(argv)\n   714\t\n   715\t\n   716\tdef main(argv: list[str] | None = None) -> int:\n   717\t    args = parse_args(argv)\n   718\t    audit = make_audit(args)\n   719\t    print_text_report(audit)\n   720\t    if args.html_output:\n   721\t        args.html_output.parent.mkdir(parents=True, exist_ok=True)\n   722\t        args.html_output.write_text(render_html_report(audit), encoding=\"utf-8\")\n   723\t        print()\n   724\t        print(f\"Wrote HTML report: {args.html_output}\")\n   725\t    return 0\n   726\t\n   727\t\n   728\tif __name__ == \"__main__\":\n   729\t    raise SystemExit(main())\n","exit_code":0,"status":"completed"}}
