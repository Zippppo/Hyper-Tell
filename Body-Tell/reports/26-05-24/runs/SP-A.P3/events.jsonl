{"type":"item.completed","item":{"id":"item_9","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,220p' Body-Tell/tests/test_model_shapes.py\"","aggregated_output":"from __future__ import annotations\n\nfrom pathlib import Path\n\nimport torch\nimport yaml\nfrom torch import nn\n\nfrom body_tell.models.voxtell_body_model import (\n    VOXTELL_V1_1_ENCODER_CHANNELS,\n    VOXTELL_V1_1_N_BLOCKS_PER_STAGE,\n    VoxTellBodyConfig,\n    VoxTellBodyModel,\n)\n\n\ndef test_voxtell_body_model_outputs_prompt_logits_shape() -> None:\n    torch.manual_seed(0)\n    model = VoxTellBodyModel(\n        VoxTellBodyConfig(\n            input_channels=1,\n            encoder_channels=(4, 8, 16),\n            text_embedding_dim=8,\n            query_dim=16,\n            transformer_num_heads=4,\n            transformer_layers=1,\n            num_maskformer_stages=3,\n            num_heads=2,\n            deep_supervision=False,\n        )\n    )\n\n    occupancy = torch.randn(2, 1, 16, 16, 16)\n    text_embeddings = torch.randn(2, 3, 8)\n\n    logits = model(occupancy, text_embeddings)\n\n    assert logits.shape == (2, 3, 16, 16, 16)\n    assert logits.dtype == occupancy.dtype\n\n\ndef test_voxtell_body_model_supports_deep_supervision() -> None:\n    torch.manual_seed(0)\n    model = VoxTellBodyModel(\n        VoxTellBodyConfig(\n            input_channels=1,\n            encoder_channels=(4, 8, 16),\n            text_embedding_dim=8,\n            query_dim=16,\n            transformer_num_heads=4,\n            transformer_layers=1,\n            num_maskformer_stages=3,\n            num_heads=2,\n            deep_supervision=True,\n        )\n    )\n\n    occupancy = torch.randn(1, 1, 16, 16, 16)\n    text_embeddings = torch.randn(1, 2, 8)\n\n    logits = model(occupancy, text_embeddings)\n\n    assert isinstance(logits, list)\n    assert [tuple(item.shape) for item in logits] == [\n        (1, 2, 16, 16, 16),\n        (1, 2, 8, 8, 8),\n    ]\n\n\ndef test_voxtell_body_model_supports_residual_encoder_policy() -> None:\n    torch.manual_seed(0)\n    model = VoxTellBodyModel(\n        VoxTellBodyConfig(\n            input_channels=1,\n            encoder_channels=(4, 8, 16),\n            backbone=\"residual_encoder\",\n            n_blocks_per_stage=(1, 2, 3),\n            text_embedding_dim=8,\n            query_dim=16,\n            transformer_num_heads=4,\n            transformer_layers=1,\n            num_maskformer_stages=3,\n            num_heads=2,\n            deep_supervision=False,\n        )\n    )\n\n    assert model.encoder.output_channels == (4, 8, 16)\n    assert model.encoder.strides == ((1, 1, 1), (2, 2, 2), (2, 2, 2))\n    assert model.encoder.n_blocks_per_stage == (1, 2, 3)\n    assert [len(stage.blocks) for stage in model.encoder.stages] == [1, 2, 3]\n\n    norms = [\n        module\n        for module in model.encoder.modules()\n        if isinstance(module, nn.InstanceNorm3d)\n    ]\n    assert norms\n    assert all(norm.eps == 1e-5 and norm.affine for norm in norms)\n\n    activations = [\n        module\n        for module in model.encoder.modules()\n        if isinstance(module, nn.LeakyReLU)\n    ]\n    assert activations\n    assert all(activation.inplace for activation in activations)\n\n    main_convs = [\n        module\n        for name, module in model.encoder.named_modules()\n        if isinstance(module, nn.Conv3d)\n        and (name == \"stem.convs.0.conv\" or name.endswith((\"conv1.conv\", \"conv2.conv\")))\n    ]\n    assert main_convs\n    assert all(conv.bias is not None for conv in main_convs)\n\n    occupancy = torch.randn(1, 1, 16, 16, 16)\n    text_embeddings = torch.randn(1, 2, 8)\n\n    logits = model(occupancy, text_embeddings)\n\n    assert logits.shape == (1, 2, 16, 16, 16)\n    assert any(name.startswith(\"encoder.stem.\") for name in model.state_dict())\n    assert not any(name.startswith(\"encoder.encoder.\") for name in model.state_dict())\n\n\ndef test_voxtell_aligned_config_declares_sp_a_encoder_plan() -> None:\n    cfg = yaml.safe_load(\n        Path(\"Body-Tell/configs/phase1_voxtell_aligned.yaml\").read_text()\n    )\n    model_cfg = cfg[\"model\"]\n\n    assert model_cfg[\"backbone\"] == \"residual_encoder\"\n    assert tuple(model_cfg[\"encoder_channels\"]) == VOXTELL_V1_1_ENCODER_CHANNELS\n    assert tuple(model_cfg[\"n_blocks_per_stage\"]) == VOXTELL_V1_1_N_BLOCKS_PER_STAGE\n    assert model_cfg[\"encoder_norm\"] == \"instance_norm_3d\"\n    assert model_cfg[\"encoder_activation\"] == \"leaky_relu\"\n    assert model_cfg[\"encoder_conv_bias\"] is True\n    assert model_cfg[\"decoder_layer\"] == 4\n    assert model_cfg[\"num_maskformer_stages\"] == 5\n\n\ndef test_voxtell_body_model_omits_parameters_unused_without_deep_supervision() -> None:\n    torch.manual_seed(0)\n    model = VoxTellBodyModel(\n        VoxTellBodyConfig(\n            input_channels=1,\n            encoder_channels=(4, 8, 16),\n            text_embedding_dim=8,\n            query_dim=16,\n            transformer_num_heads=4,\n            transformer_layers=1,\n            num_maskformer_stages=3,\n            num_heads=2,\n            deep_supervision=False,\n        )\n    )\n\n    assert len(model.mask_projections) == 2\n    assert not [\n        name\n        for name, parameter in model.named_parameters()\n        if name.startswith(\"decoder.seg_layers.\") and parameter.requires_grad\n    ]\n\n    occupancy = torch.randn(1, 1, 16, 16, 16)\n    text_embeddings = torch.randn(1, 2, 8)\n    logits = model(occupancy, text_embeddings)\n    logits.square().mean().backward()\n\n    unused = [\n        name\n        for name, parameter in model.named_parameters()\n        if parameter.requires_grad and parameter.grad is None\n    ]\n    assert unused == [\n        \"transformer_decoder.layers.0.self_attn.in_proj_weight\",\n        \"transformer_decoder.layers.0.self_attn.in_proj_bias\",\n        \"transformer_decoder.layers.0.self_attn.out_proj.weight\",\n        \"transformer_decoder.layers.0.self_attn.out_proj.bias\",\n        \"transformer_decoder.layers.0.norm1.weight\",\n        \"transformer_decoder.layers.0.norm1.bias\",\n    ]\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/bash -lc \"sed -n '220,520p' Body-Tell/reports/26-05-24/bodytell_voxtell_alignment_plan_2026-05-24.html\"","aggregated_output":"            <td>当前 encoder 无法复用 VoxTell encoder 权重，也很可能限制性能上限。这个差异不是“轻量配置”，而是 backbone 类型不同。</td>\n            <td><code>Body-Tell/body_tell/models/voxtell_body_model.py:155</code>、<code>VoxTell/models-weight/voxtell/voxtell_v1.1/plans.json:20</code>、<code>VoxTell/voxtell/model/voxtell_model.py:131</code></td>\n          </tr>\n          <tr>\n            <td>Mask projections（含 <code>num_heads</code>）</td>\n            <td><span class=\"tag bad\">真实存在</span> 两层根因：(1) Body-Tell 配置写 5，但运行时被 <code>min(num_maskformer_stages, len(encoder_channels)-1)</code> 截成 4 级；(2) Body-Tell <code>num_heads=32</code>（<code>voxtell_body_model.py:29</code>）vs VoxTell <code>num_heads=1</code>（<code>voxtell_model.py:74</code>）。两者乘积决定实际 projection 输出。</td>\n            <td>Body-Tell 实际输出 <code>[32, 2048, 4096, 8192]</code>（<code>channels × 32</code>，stage 0 例外）；VoxTell 实际输出 <strong><code>[32, 64, 128, 256, 320]</code> 量级</strong>（<code>channels × 1</code>）。<strong>原报告写 VoxTell 最高级 <code>10240</code> 是错误的。</strong> 即使 encoder 升到 6 级、stage 截断消除，<code>num_heads</code> 不同会导致 <code>project_to_decoder_channels.*</code> 与下游 mask fusion 模块的 shape 不匹配，权重无法直接复用。</td>\n            <td><code>Body-Tell/body_tell/models/voxtell_body_model.py:29</code>、<code>:83</code>、<code>:89</code>；<code>VoxTell/voxtell/model/voxtell_model.py:74</code>、<code>:177</code>、<code>:370</code></td>\n          </tr>\n          <tr>\n            <td>Decoder</td>\n            <td><span class=\"tag bad\">真实存在</span> Body-Tell 是 4-stage 手写 decoder，<code>GroupNorm + GELU</code>；VoxTell 是 5-stage <code>VoxTellDecoder</code>，使用 <code>StackedConvBlocks</code> 并继承 encoder 的 <code>InstanceNorm3d + LeakyReLU + conv_bias=true</code>。</td>\n            <td>当前 decoder 无法复用 VoxTell decoder 权重。VoxTell 还总是构造 <code>seg_layers</code>，用于 checkpoint 兼容。</td>\n            <td><code>Body-Tell/body_tell/models/voxtell_body_model.py:174</code>、<code>VoxTell/voxtell/model/voxtell_model.py:280</code></td>\n          </tr>\n          <tr>\n            <td>Position / memory 排列</td>\n            <td><span class=\"tag warn\">真实存在</span> Body-Tell 动态生成 <code>D,H,W</code> 顺序的位置编码；VoxTell 使用 init 时固定的 <code>pos_embed</code> buffer，并用 <code>H,W,D</code> 顺序 flatten。</td>\n            <td>Body-Tell 当前 <code>volume_size=[129,108,256]</code>（见 <code>configs/phase1_voxtell_body.yaml:25</code>，2026-05-24 commit <code>5c31e57</code> 后裁剪到此尺寸）不是 192³，直接加载 VoxTell <code>pos_embed</code> 会遇到 shape/语义问题。需要明确动态重建或改成 192³ profile。</td>\n            <td><code>Body-Tell/body_tell/models/voxtell_body_model.py:118</code>、<code>VoxTell/voxtell/model/voxtell_model.py:185</code>、<code>:229</code></td>\n          </tr>\n        </tbody>\n      </table>\n    </section>\n\n    <section>\n      <h2>目标状态</h2>\n      <p>新增一个 VoxTell-aligned 架构路径，而不是在现有轻量模型上做零散补丁。该路径的 state dict 命名应尽量贴近 VoxTell，降低权重加载映射复杂度。</p>\n\n      <table>\n        <thead>\n          <tr><th>模块</th><th>目标实现</th><th>权重复用要求</th></tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><code>encoder</code></td>\n            <td>使用 <code>dynamic_network_architectures.building_blocks.residual_encoders.ResidualEncoder</code>，参数与 VoxTell v1.1 plan 一致。</td>\n            <td>加载 VoxTell <code>encoder.*</code> 权重，shape mismatch 必须报错。</td>\n          </tr>\n          <tr>\n            <td><code>decoder</code></td>\n            <td>移植 VoxTell <code>VoxTellDecoder</code>，保留 5 个 stage、<code>StackedConvBlocks</code>、<code>seg_layers</code> always-built 语义。</td>\n            <td>加载 VoxTell <code>decoder.*</code> 权重；为了严格兼容，可保留 <code>self.encoder = encoder</code> 这一共享引用。</td>\n          </tr>\n          <tr>\n            <td><code>transformer_decoder</code></td>\n            <td>与 VoxTell 的 <code>TransformerDecoderLayer</code> 行为一致：默认 <code>relu</code>，pre-norm 不执行 self-attention。</td>\n            <td>同名加载 VoxTell transformer 权重；保留 self-attention 参数，即使 active path 不使用。</td>\n          </tr>\n          <tr>\n            <td><code>project_bottleneck_embed</code></td>\n            <td>使用 VoxTell 命名，替代当前 <code>project_visual_embed</code>；结构仍为 <code>320 -&gt; 2048 -&gt; 2048</code>。</td>\n            <td>直接加载 VoxTell <code>project_bottleneck_embed.*</code>。</td>\n          </tr>\n          <tr>\n            <td><code>project_text_embed</code></td>\n            <td>保持 <code>2560 -&gt; 2048 -&gt; 2048</code>。</td>\n            <td>直接加载 VoxTell <code>project_text_embed.*</code>。</td>\n          </tr>\n          <tr>\n            <td><code>project_to_decoder_channels</code> + <code>num_heads</code></td>\n            <td>使用 VoxTell 命名，替代当前 <code>mask_projections</code>；5 级；输出维度 = encoder 各级 channels × <code>num_heads</code>。<strong>条件性对齐</strong>（父表 #13，域差异豁免）：如果实验目标是<strong>直接复用 VoxTell <code>project_to_decoder_channels.*</code> 和 mask fusion 权重</strong>，则必须设 <code>num_heads=1</code>，实际输出 <code>[32, 64, 128, 256, 320]</code> 量级；如果仅做结构对齐而不复用这部分权重（更符合 Body-Tell occupancy grid 任务的需求，因为 <code>num_heads=32</code> 提供 32× mask fusion 容量是为该任务调过的），则保留 <code>num_heads=32</code>。</td>\n            <td>选 <code>num_heads=1</code>：直接加载 VoxTell <code>project_to_decoder_channels.*</code>。选保留 <code>num_heads=32</code>：必须把 <code>project_to_decoder_channels.*</code> 与 mask fusion 相关 key 全部加入跳过白名单，并在 audit 中登记\"为保留 Body-Tell mask fusion 容量而跳过这部分权重复用\"。</td>\n          </tr>\n          <tr>\n            <td><code>pos_embed</code></td>\n            <td>提供两种 policy：<code>dynamic_hwd</code> 用于当前非 192³ Body-Tell 输入；<code>fixed_voxtell_192</code> 用于严格复刻 VoxTell patch。</td>\n            <td><code>dynamic_hwd</code> 模式跳过 checkpoint 中 <code>pos_embed</code>；<code>fixed_voxtell_192</code> 模式要求 shape 完全匹配。</td>\n          </tr>\n        </tbody>\n      </table>\n    </section>\n\n    <section>\n      <h2>实施阶段</h2>\n\n      <h3>P0：建立兼容性基线</h3>\n      <ol>\n        <li><strong>（2026-05-24 新增）<code>num_heads</code> 与 projection shape 显式审计</strong>：新增 <code>Body-Tell/scripts/audit_voxtell_alignment.py</code>（如果与已有 <code>scripts/parameter_audit.py</code> 重合，应共享 utilities）。<strong>脚本第一步必须打印两侧 <code>num_heads</code> 值和每级 <code>project_to_decoder_channels</code> 实际输出 shape</strong>，确认 VoxTell 为 <code>num_heads=1</code> + 输出 <code>[32, 64, 128, 256, 320]</code> 量级，Body-Tell 当前为 <code>num_heads=32</code> + 输出 <code>[32, 2048, 4096, 8192]</code>。该审计是父表 #13 <code>num_heads</code> 决议（路径 A vs 路径 B）的输入材料，audit 完成后才能在 P4 选定路径。</li>\n        <li>实例化 Body-Tell aligned model 和 VoxTell v1.1 model，输出总参数、模块参数、state dict key/shape 覆盖率。</li>\n        <li>新增 transformer golden test <code>Body-Tell/tests/test_voxtell_transformer_compat.py</code>：同一小尺寸 state dict、相同输入、dropout=0 时，Body-Tell aligned transformer 输出必须与 VoxTell transformer 完全一致或在 <code>1e-6</code> 内。</li>\n        <li>新增 weight key audit：读取 <code>VoxTell/models-weight/voxtell/voxtell_v1.1/fold_0/checkpoint_final.pth</code>（已确认文件存在）的 <code>network_weights</code>，检查除 <code>pos_embed</code> 外的目标 key 是否全部可加载。</li>\n      </ol>\n      <p>验收：当前轻量模型仍可跑旧测试；新增审计能明确报告哪些 key 会加载、哪些 key 因 policy 跳过；<strong>且 <code>num_heads</code> 决议（设为 1 / 保留 32）必须先于 P4 落地</strong>。</p>\n\n      <h3>P1：先修 transformer decoder 语义</h3>\n      <ol>\n        <li>把 <code>Body-Tell/body_tell/models/transformer.py</code> 的 active <code>forward_pre</code> 改为 VoxTell 版本：从 <code>norm2 -&gt; cross_attn -&gt; norm3 -&gt; FFN</code> 开始，不执行 self-attention。</li>\n        <li>构造层时去掉 <code>activation=\"gelu\"</code>，或显式设为 <code>relu</code>，与 VoxTell 默认一致。</li>\n        <li>保留 <code>self_attn</code>、<code>norm1</code> 等参数名和 shape，保证 checkpoint key 不变。</li>\n      </ol>\n      <p>验收：Body-Tell aligned transformer 与 VoxTell transformer 小模型 parity test 通过；加载 VoxTell <code>transformer_decoder.*</code> 后无 missing/unexpected/shape mismatch。</p>\n\n      <h3>P2：替换 encoder 为 VoxTell residual encoder</h3>\n      <ol>\n        <li>新增配置文件 <code>Body-Tell/configs/phase1_voxtell_aligned.yaml</code>，设置 <code>encoder_channels: [32,64,128,256,320,320]</code>、<code>n_blocks_per_stage: [1,3,4,6,6,6]</code>、<code>decoder_layer: 4</code>、<code>num_maskformer_stages: 5</code>。</li>\n        <li>在模型配置中加入 <code>architecture: voxtell_v1_1</code> 或 <code>backbone: residual_encoder</code>，让旧轻量模型和 aligned 模型可并存。</li>\n        <li>使用 VoxTell 相同构造参数：<code>conv_bias=true</code>、<code>InstanceNorm3d(eps=1e-5, affine=True)</code>、<code>LeakyReLU(inplace=True)</code>、<code>BasicBlockD</code>、<code>return_skips=True</code>、<code>disable_default_stem=False</code>。</li>\n        <li>把依赖写入 Body-Tell 环境声明：<code>dynamic-network-architectures&gt;=0.4.1,&lt;0.5</code> 和 <code>einops</code>。若采用 VoxTell 原始位置编码实现，再加入 <code>positional-encodings</code>。</li>\n      </ol>\n      <p>验收：encoder 参数约 <code>90.30M</code>；输出 6 个 skip；<code>encoder.output_channels</code> 和 <code>encoder.strides</code> 与 VoxTell 一致；VoxTell <code>encoder.*</code> 权重可加载。</p>\n\n      <h3>P3：替换 decoder 为 VoxTellDecoder</h3>\n      <ol>\n        <li>移植 <code>VoxTellDecoder</code> 到 Body-Tell 模型代码或独立模块，优先保持源码结构、字段名和 state dict key 兼容。</li>\n        <li>使用 <code>n_conv_per_stage_decoder=[1,1,1,1,1]</code>，并继承 encoder 的 conv/norm/nonlin/dropout/bias。</li>\n        <li>即使 <code>deep_supervision=false</code>，也总是构造 5 个 <code>seg_layers</code>，与 VoxTell checkpoint 兼容。</li>\n        <li>移除 Body-Tell 当前 decoder 中 upconv 后的自动 <code>F.interpolate</code> fallback；如果输入尺寸不能通过转置卷积对齐，应在测试中显式暴露，或在数据裁剪 policy 中解决。</li>\n      </ol>\n      <p>验收：decoder 本体参数约 <code>12.18M</code>；5 个 stage / 5 个 transposed conv / 5 个 seg layer；VoxTell <code>decoder.*</code> 权重可加载。统计 decoder 参数时需扣除共享 encoder，避免误读为 <code>102.47M</code>。</p>\n\n      <h3>P4：对齐 projection、mask head、<code>num_heads</code> 决议和 forward 排列</h3>\n      <div class=\"callout warnbox\"><strong>P4 <code>num_heads</code> 决议（父表 #13，域差异豁免）</strong>：在执行 P4 前必须先选定路径——\n        <ul>\n          <li><strong>路径 A（强对齐，复用权重）</strong>：<code>num_heads=1</code>，projection 输出 <code>[32, 64, 128, 256, 320]</code>，可直接加载 VoxTell <code>project_to_decoder_channels.*</code> 与 mask fusion 权重。代价：失去 Body-Tell 现有 32× mask fusion 容量。</li>\n          <li><strong>路径 B（结构对齐但放弃这部分权重复用，推荐）</strong>：保留 <code>num_heads=32</code>，projection 输出维持 <code>[32, 2048, 4096, 8192, 10240]</code>（encoder 升 6 级后扩展），<code>project_to_decoder_channels.*</code> 与 mask fusion 权重 <strong>不加载</strong>，加入 P6 跳过白名单。理由：Body-Tell 处理 occupancy grid 与 VoxTell 医学影像任务差异显著，这部分权重的可迁移性弱，而 mask fusion 容量对当前任务更有价值。</li>\n        </ul>\n        默认建议路径 B，并在 P0 audit 中显式打印决议来源。如果 audit 没有给出明确收益对比，<strong>保持现状（路径 B）即可，不强制对齐 <code>num_heads</code></strong>。\n      </div>\n      <ol>\n        <li><strong>（2026-05-24 修订）<code>num_heads</code> 决议生效</strong>：按上方选定路径执行。路径 A 需把配置 <code>num_heads</code> 默认值改为 <code>1</code>，同时审计 Body-Tell 中所有依赖 <code>num_heads</code> 的 reshape（如 <code>view(B, num_heads, C//num_heads)</code>）和 decoder stage 内 <code>input_features + num_heads</code> 的通道拼接是否正确退化；路径 B 不改 <code>num_heads</code>，但需要在 P6 把 <code>project_to_decoder_channels.*</code> 与 mask fusion 相关 key 加入跳过白名单。</li>\n        <li>把当前 <code>project_visual_embed</code> 改为 VoxTell 命名 <code>project_bottleneck_embed</code>；把 <code>mask_projections</code> 改为 <code>project_to_decoder_channels</code>。</li>\n        <li>encoder 变为 6-stage 后，projection stage 自然恢复为 5 级，不再用 <code>len(encoder_channels)-1</code> 隐式截断配置。</li>\n        <li>forward 中使用 VoxTell 的 memory 排列：<code>b c d h w -&gt; b h w d c -&gt; (h w d) b c</code>。</li>\n        <li>decoder 输出仍保持 Body-Tell 训练和推理需要的 <code>(B, N, D, H, W)</code> 语义；如果内部沿用 VoxTell 注释中的 <code>h,w,d</code> 命名，需要在单测里用非立方输入验证轴没有被误换。</li>\n      </ol>\n      <p>验收：5 个 projection 输出维度按选定路径（路径 A: <code>[32, 64, 128, 256, 320]</code>；路径 B: <code>[32, 2048, 4096, 8192, 10240]</code>）；非立方输入的输出 shape 与 target mask 完全一致；mask fusion 模块在选定 <code>num_heads</code> 下有显式单测；audit 报告记录选定路径与原因。</p>\n\n      <h3>P5：位置编码策略</h3>\n      <table>\n        <thead>\n          <tr><th>策略</th><th>适用场景</th><th>实现方式</th><th>权重加载</th></tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td><code>dynamic_hwd</code></td>\n            <td>推荐用于当前 Body-Tell 数据，因为 <code>[129,108,256]</code>（commit <code>5c31e57</code> 后的实际 crop 尺寸）不是 VoxTell 的 192³ patch。</td>\n            <td>按 selected feature 的实时 <code>H,W,D</code> 生成 deterministic 3D positional encoding，并缓存到 device/dtype。</td>\n            <td>跳过 VoxTell checkpoint 的 <code>pos_embed</code>，其余权重严格加载。</td>\n          </tr>\n          <tr>\n            <td><code>fixed_voxtell_192</code></td>\n            <td>用于做完全复刻实验，或想验证整份 VoxTell state dict 可严格加载。</td>\n            <td>把 Body-Tell 数据裁剪/填充到 <code>[192,192,192]</code>，注册 shape 为 <code>(1728,1,2048)</code> 的 <code>pos_embed</code>。</td>\n            <td>要求 checkpoint 中 <code>pos_embed</code> 直接加载；数据体素尺寸也必须配套调整。</td>\n          </tr>\n        </tbody>\n      </table>\n      <p>建议先落地 <code>dynamic_hwd</code>。它牺牲的是固定 buffer 的逐元素复用，不牺牲 transformer 权重语义；对当前非立方 Body-Tell 数据更可实现。</p>\n\n      <h3>P6：权重加载入口</h3>\n      <ol>\n        <li>新增训练参数 <code>--init-from-voxtell VoxTell/models-weight/voxtell/voxtell_v1.1</code>，在 optimizer 构造前加载。</li>\n        <li>新增 loader：读取 <code>fold_0/checkpoint_final.pth</code> 的 <code>network_weights</code>，按当前 aligned 模型 key 直接加载。</li>\n        <li><strong>（2026-05-24 修订）显式 <code>unexpected_keys</code> 白名单</strong>：调用 <code>model.load_state_dict(state_dict, strict=False)</code> 后，断言 <code>set(unexpected_keys) ⊆ POLICY_ALLOWED_SKIP</code>（默认 <code>{\"pos_embed\"}</code>；若 P4 决定保留 <code>num_heads=32</code>，再扩展到 <code>{\"pos_embed\", \"project_to_decoder_channels.*\", \"decoder.<mask_fusion_keys>\"}</code>）。<strong>任何 shape mismatch 必须抛错，不得静默跳过</strong>；<code>missing_keys</code> 不为空时打印完整列表并要求显式确认。</li>\n        <li>日志记录 loaded tensor 数、loaded 参数数、skipped key、missing key、unexpected key，并写入训练 checkpoint 的 <code>config.init_from_voxtell</code>。</li>\n        <li>不要把旧 Body-Tell checkpoint 与 aligned 模型静默混用。旧 checkpoint 应只用于旧架构；aligned checkpoint 应带 <code>architecture: voxtell_v1_1</code>。</li>\n      </ol>\n      <p>验收：在 CPU 上能完成权重加载审计；<code>unexpected_keys</code> 与 policy 白名单一致；在 GPU 上能完成至少 1 个 batch 的 forward/loss/backward smoke。</p>\n\n      <h3>P7：训练实验矩阵</h3>\n      <table>\n        <thead>\n          <tr><th>实验</th><th>初始化</th><th>目的</th><th>建议</th></tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td>A：当前基线</td>\n            <td>现有轻量 Body-Tell checkpoint</td>\n            <td>保持可回退基线。</td>\n            <td>记录当前 val foreground Dice 约 <code>0.3257</code>。</td>\n          </tr>\n          <tr>\n            <td>B：aligned random</td>\n            <td>VoxTell-aligned 结构，随机初始化</td>\n            <td>分离“结构变大”与“VoxTell 权重”的收益。</td>\n            <td>先跑短程，确认显存和 loss 曲线。</td>\n          </tr>\n          <tr>\n            <td>C：aligned prompt-only</td>\n            <td>只加载 transformer / text / projection 权重</td>\n            <td>评估 prompt decoder 复用本身的收益。</td>\n            <td>可作为中间回退，因为 encoder 输入域差异最大。</td>\n          </tr>\n          <tr>\n            <td>D：aligned full</td>\n            <td>加载 encoder、decoder、projection、transformer；按 policy 跳过或加载 <code>pos_embed</code></td>\n            <td>完整复用 VoxTell 权重，验证性能上限。</td>\n            <td>使用分组学习率：prompt/transformer 较低，encoder/decoder 可稍高；不要一开始冻结全部 encoder。</td>\n          </tr>\n        </tbody>\n      </table>\n    </section>\n\n    <section>\n      <h2>验收命令</h2>\n      <pre><code># 1. Transformer 行为必须与 VoxTell 对齐\npython -m pytest Body-Tell/tests/test_voxtell_transformer_compat.py\n\n# 2. 架构和 state dict key/shape 审计\npython Body-Tell/scripts/audit_voxtell_alignment.py \\\n  --config Body-Tell/configs/phase1_voxtell_aligned.yaml \\\n  --voxtell-dir VoxTell/models-weight/voxtell/voxtell_v1.1 \\\n  --pos-embed-policy dynamic_hwd\n\n# 3. 训练 smoke，验证 forward/loss/backward/checkpoint\ncd Body-Tell\npython train.py \\\n  --config configs/phase1_voxtell_aligned.yaml \\\n  --init-from-voxtell ../VoxTell/models-weight/voxtell/voxtell_v1.1 \\\n  --smoke --epochs 2 --batch-size 1 --num-workers 0 --amp\n\n# 4. 推理 smoke，必须 strict 加载新 checkpoint\npython inference.py \\\n  --checkpoint checkpoints/voxtell_aligned_smoke/best.pt \\\n  --config configs/phase1_voxtell_aligned.yaml \\\n  --case-id S2I_00001 --prompts liver \\\n  --output outputs/inference_voxtell_aligned_smoke \\\n  --device cuda --gpu 0 --amp --prompt-batch-size 1</code></pre>\n    </section>\n\n    <section>\n      <h2>主要风险</h2>\n      <table>\n        <thead>\n          <tr><th>风险</th><th>影响</th><th>控制方式</th></tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td>显存和训练成本上升</td>\n            <td>模型从 <code>328.98M</code> 增至约 <code>440.03M</code>，encoder activation 也明显变大。</td>\n            <td>先用 batch=1、AMP、短程 smoke；必要时加入 gradient checkpointing 或降低 prompt batch。</td>\n          </tr>\n          <tr>\n            <td>VoxTell encoder 输入域是医学影像，Body-Tell 是 occupancy grid</td>\n            <td>完整加载 encoder 不一定优于随机初始化，甚至可能初期收敛慢。</td>\n            <td>保留 random / prompt-only / full 三组 A/B；使用分组学习率，不把 full 权重复用当作唯一方案。</td>\n          </tr>\n          <tr>\n            <td>非 192³ 输入与 fixed <code>pos_embed</code> 冲突</td>\n            <td>严格加载整份 VoxTell state dict 会失败或语义错误。</td>\n            <td>默认 <code>dynamic_hwd</code> 并明确跳过 <code>pos_embed</code>；另建 <code>fixed_voxtell_192</code> profile 做完整复刻。</td>\n          </tr>\n          <tr>\n            <td>旧 Body-Tell checkpoint 与新结构不兼容</td>\n            <td>推理/恢复训练可能 silent mismatch 或 strict load fail。</td>\n            <td>checkpoint 中记录 <code>architecture</code>；inference strict 校验；不给旧 checkpoint 自动迁移到 aligned 结构。</td>\n          </tr>\n          <tr>\n            <td>直接复制 VoxTell decoder 会引入共享 encoder 引用</td>\n            <td>参数统计容易误读，state dict 可能包含共享模块路径。</td>\n            <td>为了权重兼容优先保留 VoxTell 结构；审计脚本单独报告 decoder-own 参数。</td>\n          </tr>\n        </tbody>\n      </table>\n    </section>\n\n    <section>\n      <h2>建议优先级</h2>\n      <ol>\n        <li><strong>（2026-05-24 上调）P0 <code>num_heads</code> 与 projection shape 审计</strong>。这是父表 #13 <code>num_heads</code> 决议的输入材料；不在 P4 落地前完成审计，P3/P4/P6 都会建立在未经确认的输出维度假设上。允许 audit 结论是\"保留 <code>num_heads=32</code>\"（路径 B），但必须显式记录。</li>\n        <li><strong>P1 transformer 语义对齐。</strong> 当前最危险的不一致，因为 shape 能加载会掩盖语义错误。</li>\n        <li><strong>随后做 P2/P3 encoder 和 decoder。</strong> 当前 encoder 参数差距过大且结构不同，性能问题很可能与此相关；若目标是对齐 VoxTell，不应继续保留轻量自定义 backbone 作为主路线。</li>\n        <li><strong>P5 位置编码要在权重加载前定策略。</strong> 当前 Body-Tell 非立方 volume（<code>[129,108,256]</code>）不适合直接复用 VoxTell 固定 <code>pos_embed</code>。</li>\n        <li><strong>最后才跑完整训练实验。</strong> 没有 architecture/weight audit 通过前，不建议直接用 VoxTell checkpoint warm-start 长训。</li>\n      </ol>\n    </section>\n  </main>\n</body>\n</html>\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,240p' Body-Tell/tests/test_prompt_loss_backward.py\"","aggregated_output":"from __future__ import annotations\n\nimport torch\n\nfrom body_tell.losses.prompt_losses import PromptSegmentationLoss\nfrom body_tell.metrics.prompt_metrics import compute_prompt_metrics\n\n\ndef test_prompt_segmentation_loss_backpropagates() -> None:\n    torch.manual_seed(0)\n    logits = torch.randn(2, 3, 6, 5, 4, requires_grad=True)\n    targets = (torch.rand(2, 3, 6, 5, 4) > 0.7).float()\n    targets[:, 2] = 0.0\n\n    criterion = PromptSegmentationLoss(bce_weight=0.5, dice_weight=0.5)\n    result = criterion(logits, targets)\n\n    assert set(result) == {\"loss\", \"bce_loss\", \"dice_loss\"}\n    assert result[\"loss\"].ndim == 0\n    result[\"loss\"].backward()\n    assert logits.grad is not None\n    assert torch.isfinite(logits.grad).all()\n\n\ndef test_prompt_metrics_report_positive_dice_and_negative_fp_rate() -> None:\n    logits = torch.full((1, 3, 4, 4, 4), -8.0)\n    targets = torch.zeros_like(logits)\n    targets[:, 0, 1:3, 1:3, 1:3] = 1.0\n    logits[:, 0, 1:3, 1:3, 1:3] = 8.0\n    logits[:, 2, 0, 0, 0] = 8.0\n    target_empty = torch.tensor([[False, True, True]])\n\n    metrics = compute_prompt_metrics(logits, targets, target_empty=target_empty)\n\n    assert metrics[\"foreground_mean_dice\"] > 0.99\n    assert metrics[\"negative_fp_rate\"] == 1.0 / (2 * 4 * 4 * 4)\n\n\ndef test_prompt_loss_ignores_invalid_padding_prompts() -> None:\n    torch.manual_seed(1)\n    logits = torch.randn(1, 3, 4, 4, 4, requires_grad=True)\n    targets = (torch.rand(1, 3, 4, 4, 4) > 0.65).float()\n    prompt_valid = torch.tensor([[True, True, False]])\n    with torch.no_grad():\n        logits[:, 2] = 20.0\n    targets[:, 2] = 0.0\n\n    criterion = PromptSegmentationLoss(bce_weight=0.5, dice_weight=0.5)\n    masked = criterion(logits, targets, prompt_valid=prompt_valid)\n    sliced = criterion(logits[:, :2], targets[:, :2])\n\n    assert torch.allclose(masked[\"loss\"], sliced[\"loss\"])\n    masked[\"loss\"].backward()\n    assert logits.grad is not None\n    assert logits.grad[:, 2].abs().sum().item() == 0.0\n\n\ndef test_prompt_metrics_ignore_invalid_padding_prompts() -> None:\n    logits = torch.full((1, 3, 4, 4, 4), -8.0)\n    targets = torch.zeros_like(logits)\n    target_empty = torch.tensor([[False, True, True]])\n    prompt_valid = torch.tensor([[True, True, False]])\n\n    targets[:, 0, 1:3, 1:3, 1:3] = 1.0\n    logits[:, 0, 1:3, 1:3, 1:3] = 8.0\n    logits[:, 2] = 8.0\n\n    metrics = compute_prompt_metrics(\n        logits,\n        targets,\n        target_empty=target_empty,\n        prompt_valid=prompt_valid,\n    )\n\n    assert metrics[\"foreground_mean_dice\"] > 0.99\n    assert metrics[\"negative_fp_rate\"] == 0.0\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_8","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,260p' Body-Tell/body_tell/models/voxtell_body_model.py\"","aggregated_output":"\"\"\"VoxTell-style prompt-conditioned model adapted for Body-Tell occupancy grids.\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nfrom dataclasses import dataclass\nfrom typing import List, Sequence, Tuple\n\nimport torch\nimport torch.nn.functional as F\nfrom torch import Tensor, nn\n\nfrom .transformer import TransformerDecoder, TransformerDecoderLayer\n\n\nVOXTELL_V1_1_ENCODER_CHANNELS: Tuple[int, ...] = (32, 64, 128, 256, 320, 320)\nVOXTELL_V1_1_N_BLOCKS_PER_STAGE: Tuple[int, ...] = (1, 3, 4, 6, 6, 6)\n\n\n@dataclass(frozen=True)\nclass VoxTellBodyConfig:\n    input_channels: int = 1\n    encoder_channels: Tuple[int, ...] = (32, 64, 128, 256, 320)\n    backbone: str = \"conv\"\n    n_blocks_per_stage: Tuple[int, ...] | None = None\n    encoder_conv_bias: bool = True\n    encoder_norm: str = \"instance_norm_3d\"\n    encoder_activation: str = \"leaky_relu\"\n    text_embedding_dim: int = 2560\n    query_dim: int = 2048\n    text_projection_hidden_dim: int = 2048\n    transformer_num_heads: int = 8\n    transformer_layers: int = 6\n    transformer_feedforward_dim: int = 2048\n    transformer_dropout: float = 0.1\n    decoder_layer: int = -1\n    num_maskformer_stages: int = 5\n    num_heads: int = 32\n    deep_supervision: bool = False\n\n\nclass VoxTellBodyModel(nn.Module):\n    \"\"\"Prompt-conditioned binary mask model using VoxTell-style dynamic heads.\"\"\"\n\n    def __init__(self, config: VoxTellBodyConfig | None = None) -> None:\n        super().__init__()\n        self.config = config or VoxTellBodyConfig()\n        if self.config.query_dim % self.config.transformer_num_heads != 0:\n            raise ValueError(\"query_dim must be divisible by transformer_num_heads\")\n        if len(self.config.encoder_channels) < 2:\n            raise ValueError(\"encoder_channels must contain at least two stages\")\n        if self.config.num_maskformer_stages < 1:\n            raise ValueError(\"num_maskformer_stages must be at least 1 for the dynamic mask head\")\n\n        encoder_channels = tuple(int(channel) for channel in self.config.encoder_channels)\n        self.encoder = self._build_encoder(encoder_channels)\n        selected_stage = self.config.decoder_layer\n        if selected_stage < 0:\n            selected_stage = len(encoder_channels) + selected_stage\n        if selected_stage < 0 or selected_stage >= len(encoder_channels):\n            raise ValueError(\"decoder_layer selects no encoder stage\")\n        self.selected_stage = selected_stage\n\n        selected_channels = encoder_channels[self.selected_stage]\n        self.project_visual_embed = nn.Sequential(\n            nn.Linear(selected_channels, self.config.query_dim),\n            nn.GELU(),\n            nn.Linear(self.config.query_dim, self.config.query_dim),\n        )\n        self.project_text_embed = nn.Sequential(\n            nn.Linear(self.config.text_embedding_dim, self.config.text_projection_hidden_dim),\n            nn.GELU(),\n            nn.Linear(self.config.text_projection_hidden_dim, self.config.query_dim),\n        )\n\n        layer = TransformerDecoderLayer(\n            d_model=self.config.query_dim,\n            nhead=self.config.transformer_num_heads,\n            dim_feedforward=self.config.transformer_feedforward_dim,\n            dropout=self.config.transformer_dropout,\n            activation=\"relu\",\n            normalize_before=True,\n        )\n        self.transformer_decoder = TransformerDecoder(\n            decoder_layer=layer,\n            num_layers=self.config.transformer_layers,\n            norm=nn.LayerNorm(self.config.query_dim),\n        )\n\n        self.fused_stage_count = min(\n            self.config.num_maskformer_stages,\n            len(encoder_channels) - 1,\n        )\n        self.mask_projections = nn.ModuleList()\n        for stage_index, channels in enumerate(encoder_channels[: self.fused_stage_count]):\n            output_dim = channels if stage_index == 0 else channels * self.config.num_heads\n            self.mask_projections.append(\n                nn.Sequential(\n                    nn.Linear(self.config.query_dim, self.config.text_projection_hidden_dim),\n                    nn.GELU(),\n                    nn.Linear(self.config.text_projection_hidden_dim, output_dim),\n                )\n            )\n\n        self.decoder = _VoxTellBodyDecoder(\n            encoder_channels=encoder_channels,\n            num_heads=self.config.num_heads,\n            fused_stage_count=self.fused_stage_count,\n            deep_supervision=self.config.deep_supervision,\n        )\n\n    def _build_encoder(self, encoder_channels: Tuple[int, ...]) -> nn.Module:\n        backbone = self.config.backbone.lower().replace(\"-\", \"_\")\n        if backbone in {\"conv\", \"body_conv\", \"legacy_conv\"}:\n            return _BodyEncoder(\n                input_channels=self.config.input_channels,\n                channels=encoder_channels,\n            )\n        if backbone in {\"residual_encoder\", \"voxtell_residual_encoder\"}:\n            return _build_voxtell_residual_encoder(\n                input_channels=self.config.input_channels,\n                channels=encoder_channels,\n                n_blocks_per_stage=_resolve_n_blocks_per_stage(\n                    encoder_channels,\n                    self.config.n_blocks_per_stage,\n                ),\n                conv_bias=self.config.encoder_conv_bias,\n                norm=self.config.encoder_norm,\n                activation=self.config.encoder_activation,\n            )\n        raise ValueError(\n            \"backbone must be one of 'conv' or 'residual_encoder', \"\n            f\"got {self.config.backbone!r}\"\n        )\n\n    def forward(self, occupancy: Tensor, text_embeddings: Tensor) -> Tensor | List[Tensor]:\n        if text_embeddings.ndim == 4 and text_embeddings.shape[2] == 1:\n            text_embeddings = text_embeddings.squeeze(2)\n        if text_embeddings.ndim != 3:\n            raise ValueError(\n                \"text_embeddings must have shape (B, N, E) or (B, N, 1, E), \"\n                f\"got {tuple(text_embeddings.shape)}\"\n            )\n\n        skips = self.encoder(occupancy)\n        selected_feature = skips[self.selected_stage]\n        batch_size, channels, depth, height, width = selected_feature.shape\n\n        memory = selected_feature.permute(2, 3, 4, 0, 1).reshape(-1, batch_size, channels)\n        memory = self.project_visual_embed(memory)\n        pos = sinusoidal_position_encoding_3d(\n            (depth, height, width),\n            self.config.query_dim,\n            device=memory.device,\n            dtype=memory.dtype,\n        )\n\n        text_queries = text_embeddings.permute(1, 0, 2)\n        text_queries = self.project_text_embed(text_queries)\n        mask_embedding, _ = self.transformer_decoder(\n            tgt=text_queries,\n            memory=memory,\n            pos=pos,\n        )\n        mask_embedding = mask_embedding.permute(1, 0, 2)\n\n        stage_embeddings = [projection(mask_embedding) for projection in self.mask_projections]\n        num_prompts = text_embeddings.shape[1]\n        per_prompt_outputs: List[List[Tensor]] = []\n        for prompt_index in range(num_prompts):\n            prompt_stage_embeddings = [\n                embedding[:, prompt_index : prompt_index + 1, :]\n                for embedding in stage_embeddings\n            ]\n            per_prompt_outputs.append(self.decoder(skips, prompt_stage_embeddings))\n\n        outputs = [\n            torch.cat(scale_outputs, dim=1)\n            for scale_outputs in zip(*per_prompt_outputs)\n        ]\n        if self.config.deep_supervision:\n            return outputs\n        return outputs[0]\n\n\nclass _BodyEncoder(nn.Module):\n    def __init__(self, input_channels: int, channels: Sequence[int]) -> None:\n        super().__init__()\n        self.output_channels = tuple(int(channel) for channel in channels)\n        self.strides = tuple(\n            (1, 1, 1) if index == 0 else (2, 2, 2)\n            for index in range(len(channels))\n        )\n        stages = []\n        current_channels = input_channels\n        for stage_index, output_channels in enumerate(channels):\n            stride = 1 if stage_index == 0 else 2\n            stages.append(_ConvBlock(current_channels, output_channels, stride=stride))\n            current_channels = output_channels\n        self.stages = nn.ModuleList(stages)\n\n    def forward(self, x: Tensor) -> List[Tensor]:\n        skips = []\n        for stage in self.stages:\n            x = stage(x)\n            skips.append(x)\n        return skips\n\n\ndef _build_voxtell_residual_encoder(\n    input_channels: int,\n    channels: Sequence[int],\n    n_blocks_per_stage: Sequence[int],\n    conv_bias: bool,\n    norm: str,\n    activation: str,\n) -> nn.Module:\n    try:\n        from dynamic_network_architectures.building_blocks.residual import BasicBlockD\n        from dynamic_network_architectures.building_blocks.residual_encoders import ResidualEncoder\n    except ImportError as exc:\n        raise RuntimeError(\n            \"backbone='residual_encoder' requires dynamic_network_architectures\"\n        ) from exc\n\n    output_channels = tuple(int(channel) for channel in channels)\n    blocks_per_stage = tuple(int(blocks) for blocks in n_blocks_per_stage)\n    kernel_sizes = tuple((3, 3, 3) for _ in output_channels)\n    strides = tuple(\n        (1, 1, 1) if index == 0 else (2, 2, 2)\n        for index in range(len(output_channels))\n    )\n\n    encoder = ResidualEncoder(\n        input_channels=input_channels,\n        n_stages=len(output_channels),\n        features_per_stage=output_channels,\n        conv_op=nn.Conv3d,\n        kernel_sizes=kernel_sizes,\n        strides=strides,\n        n_blocks_per_stage=blocks_per_stage,\n        conv_bias=bool(conv_bias),\n        norm_op=_resolve_residual_norm(norm),\n        norm_op_kwargs={\"eps\": 1e-5, \"affine\": True},\n        dropout_op=None,\n        dropout_op_kwargs=None,\n        nonlin=_resolve_residual_activation(activation),\n        nonlin_kwargs={\"inplace\": True},\n        block=BasicBlockD,\n        bottleneck_channels=None,\n        return_skips=True,\n        disable_default_stem=False,\n        stem_channels=None,\n    )\n    encoder.output_channels = tuple(int(channel) for channel in encoder.output_channels)\n    encoder.strides = tuple(\n        tuple(int(value) for value in stride)\n        for stride in encoder.strides\n    )\n    encoder.n_blocks_per_stage = blocks_per_stage\n","exit_code":0,"status":"completed"}}
