\\\\\\\\\\\\\\\\\\\\n            norm_op_kwargs: Normalization keyword arguments.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            dropout_op: Dropout operation (inherited from encoder if None).\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            dropout_op_kwargs: Dropout keyword arguments.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            nonlin: Non-linearity operation (inherited from encoder if None).\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            nonlin_kwargs: Non-linearity keyword arguments.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            conv_bias: Whether to use bias in convolutions (inherited from encoder if None).\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            num_heads: Number of attention heads for mask embedding fusion.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        super().__init__()\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        self.deep_supervision = deep_supervision\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        self.encoder = encoder\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        self.num_classes = num_classes\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        self.num_heads = num_heads\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        n_stages_encoder = len(encoder.output_channels)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        if isinstance(n_conv_per_stage, int):\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            n_conv_per_stage = [n_conv_per_stage] * (n_stages_encoder - 1)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        assert len(n_conv_per_stage) == n_stages_encoder - 1, (\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"n_conv_per_stage must have one less entry than encoder stages. \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            f\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"Expected: {n_stages_encoder - 1}, got: {len(n_conv_per_stage)}\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        # Inherit hyperparameters from encoder if not specified\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        transpconv_op = get_matching_convtransp(conv_op=encoder.conv_op)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        conv_bias = encoder.conv_bias if conv_bias is None else conv_bias\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        norm_op = encoder.norm_op if norm_op is None else norm_op\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        norm_op_kwargs = encoder.norm_op_kwargs if norm_op_kwargs is None else norm_op_kwargs\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        dropout_op = encoder.dropout_op if dropout_op is None else dropout_op\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        dropout_op_kwargs = encoder.dropout_op_kwargs if dropout_op_kwargs is None else dropout_op_kwargs\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        nonlin = encoder.nonlin if nonlin is None else nonlin\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        nonlin_kwargs = encoder.nonlin_kwargs if nonlin_kwargs is None else nonlin_kwargs\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        # Build decoder stages from bottleneck to highest resolution\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        stages = []\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        transpconvs = []\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        seg_layers = []\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        for stage_idx in range(1, n_stages_encoder):\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            # Determine input channels: add num_heads for stages with mask embedding fusion\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            if stage_idx <= n_stages_encoder - num_maskformer_stages:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                input_features_below = encoder.output_channels[-stage_idx]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            else:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                input_features_below = encoder.output_channels[-stage_idx] + num_heads\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            input_features_skip = encoder.output_channels[-(stage_idx + 1)]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            stride_for_transpconv = encoder.strides[-stage_idx]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            # Transpose convolution for upsampling\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            transpconvs.append(transpconv_op(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                input_features_below, input_features_skip,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                stride_for_transpconv, stride_for_transpconv,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                bias=conv_bias\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            ))\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            # Convolutional blocks for feature merging\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            # Input features: 2x input_features_skip (concatenated skip + upsampled features)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            stages.append(StackedConvBlocks(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                n_conv_per_stage[stage_idx - 1], encoder.conv_op,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                2 * input_features_skip, input_features_skip,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                encoder.kernel_sizes[-(stage_idx + 1)], 1,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                conv_bias, norm_op, norm_op_kwargs,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                dropout_op, dropout_op_kwargs,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                nonlin, nonlin_kwargs, nonlin_first\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            ))\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            # Segmentation output layer (always built for parameter loading compatibility)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            # This allows models trained with deep_supervision=True to be loaded\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            # for inference with deep_supervision=False\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            seg_layers.append(encoder.conv_op(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                input_features_skip + num_heads, num_classes,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                1, 1, 0, bias=True\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            ))\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        self.stages = nn.ModuleList(stages)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        self.transpconvs = nn.ModuleList(transpconvs)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        self.seg_layers = nn.ModuleList(seg_layers)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    def forward(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        self,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        skips: List[torch.Tensor],\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        mask_embeddings: List[torch.Tensor]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    ) -> List[torch.Tensor]:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        Forward pass through decoder with mask embedding fusion.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        Processes features from bottleneck to highest resolution, fusing\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        mask embeddings at multiple stages via einsum operations.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        Args:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            skips: List of encoder skip connections in computation order.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                Last entry should be bottleneck features.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            mask_embeddings: List of mask embeddings for each decoder stage,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                in order from lowest to highest resolution.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        Returns:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            List of segmentation predictions. If deep_supervision=False,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            returns single-element list with highest resolution prediction.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            If deep_supervision=True, returns predictions at all scales\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            from highest to lowest resolution.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        lres_input = skips[-1]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        seg_outputs = []\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        # Reverse mask embeddings to match decoder stage order (bottleneck first)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        mask_embeddings = mask_embeddings[::-1]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        for stage_idx in range(len(self.stages)):\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            # Upsample and concatenate with skip connection\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            x = self.transpconvs[stage_idx](lres_input)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            x = torch.cat((x, skips[-(stage_idx + 2)]), dim=1)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            x = self.stages[stage_idx](x)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            # Apply mask embedding fusion for relevant stages\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            if stage_idx == (len(self.stages) - 1):\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                # Final stage: generate segmentation via einsum\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                # x: (B, C, H, W, D), mask_embeddings[-1]: (B, N, C)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                # Output: (B, N, H, W, D)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                seg_pred = torch.einsum('b c h w d, b n c -> b n h w d', x, mask_embeddings[-1])\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                seg_outputs.append(seg_pred)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            elif stage_idx >= len(self.stages) - len(mask_embeddings):\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                # Intermediate stages with mask embedding fusion\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                mask_embedding = mask_embeddings.pop(0)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                batch_size, _, channels = mask_embedding.shape\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                # Reshape for multi-head fusion and compute attention-weighted features\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                # Shape: (B, num_heads, C // num_heads)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                mask_embedding_reshaped = mask_embedding.view(batch_size, self.num_heads, -1)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                fusion_features = torch.einsum(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                    'b c h w d, b n c -> b n h w d',\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                    x, mask_embedding_reshaped\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                )\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                # Concatenate fused features with spatial features\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                x = torch.cat((x, fusion_features), dim=1)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n                seg_outputs.append(self.seg_layers[stage_idx](x))\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            lres_input = x\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        # Reverse outputs to have highest resolution first\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        seg_outputs = seg_outputs[::-1]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        if not self.deep_supervision:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            return seg_outputs[:1]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        else:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            return seg_outputs\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":0,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"completed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}}\\\\\\\\\\\\\\\\n{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item_21\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"agent_message\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"text\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"P0 has three concrete deliverables: an audit CLI, transformer parity material for P1, and a P6 skip-policy input. I’m checking the runtime imports now because VoxTell model instantiation depends on its own package plus dynamic-network-architectures.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}}\\\\\\\\\\\\\\\\n{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item.started\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item_22\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/bin/bash -lc 'conda run -n voxtell python --version'\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":null,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"in_progress\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}}\\\\\\\\\\\\\\\\n{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item.started\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item_23\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"conda run -n voxtell python - <<'PY'\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nimport torch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nprint('torch', torch.__version__)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ntry:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    import dynamic_network_architectures\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    print('dynamic_network_architectures ok')\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nexcept Exception as exc:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    print('dynamic_network_architectures error', type(exc).__name__, exc)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ntry:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    import positional_encodings\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    print('positional_encodings ok')\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nexcept Exception as exc:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    print('positional_encodings error', type(exc).__name__, exc)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nPY\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":null,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"in_progress\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}}\\\\\\\\\\\\\\\\n{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item.started\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item_24\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,220p' Body-Tell/tests/test_model_shapes.py && sed -n '1,120p' Body-Tell/conftest.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":null,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"in_progress\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}}\\\\\\\\\\\\\\\\n{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item.started\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item_25\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"find VoxTell -maxdepth 3 -type f | grep -E '(__init__\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\.py|setup|pyproject|requirements|environment)' | sort\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":null,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"in_progress\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"}}\\\\\\\\\\\\\\\\n{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item.completed\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":{\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"item_24\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"type\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"command_execution\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/bin/bash -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,220p' Body-Tell/tests/test_model_shapes.py && sed -n '1,120p' Body-Tell/conftest.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"aggregated_output\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"from __future__ import annotations\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nimport torch\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\nfrom body_tell.models.voxtell_body_model import VoxTellBodyConfig, VoxTellBodyModel\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef test_voxtell_body_model_outputs_prompt_logits_shape() -> None:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    torch.manual_seed(0)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    model = VoxTellBodyModel(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        VoxTellBodyConfig(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            input_channels=1,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            encoder_channels=(4, 8, 16),\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            text_embedding_dim=8,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            query_dim=16,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            transformer_num_heads=4,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            transformer_layers=1,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            num_maskformer_stages=3,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            num_heads=2,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            deep_supervision=False,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    occupancy = torch.randn(2, 1, 16, 16, 16)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    text_embeddings = torch.randn(2, 3, 8)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    logits = model(occupancy, text_embeddings)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    assert logits.shape == (2, 3, 16, 16, 16)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    assert logits.dtype == occupancy.dtype\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef test_voxtell_body_model_supports_deep_supervision() -> None:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    torch.manual_seed(0)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    model = VoxTellBodyModel(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        VoxTellBodyConfig(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            input_channels=1,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            encoder_channels=(4, 8, 16),\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            text_embedding_dim=8,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            query_dim=16,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            transformer_num_heads=4,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            transformer_layers=1,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            num_maskformer_stages=3,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            num_heads=2,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            deep_supervision=True,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    occupancy = torch.randn(1, 1, 16, 16, 16)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    text_embeddings = torch.randn(1, 2, 8)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    logits = model(occupancy, text_embeddings)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    assert isinstance(logits, list)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    assert [tuple(item.shape) for item in logits] == [\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        (1, 2, 16, 16, 16),\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        (1, 2, 8, 8, 8),\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    ]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ndef test_voxtell_body_model_omits_parameters_unused_without_deep_supervision() -> None:\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    torch.manual_seed(0)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    model = VoxTellBodyModel(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        VoxTellBodyConfig(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            input_channels=1,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            encoder_channels=(4, 8, 16),\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            text_embedding_dim=8,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            query_dim=16,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            transformer_num_heads=4,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            transformer_layers=1,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            num_maskformer_stages=3,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            num_heads=2,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n            deep_supervision=False,\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        )\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    assert len(model.mask_projections) == 2\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    assert not [\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        for name, parameter in model.named_parameters()\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        if name.startswith(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"decoder.seg_layers.\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\") and parameter.requires_grad\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    ]\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    occupancy = torch.randn(1, 1, 16, 16, 16)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    text_embeddings = torch.randn(1, 2, 8)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    logits = model(occupancy, text_embeddings)\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    logits.square().mean().backward()\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n    unused = [\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        name\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        for name, parameter in model.named_parameters()\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\n        if parameter.requires_grad and parameter.grad is None\\\\\\\